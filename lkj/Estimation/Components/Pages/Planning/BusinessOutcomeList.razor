@attribute [Route(RoutingPath.BusinessOutcomes)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.JiraLogic
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Microsoft.AspNetCore.WebUtilities
@using Serilog

@inject IBusinessOutcomeService BoService
@inject ICapitalProjectService CapitalProjectService
@inject IDepartmentService DepartmentService
@inject IJiraAuthService JiraAuth
@inject IWindowsAuthService WindowsAuth
@inject NavigationManager Nav
@inject IModalDialogService MessageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJiraIssueService JiraIssueService
@inject IConfiguration Configuration

@implements IDisposable

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6">@PlanningDisplayNames.BusinessOutcomes</MudText>

        <MudToolBar>
            <MudSpacer />
            <div style="position:relative; margin-right: 10px;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ViewColumn"
                           Disabled="_loading"
                           OnClick="() => _columnsPopoverOpen = !_columnsPopoverOpen">
                    Columns
                </MudButton>
                <MudPopover Open="_columnsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:280px">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@PlanningDisplayNames.ToggleColumns</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _columnsPopoverOpen = false" />
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <MudSwitch T="bool" @bind-Value="_showJiraId" Label="@PlanningDisplayNames.JiraId" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showName" Label="@PlanningDisplayNames.Name" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showCapitalProject" Label="@PlanningDisplayNames.CapitalProjec" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showEpicJiraId" Label="@PlanningDisplayNames.EpicId" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showEpic" Label="@PlanningDisplayNames.Epic" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showProgramJiraId" Label="@PlanningDisplayNames.StrategicObjectiveJiraId" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showActions" Label="@PlanningDisplayNames.Actions" Color="Color.Primary" Dense />
                    </div>
                </MudPopover>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Disabled="_loading"
                       Style="margin-right: 10px"
                       OnClick="() => _drawerOpen = !_drawerOpen">
                Filter
            </MudButton>

            @if (_canEdit)
            {
                @if (_jiraConnected)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Sync"
                               Disabled="_syncing"
                               Style="margin-right: 10px"
                               OnClick="OpenSyncDialogAsync">
                        Synchronize with Jira
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.SyncAlt"
                               Disabled="_syncing"
                               Style="margin-right: 10px"
                               OnClick="SyncFilteredAsync">
                        Synchronize only filtered
                    </MudButton>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Style="margin-right: 10px; display: none;"
                           OnClick="@(() => Nav.NavigateTo(RoutingPath.BusinessOutcomesNew))">
                    New
                </MudButton>
            }
        </MudToolBar>

        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2"
                    Variant="DrawerVariant.Temporary" Width="400px"
                    Style="background: var(--mud-palette-surface)">
            <MudDrawerHeader>
                <div class="d-flex align-center justify-space-between" style="width:100%">
                    <MudText Typo="Typo.h6">@PlanningDisplayNames.Filters</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _drawerOpen = false" />
                </div>
            </MudDrawerHeader>
            <div class="d-flex flex-column gap-3 pa-4">
                <MudTextField @bind-Value="FilterSearch" Label="@PlanningDisplayNames.Search" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <div class="d-flex align-end gap-2">
                    <MudSelect T="string" Label="@PlanningDisplayNames.PI" MultiSelection
                               @bind-SelectedValues="FilterPiNames"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var pi in _availablePis)
                        {
                            <MudSelectItem T="string" Value="@pi">@pi</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Text="Negate: find business outcomes whose features have no PI or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterPiNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableEpicIds"
                                        Values="FilterEpicNames"
                                        ValuesChanged="OnFilterEpicNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.PortfolioEpic"
                                        ToStringFunc="@LookupEpicText"
                                        ItemTemplate="@EpicItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find business outcomes without Portfolio Epic or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterEpicNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableProgramIds"
                                        Values="FilterProgramNames"
                                        ValuesChanged="OnFilterProgramNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.StrategicObjective"
                                        ToStringFunc="@LookupProgramText"
                                        ItemTemplate="@ProgramItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find business outcomes without Strategic Objective or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterProgramNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <MudSelect T="string" Label="@PlanningDisplayNames.Department" MultiSelection
                           @bind-SelectedValues="FilterDepartmentNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var dept in _availableDepartments)
                    {
                        <MudSelectItem T="string" Value="@dept">@dept</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="@PlanningDisplayNames.CapitalProjec" MultiSelection
                           @bind-SelectedValues="FilterCapitalProjectNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cp in _availableCapitalProjects)
                    {
                        <MudSelectItem T="string" Value="@cp">@cp</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ClearAll"
                           FullWidth OnClick="ClearFilters" Class="mt-2">
                    @PlanningDisplayNames.ClearFilters
                </MudButton>
            </div>
        </MudDrawer>

        @if (_syncing)
        {
            <MudProgressLinear Indeterminate Color="Color.Warning" Class="mb-2" />
            <MudAlert Severity="Severity.Info" Class="mb-2">Synchronizing Business Outcomes from Jira...</MudAlert>
        }

        <MudDivider />

        <MudDataGrid T="BoRow" Items="@_filteredRows"
                     Hover="true" Striped="true" Dense="true" Elevation="0"
                     Loading="_loading" LoadingProgressColor="Color.Primary">
            <Columns>
                <TemplateColumn Title="@PlanningDisplayNames.JiraId" Sortable="false" CellStyle="width:150px;" Hidden="!_showJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.JiraId))
                        {
                            <a href="@(Configuration["JiraTaskUrl"] + context.Item.JiraId)" target="_blank" style="text-decoration:none">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                    @context.Item.JiraId
                                </MudChip>
                            </a>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" Hidden="!_showName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="ToggleSummarySort">
                            <span>@PlanningDisplayNames.Summary</span>
                            @if (_sortColumn == SortableSummary)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        <MudText Class="font-weight-bold">@context.Item.Summary</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.CapitalProjec" Sortable="false" CellStyle="width:200px;" Hidden="!_showCapitalProject">
                    <CellTemplate>
                        @if (context.Item.CapitalProjects.Count > 0)
                        {
                            @foreach (var cp in context.Item.CapitalProjects)
                            {
                                <MudTooltip Text="@cp.Description">
                                    <a href="@($"{RoutingPath.CapitalProjects}/{cp.Id}")" target="_blank" style="text-decoration:none">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mr-1" Style="cursor:pointer">
                                            @cp.Name
                                        </MudChip>
                                    </a>
                                </MudTooltip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.EpicId" Sortable="false" CellStyle="width:150px;" Hidden="!_showEpicJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.EpicJiraId))
                        {
                            <MudTooltip Text="@context.Item.EpicName">
                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.EpicJiraId)" target="_blank" style="text-decoration:none">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer">
                                        @context.Item.EpicJiraId
                                    </MudChip>
                                </a>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.Epic" Sortable="false" Hidden="!_showEpic">
                    <CellTemplate>
                        @if (context.Item.EpicName is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.PortfolioEpics}/{context.Item.EpicId}"))">@context.Item.EpicName</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.StrategicObjectiveJiraId" Sortable="false" CellStyle="width:200px;" Hidden="!_showProgramJiraId">
                    <CellTemplate>
                        @if (context.Item.ProgramJiraIds.Count > 0)
                        {
                            @foreach (var prog in context.Item.ProgramJiraIds)
                            {
                                <MudTooltip Text="@prog.Summary">
                                    <a href="@(Configuration["JiraTaskUrl"] + prog.JiraId)" target="_blank" style="text-decoration:none">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer">
                                            @prog.JiraId
                                        </MudChip>
                                    </a>
                                </MudTooltip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                @if (_canEdit)
                {
                    <TemplateColumn Title="@PlanningDisplayNames.Actions" CellStyle="text-align:right; width:150px;" Sortable="false" Filterable="false" Hidden="!_showActions">
                        <CellTemplate>
                            <MudFab Class="m-2" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => NavigateToEdit(context.Item.Id))" />
                            <MudFab Class="m-2" StartIcon="@Icons.Material.Filled.DeleteForever" IconColor="Color.Secondary" Size="Size.Small" OnClick="() => ConfirmDeleteAsync(context.Item)" />
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
            <NoRecordsContent><MudText Class="pa-6 mud-text-secondary">No business outcomes found.</MudText></NoRecordsContent>
            <PagerContent><MudDataGridPager T="BoRow" PageSizeOptions="new[] { 10, 25, 50, 100 }" /></PagerContent>
        </MudDataGrid>
    </MudPaper>
</div>

@code {
    [CascadingParameter(Name = "UserPageAccess")]
    private Dictionary<string, AccessLevel> UserPageAccess { get; set; } = new();

    private List<BoRow> _rows = new();
    private List<BoRow> _filteredRows = new();
    private bool _loading = true;
    private bool _canEdit;
    private bool _drawerOpen;
    private bool _columnsPopoverOpen;

    // --- Capital project lookup: JiraKey -> CapitalProjectRef ---
    private Dictionary<string, CapitalProjectRef> _capitalProjectByJiraKey = new(StringComparer.OrdinalIgnoreCase);

    // --- Jira state ---
    private string? _userName;
    private bool _jiraConnected;
    private bool _syncing;
    private List<CapitalProject> _allCapitalProjectsForSync = new();

    // --- Column visibility (true = visible) ---
    private bool _showJiraId = true;
    private bool _showName = true;
    private bool _showCapitalProject = true;
    private bool _showEpicJiraId = true;
    private bool _showEpic = true;
    private bool _showProgramJiraId = true;
    private bool _showActions = true;

    // --- Sort state ---
    private const string SortableSummary = "Summary";
    private string? _sortColumn;
    private bool _sortDescending;

    // --- URL state ---
    private bool _suppressUrlUpdate = true;

    // --- Available filter values ---
    private List<string> _availableDepartments = new();
    private List<(string JiraId, string? Summary)> _availableEpics = new();
    private List<(string JiraId, string? Summary)> _availablePrograms = new();
    private List<string> _availableCapitalProjects = new();
    private List<string> _availablePis = new();
    private Dictionary<int, string> _cpToDept = new();

    private List<string> _availableEpicIds => _availableEpics.Select(e => e.JiraId).ToList();
    private List<string> _availableProgramIds => _availablePrograms.Select(p => p.JiraId).ToList();

    private string LookupEpicText(string? jiraId)
    {
        if (string.IsNullOrEmpty(jiraId))
        {
            return string.Empty;
        }

        var epic = _availableEpics.FirstOrDefault(e => e.JiraId == jiraId);

        if (epic.JiraId is null)
        {
            return jiraId;
        }

        return string.IsNullOrEmpty(epic.Summary) ? epic.JiraId : $"{epic.JiraId} — {epic.Summary}";
    }

    private string LookupProgramText(string? jiraId)
    {
        if (string.IsNullOrEmpty(jiraId))
        {
            return string.Empty;
        }

        var prog = _availablePrograms.FirstOrDefault(p => p.JiraId == jiraId);

        if (prog.JiraId is null)
        {
            return jiraId;
        }

        return string.IsNullOrEmpty(prog.Summary) ? prog.JiraId : $"{prog.JiraId} — {prog.Summary}";
    }

    private RenderFragment<string> EpicItemTemplate => jiraId => @<text>
        @{
            var epic = _availableEpics.FirstOrDefault(e => e.JiraId == jiraId);
        }
        <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
            <b>@jiraId</b>@(string.IsNullOrEmpty(epic.Summary) ? "" : $" — {epic.Summary}")
        </div>
    </text>;

    private RenderFragment<string> ProgramItemTemplate => jiraId => @<text>
        @{
            var prog = _availablePrograms.FirstOrDefault(p => p.JiraId == jiraId);
        }
        <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
            <b>@jiraId</b>@(string.IsNullOrEmpty(prog.Summary) ? "" : $" — {prog.Summary}")
        </div>
    </text>;

    private void OnFilterEpicNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterEpicNames = values;
    }

    private void OnFilterProgramNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterProgramNames = values;
    }

    // --- Filter properties with debounced recomputation ---

    private Timer? _filterDebounceTimer;
    private const int FilterDebounceMs = 200;

    private void ScheduleRecompute()
    {
        _filterDebounceTimer?.Dispose();
        _filterDebounceTimer = new Timer(_ =>
            InvokeAsync(() => { RecomputeFilteredRows(); UpdateUrl(); StateHasChanged(); }),
            null, FilterDebounceMs, Timeout.Infinite);
    }

    private string? _filterSearchBacking;
    private string? FilterSearch
    {
        get => _filterSearchBacking;
        set { _filterSearchBacking = value; ScheduleRecompute(); }
    }

    private bool _filterEpicNotBacking;
    private bool FilterEpicNot
    {
        get => _filterEpicNotBacking;
        set { _filterEpicNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterEpicNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterEpicNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterEpicNames
    {
        get => _filterEpicNamesBacking;
        set { _filterEpicNamesBacking = value; _filterEpicNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterProgramNotBacking;
    private bool FilterProgramNot
    {
        get => _filterProgramNotBacking;
        set { _filterProgramNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterProgramNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterProgramNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterProgramNames
    {
        get => _filterProgramNamesBacking;
        set { _filterProgramNamesBacking = value; _filterProgramNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterDepartmentNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterDepartmentNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterDepartmentNames
    {
        get => _filterDepartmentNamesBacking;
        set { _filterDepartmentNamesBacking = value; _filterDepartmentNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterCapitalProjectNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterCapitalProjectNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterCapitalProjectNames
    {
        get => _filterCapitalProjectNamesBacking;
        set { _filterCapitalProjectNamesBacking = value; _filterCapitalProjectNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterPiNotBacking;
    private bool FilterPiNot
    {
        get => _filterPiNotBacking;
        set { _filterPiNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterPiNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterPiNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterPiNames
    {
        get => _filterPiNamesBacking;
        set { _filterPiNamesBacking = value; _filterPiNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private void ClearFilters()
    {
        _filterSearchBacking = null;
        _filterDepartmentNamesBacking = Array.Empty<string>();
        _filterDepartmentNamesSet.Clear();
        _filterEpicNotBacking = false;
        _filterEpicNamesBacking = Array.Empty<string>();
        _filterEpicNamesSet.Clear();
        _filterProgramNotBacking = false;
        _filterProgramNamesBacking = Array.Empty<string>();
        _filterProgramNamesSet.Clear();
        _filterCapitalProjectNamesBacking = Array.Empty<string>();
        _filterCapitalProjectNamesSet.Clear();
        _filterPiNotBacking = false;
        _filterPiNamesBacking = Array.Empty<string>();
        _filterPiNamesSet.Clear();
        RecomputeFilteredRows();
        UpdateUrl();
    }

    // --- Sort logic ---

    private void ToggleSummarySort()
    {
        if (_sortColumn == SortableSummary)
        {
            if (_sortDescending)
            {
                _sortColumn = null;
                _sortDescending = false;
            }
            else
            {
                _sortDescending = true;
            }
        }
        else
        {
            _sortColumn = SortableSummary;
            _sortDescending = false;
        }
        RecomputeFilteredRows();
        UpdateUrl();
    }

    // --- Filter logic ---

    private void RecomputeFilteredRows()
    {
        IEnumerable<BoRow> filtered = _rows.Where(MatchesFilter);

        if (_sortColumn == SortableSummary)
        {
            filtered = _sortDescending
                ? filtered.OrderByDescending(r => r.Summary)
                : filtered.OrderBy(r => r.Summary);
        }

        _filteredRows = filtered.ToList();
    }

    private bool MatchesFilter(BoRow r)
    {
        if (!string.IsNullOrWhiteSpace(_filterSearchBacking))
        {
            var s = _filterSearchBacking.Trim();
            if (!((r.Summary?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.JiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.EpicName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.EpicJiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)))
            {
                return false;
            }
        }

        if (_filterEpicNotBacking)
        {
            if (_filterEpicNamesSet.Count > 0)
            {
                if (r.EpicJiraId is not null && _filterEpicNamesSet.Contains(r.EpicJiraId))
                {
                    return false;
                }
            }
            else
            {
                if (r.EpicJiraId is not null)
                {
                    return false;
                }
            }
        }
        else if (_filterEpicNamesSet.Count > 0
            && (r.EpicJiraId is null || !_filterEpicNamesSet.Contains(r.EpicJiraId)))
        {
            return false;
        }

        if (_filterProgramNotBacking)
        {
            if (_filterProgramNamesSet.Count > 0)
            {
                if (r.ProgramJiraIds.Any(p => _filterProgramNamesSet.Contains(p.JiraId)))
                {
                    return false;
                }
            }
            else
            {
                if (r.ProgramJiraIds.Count > 0)
                {
                    return false;
                }
            }
        }
        else if (_filterProgramNamesSet.Count > 0
            && !r.ProgramJiraIds.Any(p => _filterProgramNamesSet.Contains(p.JiraId)))
        {
            return false;
        }

        if (_filterDepartmentNamesSet.Count > 0
            && !r.CapitalProjects.Any(cp => _cpToDept.TryGetValue(cp.Id, out var dn) && _filterDepartmentNamesSet.Contains(dn)))
        {
            return false;
        }

        if (_filterCapitalProjectNamesSet.Count > 0
            && !r.CapitalProjects.Any(cp => _filterCapitalProjectNamesSet.Contains(cp.Name)))
        {
            return false;
        }

        if (_filterPiNotBacking)
        {
            if (_filterPiNamesSet.Count > 0)
            {
                if (r.FeaturePis.Any(p => _filterPiNamesSet.Contains(p.Name)))
                {
                    return false;
                }
            }
            else
            {
                if (r.FeaturePis.Count > 0)
                {
                    return false;
                }
            }
        }
        else if (_filterPiNamesSet.Count > 0
            && !r.FeaturePis.Any(p => _filterPiNamesSet.Contains(p.Name)))
        {
            return false;
        }

        return true;
    }

    // --- URL state management ---

    private void ReadUrlParams()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);

        if (q.TryGetValue("search", out var search) && !string.IsNullOrWhiteSpace(search))
        {
            _filterSearchBacking = search.ToString();
        }

        if (q.TryGetValue("epicNot", out var epicNot)
            && string.Equals(epicNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterEpicNotBacking = true;
        }

        if (q.TryGetValue("epic", out var epic) && !string.IsNullOrWhiteSpace(epic))
        {
            var vals = epic.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterEpicNamesBacking = vals;
            _filterEpicNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("programNot", out var programNot)
            && string.Equals(programNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterProgramNotBacking = true;
        }

        if (q.TryGetValue("program", out var program) && !string.IsNullOrWhiteSpace(program))
        {
            var vals = program.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterProgramNamesBacking = vals;
            _filterProgramNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("dept", out var dept) && !string.IsNullOrWhiteSpace(dept))
        {
            var vals = dept.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterDepartmentNamesBacking = vals;
            _filterDepartmentNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("cp", out var cp) && !string.IsNullOrWhiteSpace(cp))
        {
            var vals = cp.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterCapitalProjectNamesBacking = vals;
            _filterCapitalProjectNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("piNot", out var piNot)
            && string.Equals(piNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterPiNotBacking = true;
        }

        if (q.TryGetValue("pi", out var pi) && !string.IsNullOrWhiteSpace(pi))
        {
            var vals = pi.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterPiNamesBacking = vals;
            _filterPiNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("sortBy", out var sortBy) && !string.IsNullOrWhiteSpace(sortBy))
        {
            _sortColumn = sortBy.ToString();
            _sortDescending = q.TryGetValue("sortDesc", out var sortDesc)
                && string.Equals(sortDesc, "true", StringComparison.OrdinalIgnoreCase);
        }
    }

    private void UpdateUrl()
    {
        if (_suppressUrlUpdate)
        {
            return;
        }

        var query = new Dictionary<string, object?>();
        query["search"] = string.IsNullOrWhiteSpace(_filterSearchBacking) ? null : _filterSearchBacking;
        query["dept"] = _filterDepartmentNamesSet.Count > 0 ? string.Join(",", _filterDepartmentNamesBacking) : null;
        query["epicNot"] = _filterEpicNotBacking ? (object?)true : null;
        query["epic"] = _filterEpicNamesSet.Count > 0 ? string.Join(",", _filterEpicNamesBacking) : null;
        query["programNot"] = _filterProgramNotBacking ? (object?)true : null;
        query["program"] = _filterProgramNamesSet.Count > 0 ? string.Join(",", _filterProgramNamesBacking) : null;
        query["cp"] = _filterCapitalProjectNamesSet.Count > 0 ? string.Join(",", _filterCapitalProjectNamesBacking) : null;
        query["piNot"] = _filterPiNotBacking ? (object?)true : null;
        query["pi"] = _filterPiNamesSet.Count > 0 ? string.Join(",", _filterPiNamesBacking) : null;
        query["sortBy"] = _sortColumn;
        query["sortDesc"] = _sortDescending && _sortColumn is not null ? (object?)true : null;

        var uri = Nav.GetUriWithQueryParameters(query);
        Nav.NavigateTo(uri, replace: true);
    }

    private void NavigateToEdit(int id)
    {
        var currentUri = new Uri(Nav.Uri);
        var returnUrl = currentUri.PathAndQuery;
        var editUri = Nav.GetUriWithQueryParameters(
            $"{RoutingPath.BusinessOutcomes}/{id}",
            new Dictionary<string, object?> { ["returnUrl"] = returnUrl });
        Nav.NavigateTo(editUri);
    }

    // --- Lifecycle ---

    protected override async Task OnInitializedAsync()
    {
        _canEdit = UserPageAccess.TryGetValue("BusinessOutcomes", out var access) && access == AccessLevel.Edit;

        try
        {
            _userName = await WindowsAuth.GetUserName();
            if (_userName is not null && JiraAuth.IsConfigured)
            {
                _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
            }

            var departments = await DepartmentService.GetAllAsync();
            _cpToDept = departments
                .SelectMany(d => d.CapitalProjects.Select(cp => (cp.Id, d.Name)))
                .ToDictionary(x => x.Id, x => x.Name);

            _allCapitalProjectsForSync = await CapitalProjectService.GetAllAsync();
            _capitalProjectByJiraKey = _allCapitalProjectsForSync
                .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey))
                .GroupBy(cp => cp.JiraKey!, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    g => g.Key,
                    g => new CapitalProjectRef(g.First().Id, g.First().Name, g.First().Description),
                    StringComparer.OrdinalIgnoreCase);

            var items = await BoService.GetAllWithHierarchyAsync();
            _rows = items.Select(bo =>
            {
                var epic = bo.PortfolioEpic;
                var programs = epic?.StrategicObjectivePortfolioEpics
                    .Select(ppe => ppe.StrategicObjective).ToList() ?? new();

                var resolvedCp = ResolveCapitalProject(bo.ProjectKey, bo.JiraId);

                return new BoRow(
                    Id: bo.Id,
                    JiraId: bo.JiraId,
                    Summary: bo.Summary,
                    EpicId: bo.PortfolioEpicId,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Summary,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Summary))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjects: resolvedCp is not null
                        ? new List<CapitalProjectRef> { resolvedCp }
                        : new List<CapitalProjectRef>(),
                    FeaturePis: bo.Features
                        .Where(f => f.Pi is not null)
                        .Select(f => new FeaturePiRef(f.Pi!.Name, f.Pi.StartDate))
                        .DistinctBy(p => p.Name, StringComparer.OrdinalIgnoreCase).ToList()
                );
            }).ToList();

            _availableEpics = _rows
                .Where(r => !string.IsNullOrEmpty(r.EpicJiraId))
                .Select(r => (r.EpicJiraId!, r.EpicName))
                .DistinctBy(e => e.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(e => e.Item1).ToList();
            _availablePrograms = _rows
                .SelectMany(r => r.ProgramJiraIds)
                .Where(p => !string.IsNullOrEmpty(p.JiraId))
                .Select(p => (p.JiraId, p.Summary))
                .DistinctBy(p => p.JiraId, StringComparer.OrdinalIgnoreCase)
                .OrderBy(p => p.JiraId).ToList();
            _availableDepartments = _rows
                .SelectMany(r => r.CapitalProjects)
                .Where(cp => _cpToDept.ContainsKey(cp.Id))
                .Select(cp => _cpToDept[cp.Id])
                .Distinct().OrderBy(n => n).ToList();
            _availableCapitalProjects = _rows
                .SelectMany(r => r.CapitalProjects.Select(cp => cp.Name))
                .Where(n => !string.IsNullOrEmpty(n))
                .Distinct().OrderBy(n => n).ToList();
            _availablePis = _rows
                .SelectMany(r => r.FeaturePis)
                .GroupBy(p => p.Name, StringComparer.OrdinalIgnoreCase)
                .Select(g => new { Name = g.Key, StartDate = g.Max(p => p.StartDate) })
                .OrderByDescending(p => p.StartDate ?? DateTime.MinValue)
                .ThenBy(p => p.Name)
                .Select(p => p.Name).ToList();

            ReadUrlParams();
            RecomputeFilteredRows();
        }
        finally
        {
            _loading = false;
            _suppressUrlUpdate = false;
        }
    }

    private async Task ConfirmDeleteAsync(BoRow row)
    {
        try
        {
            if (await MessageService.Confirm($"Delete {row.Summary} ?"))
            {
                await BoService.DeleteAsync(row.Id);
                _rows.RemoveAll(r => r.Id == row.Id);
                RecomputeFilteredRows();
                UpdateUrl();
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    // --- Jira sync ---

    private async Task OpenSyncDialogAsync()
    {
        if (_allCapitalProjectsForSync.Count == 0)
        {
            _allCapitalProjectsForSync = await CapitalProjectService.GetAllAsync();
        }

        var projectsWithKey = _allCapitalProjectsForSync
            .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey)).ToList();

        if (projectsWithKey.Count == 0)
        {
            Snackbar.Add("No ART Level records have a Jira Key configured.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<JiraSyncDialog>
        {
            { x => x.Projects, projectsWithKey.Select(cp => new JiraSyncDialog.ProjectOption(cp.Id, cp.JiraKey!, cp.Name)).ToList() },
            { x => x.IssueType, JiraIssueTypes.BusinessOutcome },
            { x => x.UserName, _userName! }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<JiraSyncDialog>("Synchronize with Jira", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
        {
            return;
        }

        var syncResult = (JiraSyncDialog.JiraSyncDialogResult)result.Data!;
        await RunSyncAsync(syncResult.ProjectKey, syncResult.Issues);
    }

    private async Task RunSyncAsync(string projectKey, List<JiraIssueResponse> jiraIssues, Dictionary<string, HashSet<string>>? propertyMaskByJiraKey = null)
    {
        _syncing = true;
        StateHasChanged();

        try
        {
            if (jiraIssues.Count == 0)
            {
                Snackbar.Add($"No Business Outcomes found in Jira project {projectKey}.", Severity.Info);
                return;
            }

            var syncItems = jiraIssues.Select(ji => new JiraEpicSyncItem(
                JiraKey: ji.Key,
                Name: ji.Summary,
                Description: ji.Description,
                IssueType: ji.IssueType,
                Labels: ji.Labels is { Count: > 0 } ? string.Join(",", ji.Labels) : null,
                ParentLink: ji.ParentLink,
                Status: ji.Status,
                JiraUpdated: ji.Updated,
                TargetStart: ji.TargetStart,
                TargetEnd: ji.TargetEnd,
                StoryPoints: ji.StoryPoints
            )
            {
                PropertyMask = propertyMaskByJiraKey?.GetValueOrDefault(ji.Key)
            }).ToList();

            var syncResult = await BoService.SyncFromJiraAsync(projectKey, syncItems);

            Snackbar.Add(
                $"Sync complete: {syncResult.Created} created, {syncResult.Updated} updated, {syncResult.Linked} linked.",
                Severity.Success);

            // Reload data
            var items = await BoService.GetAllWithHierarchyAsync();
            _rows = items.Select(bo =>
            {
                var epic = bo.PortfolioEpic;
                var programs = epic?.StrategicObjectivePortfolioEpics
                    .Select(ppe => ppe.StrategicObjective).ToList() ?? new();

                var resolvedCp = ResolveCapitalProject(bo.ProjectKey, bo.JiraId);

                return new BoRow(
                    Id: bo.Id,
                    JiraId: bo.JiraId,
                    Summary: bo.Summary,
                    EpicId: bo.PortfolioEpicId,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Summary,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Summary))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjects: resolvedCp is not null
                        ? new List<CapitalProjectRef> { resolvedCp }
                        : new List<CapitalProjectRef>(),
                    FeaturePis: bo.Features
                        .Where(f => f.Pi is not null)
                        .Select(f => new FeaturePiRef(f.Pi!.Name, f.Pi.StartDate))
                        .DistinctBy(p => p.Name, StringComparer.OrdinalIgnoreCase).ToList()
                );
            }).ToList();
            RecomputeFilteredRows();
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Jira Business Outcome sync failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private async Task SyncFilteredAsync()
    {
        var jiraKeys = _filteredRows
            .Where(r => !string.IsNullOrWhiteSpace(r.JiraId))
            .Select(r => r.JiraId!)
            .Distinct().ToList();

        if (jiraKeys.Count == 0)
        {
            Snackbar.Add("No filtered records have a Jira ID.", Severity.Warning);
            return;
        }

        _syncing = true;
        StateHasChanged();

        try
        {
            var jiraIssues = await JiraIssueService.GetIssuesByKeysAsync(_userName!, jiraKeys);

            var dbItems = (await BoService.GetAllAsync())
                .Where(bo => jiraKeys.Contains(bo.JiraId!))
                .ToDictionary(bo => bo.JiraId!);

            var diffs = new List<JiraFilteredSyncDiffDialog.DiffItem>();
            foreach (var ji in jiraIssues)
            {
                if (!dbItems.TryGetValue(ji.Key, out var db))
                {
                    continue;
                }

                if (!string.Equals(db.Summary, ji.Summary, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Summary", db.Summary, ji.Summary));
                }
                if (!string.Equals(db.Description, ji.Description, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Description", db.Description, ji.Description));
                }
                var jiraLabels = ji.Labels is { Count: > 0 } ? string.Join(",", ji.Labels) : null;
                if (!string.Equals(db.Labels, jiraLabels, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Labels", db.Labels, jiraLabels));
                }
                if (!string.Equals(db.Status, ji.Status, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Status", db.Status, ji.Status));
                }
            }

            var parameters = new DialogParameters<JiraFilteredSyncDiffDialog>
            {
                { x => x.Diffs, diffs },
                { x => x.JiraIssues, jiraIssues }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
            var dialog = await DialogService.ShowAsync<JiraFilteredSyncDiffDialog>(
                "Jira Differences — Business Outcomes", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled)
            {
                var selection = (JiraFilteredSyncDiffDialog.SyncSelection)result.Data!;
                await RunSyncAsync(string.Empty, selection.Issues, selection.PropertyMaskByJiraKey);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Sync filtered business outcomes failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    public void Dispose()
    {
        _filterDebounceTimer?.Dispose();
    }

    private CapitalProjectRef? ResolveCapitalProject(string? projectKey, string? jiraId)
    {
        var key = projectKey;
        if (string.IsNullOrWhiteSpace(key) && !string.IsNullOrWhiteSpace(jiraId))
        {
            var dash = jiraId.IndexOf('-');
            key = dash > 0 ? jiraId.Substring(0, dash) : jiraId;
        }

        if (string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        return _capitalProjectByJiraKey.TryGetValue(key, out var cp) ? cp : null;
    }

    private record JiraRef(string JiraId, string? Summary);
    private record CapitalProjectRef(int Id, string Name, string? Description);
    private record FeaturePiRef(string Name, DateTime? StartDate);

    private record BoRow(
        int Id,
        string? JiraId,
        string? Summary,
        int? EpicId,
        string? EpicJiraId,
        string? EpicName,
        List<JiraRef> ProgramJiraIds,
        List<CapitalProjectRef> CapitalProjects,
        List<FeaturePiRef> FeaturePis
    );
}
