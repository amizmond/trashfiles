    // --- Capacity check ---

    private bool CapacityCheckEnabled
    {
        get => _capacityCheckEnabled;
        set
        {
            _capacityCheckEnabled = value;
            if (value)
                _ = RunCapacityCheckAsync();
            else
            {
                _piCapacityResults.Clear();
                _featureCapacityMap.Clear();
            }
        }
    }

    private async Task RunCapacityCheckAsync()
    {
        _capacityCalculating = true;
        StateHasChanged();

        try
        {
            _piCapacityResults.Clear();
            _featureCapacityMap.Clear();

            // Calculate capacity independently for each PI
            var tasks = _piStacks.Select(async stack =>
            {
                var result = await CapacityService.CalculateCapacityAsync(stack.Features);
                return (PiId: stack.Pi.Id, Result: result);
            }).ToList();

            var results = await Task.WhenAll(tasks);

            foreach (var (piId, result) in results)
            {
                _piCapacityResults[piId] = result;
                foreach (var fr in result.FeatureResults)
                    _featureCapacityMap[fr.FeatureId] = fr;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Capacity calculation error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _capacityCalculating = false;
            StateHasChanged();
        }
    }

    private FeatureCapacityResult? GetFeatureCapacity(int featureId)
    {
        return _featureCapacityMap.GetValueOrDefault(featureId);
    }

