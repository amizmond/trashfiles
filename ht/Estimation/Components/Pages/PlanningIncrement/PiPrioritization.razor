@attribute [Route(RoutingPath.PiPrioritization)]
@using Estimation.Core.Models
@using Estimation.Core.Services

@using Estimation.Components.ModalDialog

@implements IAsyncDisposable

@inject IPiPrioritizationService PrioritizationService
@inject IPiService PiService
@inject ITeamService TeamService
@inject IPiCapacityService CapacityService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IModalDialogService ModalDialogService
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration

<PageTitle>PI Prioritization</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        @if (_initialLoading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
            <MudText Typo="Typo.body1" Class="mud-text-secondary">Loading...</MudText>
        }
        else
        {
        <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" Style="@(_saving ? "" : "visibility:hidden")" />
        <div class="d-flex align-center gap-2 mb-4">
            <div class="d-flex align-center">
                <MudSelect
                    T="int?"
                    @bind-Value="_selectedPiId"
                    Label="Select PI"
                    Variant="Variant.Outlined"
                    Dense
                    AnchorOrigin="Origin.BottomCenter"
                    Style="width:300px; margin-right: 15px;"
                >
                    @foreach (var pi in _allPis)
                    {
                        <MudSelectItem T="int?" Value="pi.Id">@pi.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddPi" Disabled="@(_selectedPiId is null || _saving)">
                    Add PI
                </MudButton>
            </div>

            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       Disabled="@(!_hasUnsavedChanges || _saving)"
                       OnClick="SaveChangesAsync">
                Save
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@(_rankingSortAsc ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                       Disabled="_piStacks.Count == 0"
                       OnClick="SortByRanking">
                Ranking @(_rankingSortAsc ? "ASC" : "DESC")
            </MudButton>
            <div style="position:relative">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Disabled="_piStacks.Count == 0"
                           OnClick="() => _detailsPopoverOpen = !_detailsPopoverOpen">
                    Details
                </MudButton>
                <MudPopover Open="_detailsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:280px">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Toggle Details</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _detailsPopoverOpen = false" />
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <MudSwitch T="bool" @bind-Value="_showCapitalProject" Label="ART Level" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showProjectProgram" Label="Strategic Objective" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showPortfolioEpic" Label="Portfolio Epic" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showBusinessOutcome" Label="Business Outcome" Color="Color.Primary" Dense />
                    </div>
                </MudPopover>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Disabled="_piStacks.Count == 0"
                       OnClick="() => _drawerOpen = !_drawerOpen">
                Filter
            </MudButton>
            <MudCheckBox T="bool" @bind-Value="CapacityCheckEnabled"
                         Label="Capacity check" Color="Color.Primary"
                         Disabled="@(_piStacks.Count == 0 || _saving)" />
        </div>

        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2"
                    Variant="DrawerVariant.Temporary" Width="400px"
                    Style="background: var(--mud-palette-surface)">
            <MudDrawerHeader>
                <div class="d-flex align-center justify-space-between" style="width:100%">
                    <MudText Typo="Typo.h6">Filters</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _drawerOpen = false" />
                </div>
            </MudDrawerHeader>
            <div class="d-flex flex-column gap-3 pa-4">
                <MudTextField @bind-Value="FilterName" Label="Name" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable Immediate DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <div class="d-flex align-center gap-2">
                    <MudSelect T="string" Label="Business Outcome" MultiSelection
                               @bind-SelectedValues="FilterBoJiraIds"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var bo in _availableBusinessOutcomes)
                        {
                            <MudSelectItem T="string" Value="bo.JiraId">
                                <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                    <b>@bo.JiraId</b> — @bo.Summary
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>
                    <MudCheckBox T="bool" @bind-Value="FilterBoNot" Label="Not" Dense />
                </div>

                <MudTextField @bind-Value="FilterBoName" Label="Business Outcome Name"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable Immediate DebounceInterval="300" Dense />

                <MudSelect T="string" Label="Team" MultiSelection
                           @bind-SelectedValues="FilterTeamNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var team in _allTeams)
                    {
                        <MudSelectItem T="string" Value="team.Name">@team.Name</MudSelectItem>
                    }
                </MudSelect>

                <div class="d-flex align-center gap-2">
                    <MudSelect T="string" Label="ART Level" MultiSelection
                               @bind-SelectedValues="FilterCapitalProjectNames"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var cp in _availableCapitalProjects)
                        {
                            <MudSelectItem T="string" Value="cp">@cp</MudSelectItem>
                        }
                    </MudSelect>
                    <MudCheckBox T="bool" @bind-Value="FilterCapitalProjectNot" Label="Not" Dense />
                </div>

                <div class="d-flex align-center gap-2">
                    <MudSelect T="string" Label="Strategic Objective" MultiSelection
                               @bind-SelectedValues="FilterProjectProgramJiraIds"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var pp in _availableProjectPrograms)
                        {
                            <MudSelectItem T="string" Value="pp.JiraId">
                                <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                    <b>@pp.JiraId</b> — @pp.Summary
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>
                    <MudCheckBox T="bool" @bind-Value="FilterProjectProgramNot" Label="Not" Dense />
                </div>

                <div class="d-flex align-center gap-2">
                    <MudSelect T="string" Label="Portfolio Epic" MultiSelection
                               @bind-SelectedValues="FilterPortfolioEpicJiraIds"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var pe in _availablePortfolioEpics)
                        {
                            <MudSelectItem T="string" Value="pe.JiraId">
                                <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                    <b>@pe.JiraId</b> — @pe.Summary
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>
                    <MudCheckBox T="bool" @bind-Value="FilterPortfolioEpicNot" Label="Not" Dense />
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ClearAll"
                           FullWidth OnClick="ClearFilters" Class="mt-2">
                    Clear Filters
                </MudButton>
            </div>
        </MudDrawer>

        @if (_capacityCheckEnabled && _capacityCalculating)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-3" />
        }

        @if (_piStacks.Count == 0)
        {
            <MudText Typo="Typo.body1" Class="mud-text-secondary">Select a PI and click "Add PI" to view features.</MudText>
        }
        else
        {
            <div class="pi-stacks-container">
                @foreach (var stack in _piStacks)
                {
                    <div class="pi-stack" @key="stack.Pi.Id">
                        <div class="pi-stack-header">
                            <MudText Typo="Typo.h6"> PI Name: @stack.Pi.Name</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => RemoveStack(stack)" />
                        </div>

                        @if (_capacityCheckEnabled && _piCapacityResults.TryGetValue(stack.Pi.Id, out var piCapacity))
                        {
                            <div class="pa-2" style="background: var(--mud-palette-background-grey)">
                                <div class="d-flex gap-2 flex-wrap align-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                        Total: @piCapacity.Summary.TotalFeatures
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                                        Reserved: @piCapacity.Summary.FeaturesFullyReserved
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">
                                        Partial: @piCapacity.Summary.FeaturesPartiallyReserved
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">
                                        Not Reserved: @piCapacity.Summary.FeaturesNotReserved
                                    </MudChip>
                                    <MudSpacer />
                                    <MudButton StartIcon="@Icons.Material.Filled.BarChart"
                                               Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               OnClick="() => ShowTeamCapacityChart(stack.Pi.Name, piCapacity)">Team Capacity</MudButton>
                                </div>
                                <div class="d-flex gap-3 mt-1">
                                    <MudText Typo="Typo.caption">
                                        Required: <b>@piCapacity.Summary.TotalRequiredCapacity</b>
                                    </MudText>
                                    <MudText Typo="Typo.caption">
                                        Reserved: <b>@piCapacity.Summary.TotalReservedCapacity</b>
                                    </MudText>
                                    <MudText Typo="Typo.caption">
                                        Unreserved: <b>@piCapacity.Summary.TotalUnreservedCapacity</b>
                                    </MudText>
                                </div>
                            </div>
                        }

                        @if (stack.Loading)
                        {
                            <MudProgressLinear Indeterminate Color="Color.Primary" />
                        }
                        else
                        {
                            <div class="pi-stack-body" data-pi-id="@stack.Pi.Id">
                                @if (stack.Features.Count == 0)
                                {
                                    <MudText Typo="Typo.body1" Class="mud-text-secondary pa-2">Drop features here</MudText>
                                }
                                else
                                {
                                    var filtered = GetFilteredFeatures(stack.Pi.Id);
                                    @if (filtered.Count == 0)
                                    {
                                        <MudText Typo="Typo.body1" Class="mud-text-secondary pa-2">No features match the current filter.</MudText>
                                    }
                                    else
                                    {
                                        <div class="pi-priority-list">
                                            @foreach (var feature in filtered)
                                            {
                                                <PiPriorityCard @key="feature.Id"
                                                                Feature="feature"
                                                                EstimatedTotal="@_estimatedTotals.GetValueOrDefault(feature.Id)"
                                                                JiraTaskUrl="@_jiraTaskUrl"
                                                                CapacityResult="@GetFeatureCapacity(feature.Id)"
                                                                CapacityCheckEnabled="_capacityCheckEnabled"
                                                                ShowCapitalProject="_showCapitalProject"
                                                                ShowStrategicObjective="_showProjectProgram"
                                                                ShowPortfolioEpic="_showPortfolioEpic"
                                                                ShowBusinessOutcome="_showBusinessOutcome"
                                                                OnShowDetails="ShowFeatureDetails"
                                                                OnOpenInNewWindow="OpenFeatureInNewWindow"
                                                                OnRankingChanged="OnFeatureRankingChanged"
                                                                OnShowCapacityDetails="ShowCapacityDetails" />
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        }
    </MudPaper>
</div>

<style>
    .pi-stacks-container {
        display: flex;
        gap: 16px;
        overflow-x: auto;
    }

    .pi-stack {
        min-width: 500px;
        flex: 1;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
    }

    .pi-stack-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        background: var(--mud-palette-background-grey);
        border-radius: 8px 8px 0 0;
    }

    .pi-stack-body {
        min-height: 100px;
    }

    .pi-priority-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 8px;
    }

    .pi-priority-card {
        padding: 12px 16px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        background: var(--mud-palette-surface);
        cursor: grab;
        transition: box-shadow 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
        user-select: none;
        display: flex;
        flex-direction: column;
    }

    .pi-priority-card:hover {
        box-shadow: var(--mud-elevation-2);
    }

    .pi-priority-card.dragging {
        opacity: 0.4;
    }

    .pi-priority-card.drag-over {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 0 2px var(--mud-palette-primary);
    }
</style>

@code {
    private List<Pi> _allPis = new();
    private List<Team> _allTeams = new();
    private List<PiStack> _piStacks = new();
    private int? _selectedPiId;
    private int? _dragSourcePiId;
    private int? _dragSourceId;
    private bool _initialLoading = true;
    private bool _saving;
    private bool _hasUnsavedChanges;
    private HashSet<int> _movedFeatureIds = new();
    private Dictionary<int, int> _estimatedTotals = new();
    private Dictionary<int, List<Feature>> _filteredFeatures = new();
    private string? _jiraTaskUrl;
    private bool _capacityCheckEnabled;
    private bool _capacityCalculating;
    private Dictionary<int, PiCapacityResult> _piCapacityResults = new();
    private Dictionary<int, FeatureCapacityResult> _featureCapacityMap = new();
    private bool _requireRankingChangeComment;
    private HashSet<int> _commentChangedFeatureIds = new();

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<PiPrioritization>? _dotNetRef;
    private IDisposable? _locationChangingRegistration;

    private bool _drawerOpen;
    private bool _detailsPopoverOpen;

    // --- Details visibility ---
    private bool _showCapitalProject;
    private bool _showProjectProgram;
    private bool _showPortfolioEpic;
    private bool _showBusinessOutcome = true;

    // --- Filter properties with debounced recomputation ---

    private Timer? _filterDebounceTimer;
    private const int FilterDebounceMs = 200;

    private void ScheduleRecompute()
    {
        _filterDebounceTimer?.Dispose();
        _filterDebounceTimer = new Timer(_ =>
            InvokeAsync(() => { RecomputeFilteredFeatures(); StateHasChanged(); }),
            null, FilterDebounceMs, Timeout.Infinite);
    }

    private string? _filterNameBacking;
    private string? FilterName
    {
        get => _filterNameBacking;
        set { _filterNameBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterBoJiraIdsBacking = Array.Empty<string>();
    private HashSet<string> _filterBoJiraIdsSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterBoJiraIds
    {
        get => _filterBoJiraIdsBacking;
        set { _filterBoJiraIdsBacking = value; _filterBoJiraIdsSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterBoNotBacking;
    private bool FilterBoNot
    {
        get => _filterBoNotBacking;
        set { _filterBoNotBacking = value; ScheduleRecompute(); }
    }

    private string? _filterBoNameBacking;
    private string? FilterBoName
    {
        get => _filterBoNameBacking;
        set { _filterBoNameBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterTeamNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterTeamNamesSet = new();
    private IReadOnlyCollection<string> FilterTeamNames
    {
        get => _filterTeamNamesBacking;
        set { _filterTeamNamesBacking = value; _filterTeamNamesSet = new HashSet<string>(value); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterCapitalProjectNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterCapitalProjectNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterCapitalProjectNames
    {
        get => _filterCapitalProjectNamesBacking;
        set { _filterCapitalProjectNamesBacking = value; _filterCapitalProjectNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterCapitalProjectNotBacking;
    private bool FilterCapitalProjectNot
    {
        get => _filterCapitalProjectNotBacking;
        set { _filterCapitalProjectNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterProjectProgramJiraIdsBacking = Array.Empty<string>();
    private HashSet<string> _filterProjectProgramJiraIdsSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterProjectProgramJiraIds
    {
        get => _filterProjectProgramJiraIdsBacking;
        set { _filterProjectProgramJiraIdsBacking = value; _filterProjectProgramJiraIdsSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterProjectProgramNotBacking;
    private bool FilterProjectProgramNot
    {
        get => _filterProjectProgramNotBacking;
        set { _filterProjectProgramNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterPortfolioEpicJiraIdsBacking = Array.Empty<string>();
    private HashSet<string> _filterPortfolioEpicJiraIdsSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterPortfolioEpicJiraIds
    {
        get => _filterPortfolioEpicJiraIdsBacking;
        set { _filterPortfolioEpicJiraIdsBacking = value; _filterPortfolioEpicJiraIdsSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterPortfolioEpicNotBacking;
    private bool FilterPortfolioEpicNot
    {
        get => _filterPortfolioEpicNotBacking;
        set { _filterPortfolioEpicNotBacking = value; ScheduleRecompute(); }
    }

    private List<(string JiraId, string? Summary)> _availableBusinessOutcomes = new();
    private List<string> _availableCapitalProjects = new();
    private List<(string JiraId, string? Summary)> _availableProjectPrograms = new();
    private List<(string JiraId, string? Summary)> _availablePortfolioEpics = new();

    private bool _rankingSortAsc = true;

    private void SortByRanking()
    {
        foreach (var stack in _piStacks)
        {
            if (_rankingSortAsc)
                stack.Features.Sort((a, b) => (a.Ranking ?? int.MaxValue).CompareTo(b.Ranking ?? int.MaxValue));
            else
                stack.Features.Sort((a, b) => (b.Ranking ?? int.MinValue).CompareTo(a.Ranking ?? int.MinValue));
        }
        _rankingSortAsc = !_rankingSortAsc;
        RecomputeFilteredFeatures();
    }

    private void ClearFilters()
    {
        _filterNameBacking = null;
        _filterBoJiraIdsBacking = Array.Empty<string>();
        _filterBoJiraIdsSet.Clear();
        _filterBoNotBacking = false;
        _filterBoNameBacking = null;
        _filterTeamNamesBacking = Array.Empty<string>();
        _filterTeamNamesSet.Clear();
        _filterCapitalProjectNamesBacking = Array.Empty<string>();
        _filterCapitalProjectNamesSet.Clear();
        _filterCapitalProjectNotBacking = false;
        _filterProjectProgramJiraIdsBacking = Array.Empty<string>();
        _filterProjectProgramJiraIdsSet.Clear();
        _filterProjectProgramNotBacking = false;
        _filterPortfolioEpicJiraIdsBacking = Array.Empty<string>();
        _filterPortfolioEpicJiraIdsSet.Clear();
        _filterPortfolioEpicNotBacking = false;
        RecomputeFilteredFeatures();
    }

    // --- Filter logic ---

    private static readonly List<Feature> EmptyFeatures = new();

    private List<Feature> GetFilteredFeatures(int piId)
    {
        return _filteredFeatures.TryGetValue(piId, out var list) ? list : EmptyFeatures;
    }

    private void RecomputeFilteredFeatures()
    {
        _filteredFeatures.Clear();
        foreach (var stack in _piStacks)
            _filteredFeatures[stack.Pi.Id] = stack.Features.Where(MatchesFilter).ToList();
    }

    private bool MatchesFilter(Feature f)
    {
        if (!string.IsNullOrWhiteSpace(_filterNameBacking)
            && !(f.Name?.Contains(_filterNameBacking.Trim(), StringComparison.OrdinalIgnoreCase) ?? false))
            return false;

        if (_filterBoJiraIdsSet.Count > 0)
        {
            var boMatches = f.BusinessOutcome?.JiraId is not null && _filterBoJiraIdsSet.Contains(f.BusinessOutcome.JiraId);
            if (_filterBoNotBacking ? boMatches : !boMatches)
                return false;
        }

        if (!string.IsNullOrWhiteSpace(_filterBoNameBacking)
            && !(f.BusinessOutcome?.Summary?.Contains(_filterBoNameBacking.Trim(), StringComparison.OrdinalIgnoreCase) ?? false))
            return false;

        if (_filterTeamNamesSet.Count > 0
            && !f.FeatureTeams.Any(ft => _filterTeamNamesSet.Contains(ft.Team.Name)))
            return false;

        if (_filterCapitalProjectNamesSet.Count > 0)
        {
            var cpNames = f.BusinessOutcome?.PortfolioEpic?.StrategicObjectivePortfolioEpics
                .SelectMany(ppe => ppe.StrategicObjective.CapitalProjectStrategicObjectives)
                .Select(cpp => cpp.CapitalProject.Name)
                .Where(n => n is not null) ?? Enumerable.Empty<string>();
            var cpMatches = cpNames.Any(n => _filterCapitalProjectNamesSet.Contains(n!));
            if (_filterCapitalProjectNotBacking ? cpMatches : !cpMatches)
                return false;
        }

        if (_filterProjectProgramJiraIdsSet.Count > 0)
        {
            var ppJiraIds = f.BusinessOutcome?.PortfolioEpic?.StrategicObjectivePortfolioEpics
                .Select(ppe => ppe.StrategicObjective.JiraId)
                .Where(id => id is not null) ?? Enumerable.Empty<string>();
            var ppMatches = ppJiraIds.Any(id => _filterProjectProgramJiraIdsSet.Contains(id!));
            if (_filterProjectProgramNotBacking ? ppMatches : !ppMatches)
                return false;
        }

        if (_filterPortfolioEpicJiraIdsSet.Count > 0)
        {
            var peMatches = f.BusinessOutcome?.PortfolioEpic?.JiraId is not null
                && _filterPortfolioEpicJiraIdsSet.Contains(f.BusinessOutcome.PortfolioEpic.JiraId);
            if (_filterPortfolioEpicNotBacking ? peMatches : !peMatches)
                return false;
        }

        return true;
    }

    // --- Lifecycle ---

    protected override async Task OnInitializedAsync()
    {
        var pisTask = PiService.GetAllLightAsync();
        var teamsTask = TeamService.GetAllNamesAsync();

        await Task.WhenAll(pisTask, teamsTask);

        _allPis = await pisTask;
        _allTeams = await teamsTask;
        _jiraTaskUrl = Configuration["JiraTaskUrl"];
        _requireRankingChangeComment = Configuration.GetValue<bool>("RequireRankingChangeComment");
        _initialLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/piDragDrop.js");
            await _jsModule.InvokeVoidAsync("init", _dotNetRef);
            _locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
        }
    }

    private async Task SetBeforeUnload(bool enabled)
    {
        if (_jsModule is null) return;
        try
        {
            await _jsModule.InvokeVoidAsync("setBeforeUnload", enabled);
        }
        catch (JSDisconnectedException) { }
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!_hasUnsavedChanges) return;

        var confirmed = await ModalDialogService.Confirm(
            "You have unsaved changes. Do you want to leave without saving?",
            "Unsaved Changes",
            "Leave");

        if (!confirmed)
            context.PreventNavigation();
    }

    public async ValueTask DisposeAsync()
    {
        _filterDebounceTimer?.Dispose();
        _locationChangingRegistration?.Dispose();
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("dispose");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();
    }

    // --- Data loading ---

    private void ComputeEstimatedTotals(List<Feature> features)
    {
        foreach (var f in features)
            _estimatedTotals[f.Id] = f.FeatureTechnologyStacks.Sum(fts => fts.EstimatedEffort ?? 0);
    }

    private async Task AddPi()
    {
        if (_selectedPiId is null) return;
        if (_piStacks.Any(s => s.Pi.Id == _selectedPiId.Value)) return;

        var pi = _allPis.FirstOrDefault(p => p.Id == _selectedPiId.Value);
        if (pi is null) return;

        var stack = new PiStack { Pi = pi, Loading = true };
        _piStacks.Add(stack);
        StateHasChanged();

        stack.Features = await PrioritizationService.GetPrioritizedFeaturesAsync(pi.Id);
        ComputeEstimatedTotals(stack.Features);
        RebuildAvailableFilterValues();
        RecomputeFilteredFeatures();
        stack.Loading = false;
        StateHasChanged();

        if (_capacityCheckEnabled)
            await RunCapacityCheckAsync();
    }

    private void RebuildAvailableFilterValues()
    {
        var allFeatures = _piStacks.SelectMany(s => s.Features).ToList();

        _availableBusinessOutcomes = allFeatures
            .Where(f => !string.IsNullOrEmpty(f.BusinessOutcome?.JiraId))
            .Select(f => (f.BusinessOutcome!.JiraId!, f.BusinessOutcome.Summary))
            .DistinctBy(b => b.Item1, StringComparer.OrdinalIgnoreCase)
            .OrderBy(b => b.Item1)
            .ToList();

        _availablePortfolioEpics = allFeatures
            .Where(f => !string.IsNullOrEmpty(f.BusinessOutcome?.PortfolioEpic?.JiraId))
            .Select(f => (f.BusinessOutcome!.PortfolioEpic!.JiraId!, f.BusinessOutcome.PortfolioEpic.Summary))
            .DistinctBy(e => e.Item1, StringComparer.OrdinalIgnoreCase)
            .OrderBy(e => e.Item1)
            .ToList();

        _availableProjectPrograms = allFeatures
            .Where(f => f.BusinessOutcome?.PortfolioEpic?.StrategicObjectivePortfolioEpics is not null)
            .SelectMany(f => f.BusinessOutcome!.PortfolioEpic!.StrategicObjectivePortfolioEpics)
            .Where(ppe => !string.IsNullOrEmpty(ppe.StrategicObjective.JiraId))
            .Select(ppe => (ppe.StrategicObjective.JiraId!, (string?)ppe.StrategicObjective.Summary))
            .DistinctBy(p => p.Item1, StringComparer.OrdinalIgnoreCase)
            .OrderBy(p => p.Item1)
            .ToList();

        _availableCapitalProjects = allFeatures
            .Where(f => f.BusinessOutcome?.PortfolioEpic?.StrategicObjectivePortfolioEpics is not null)
            .SelectMany(f => f.BusinessOutcome!.PortfolioEpic!.StrategicObjectivePortfolioEpics)
            .SelectMany(ppe => ppe.StrategicObjective.CapitalProjectStrategicObjectives)
            .Select(cpp => cpp.CapitalProject.Name)
            .Where(n => !string.IsNullOrEmpty(n))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(n => n)
            .ToList();
    }

    private void RemoveStack(PiStack stack)
    {
        foreach (var f in stack.Features)
            _estimatedTotals.Remove(f.Id);
        _filteredFeatures.Remove(stack.Pi.Id);
        _piStacks.Remove(stack);
        RebuildAvailableFilterValues();
        RecomputeFilteredFeatures();
    }

    // --- JS Interop drag-and-drop handlers ---

    [JSInvokable]
    public void OnJsDragStart(int featureId, int sourcePiId)
    {
        _dragSourceId = featureId;
        _dragSourcePiId = sourcePiId;
    }

    [JSInvokable]
    public async Task OnJsDrop(int targetFeatureId, int targetPiId)
    {
        if (!_dragSourceId.HasValue) return;

        var targetStack = _piStacks.FirstOrDefault(s => s.Pi.Id == targetPiId);
        if (targetStack is null) return;

        if (targetFeatureId == -1)
        {
            await MoveFeature(targetStack, targetStack.Features.Count);
        }
        else
        {
            if (_dragSourceId.Value == targetFeatureId) return;
            var targetFeature = targetStack.Features.FirstOrDefault(f => f.Id == targetFeatureId);
            if (targetFeature is null) return;
            var targetIndex = targetStack.Features.IndexOf(targetFeature);
            await MoveFeature(targetStack, targetIndex);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnJsDragEnd()
    {
        _dragSourceId = null;
        _dragSourcePiId = null;
    }

    private async Task MoveFeature(PiStack targetStack, int targetIndex)
    {
        var sourceStack = _piStacks.FirstOrDefault(s => s.Pi.Id == _dragSourcePiId);
        if (sourceStack is null) return;

        var sourceFeature = sourceStack.Features.FirstOrDefault(f => f.Id == _dragSourceId!.Value);
        if (sourceFeature is null) return;

        var isCrossStack = _dragSourcePiId != targetStack.Pi.Id;

        // Capture state before the move so we can revert on cancel
        var oldSourceRankings = sourceStack.Features.Select(f => (f, f.Ranking)).ToList();
        var oldTargetRankings = isCrossStack ? targetStack.Features.Select(f => (f, f.Ranking)).ToList() : null;
        var oldPiId = sourceFeature.PiId;
        var oldPi = sourceFeature.Pi;

        sourceStack.Features.Remove(sourceFeature);

        if (isCrossStack)
        {
            sourceFeature.PiId = targetStack.Pi.Id;
            sourceFeature.Pi = targetStack.Pi;
        }

        if (targetIndex > targetStack.Features.Count)
            targetIndex = targetStack.Features.Count;
        targetStack.Features.Insert(targetIndex, sourceFeature);

        for (var i = 0; i < targetStack.Features.Count; i++)
            targetStack.Features[i].Ranking = i + 1;

        if (isCrossStack)
        {
            for (var i = 0; i < sourceStack.Features.Count; i++)
                sourceStack.Features[i].Ranking = i + 1;
        }

        _dragSourceId = null;
        _dragSourcePiId = null;

        if (_requireRankingChangeComment)
        {
            RecomputeFilteredFeatures();
            StateHasChanged();

            var parameters = new Dictionary<string, object?>
            {
                { nameof(RankingChangeCommentDialog.Feature), sourceFeature }
            };
            var dialogRef = await ModalDialogService.Component<RankingChangeCommentDialog>(
                "Ranking Change Comment", parameters);
            var result = await dialogRef.Result;

            if (result is null || result.Canceled)
            {
                // Revert the move
                targetStack.Features.Remove(sourceFeature);
                if (isCrossStack)
                {
                    sourceFeature.PiId = oldPiId;
                    sourceFeature.Pi = oldPi;
                    foreach (var (f, r) in oldTargetRankings!)
                        f.Ranking = r;
                }
                foreach (var (f, r) in oldSourceRankings)
                    f.Ranking = r;
                // Re-insert at original position
                var originalIndex = oldSourceRankings.FindIndex(x => x.f.Id == sourceFeature.Id);
                if (originalIndex >= 0 && originalIndex <= sourceStack.Features.Count)
                    sourceStack.Features.Insert(originalIndex, sourceFeature);
                else
                    sourceStack.Features.Add(sourceFeature);

                RecomputeFilteredFeatures();
                return;
            }

            var comment = result.Data as string;
            sourceFeature.Comments = comment;
            _commentChangedFeatureIds.Add(sourceFeature.Id);
        }

        if (isCrossStack)
            _movedFeatureIds.Add(sourceFeature.Id);

        if (!_hasUnsavedChanges)
        {
            _hasUnsavedChanges = true;
            _ = SetBeforeUnload(true);
        }

        RecomputeFilteredFeatures();

        if (_capacityCheckEnabled)
            _ = RunCapacityCheckAsync();
    }

    private async Task OnFeatureRankingChanged((Feature Feature, int? OldRanking, int? NewRanking) args)
    {
        if (_requireRankingChangeComment)
        {
            var parameters = new Dictionary<string, object?>
            {
                { nameof(RankingChangeCommentDialog.Feature), args.Feature }
            };
            var dialogRef = await ModalDialogService.Component<RankingChangeCommentDialog>(
                "Ranking Change Comment", parameters);
            var result = await dialogRef.Result;

            if (result is null || result.Canceled)
            {
                args.Feature.Ranking = args.OldRanking;
                return;
            }

            var comment = result.Data as string;
            args.Feature.Comments = comment;
            _commentChangedFeatureIds.Add(args.Feature.Id);
        }

        var stack = _piStacks.FirstOrDefault(s => s.Pi.Id == args.Feature.PiId);
        if (stack is not null)
        {
            stack.Features.Sort((a, b) => (a.Ranking ?? int.MaxValue).CompareTo(b.Ranking ?? int.MaxValue));
            RecomputeFilteredFeatures();
        }

        if (_capacityCheckEnabled)
            _ = RunCapacityCheckAsync();

        if (!_hasUnsavedChanges)
        {
            _hasUnsavedChanges = true;
            _ = SetBeforeUnload(true);
        }
    }

    private async Task SaveChangesAsync()
    {
        _saving = true;
        try
        {
            if (_movedFeatureIds.Count > 0)
            {
                var moves = _piStacks
                    .SelectMany(s => s.Features)
                    .Where(f => _movedFeatureIds.Contains(f.Id) && f.PiId.HasValue)
                    .Select(f => (f.Id, f.PiId!.Value))
                    .ToList();
                await PrioritizationService.MoveFeaturesToPiAsync(moves);
            }

            var allPriorities = _piStacks
                .SelectMany(s => s.Features.Select((f, i) => (f.Id, Priority: i + 1)))
                .ToList();

            if (allPriorities.Count > 0)
                await PrioritizationService.UpdatePrioritiesAsync(allPriorities);

            if (_commentChangedFeatureIds.Count > 0)
            {
                var comments = _piStacks
                    .SelectMany(s => s.Features)
                    .Where(f => _commentChangedFeatureIds.Contains(f.Id))
                    .Select(f => (f.Id, f.Comments))
                    .ToList();
                await PrioritizationService.UpdateFeatureCommentsAsync(comments);
                _commentChangedFeatureIds.Clear();
            }

            _movedFeatureIds.Clear();
            _hasUnsavedChanges = false;
            await SetBeforeUnload(false);
            Snackbar.Add("Changes saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

