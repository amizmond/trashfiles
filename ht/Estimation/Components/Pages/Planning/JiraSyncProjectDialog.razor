@using Estimation.Core.Models

<MudDialog>
    <DialogContent>
        <MudText Class="mb-4">Select an ART Level project to synchronize Strategic Objectives from Jira:</MudText>
        <MudSelect T="ProjectOption" @bind-Value="_selected" Label="ART Level (Jira Project)" Variant="Variant.Outlined" Required>
            @foreach (var p in Projects)
            {
                <MudSelectItem T="ProjectOption" Value="p">@p.JiraKey — @p.Name</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_selected is null" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<ProjectOption> Projects { get; set; } = new();

    private ProjectOption? _selected;

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(_selected!));

    public record ProjectOption(int Id, string JiraKey, string Name);
}
