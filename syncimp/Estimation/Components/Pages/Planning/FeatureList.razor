@attribute [Route(RoutingPath.Features)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.JiraLogic
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Estimation.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using MudBlazor.Utilities
@using Serilog

@inject IFeatureService FeatureService
@inject IFeatureUploadService FeatureUploadService
@inject IBrowserDownloadService DownloadService
@inject IPiService PiService
@inject ICapitalProjectService CapitalProjectService
@inject IDepartmentService DepartmentService
@inject ITeamService TeamService
@inject ITechnologyStackService TechnologyStackService
@inject IBusinessOutcomeService BusinessOutcomeService
@inject IJiraAuthService JiraAuth
@inject IWindowsAuthService WindowsAuth
@inject IUserPermissionService UserPermissions
@inject ISolutionTrainResolver TrainResolver
@inject NavigationManager Nav
@inject IModalDialogService MessageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJiraIssueService JiraIssueService
@inject IJiraDiffService JiraDiffService
@inject IConfiguration Configuration
@inject IJSRuntime JS

@implements IDisposable

<AccessGuard PageKey="Features">
<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6">@PlanningDisplayNames.Features</MudText>

        <div class="d-flex flex-wrap align-center justify-end gap-2 pa-2">
            <div style="position:relative;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ViewColumn"
                           Disabled="_loading"
                           OnClick="() => _columnsPopoverOpen = !_columnsPopoverOpen">
                    Columns
                </MudButton>
                <MudPopover Open="_columnsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:340px; max-height:75vh; overflow-y:auto">
                    <div class="d-flex align-center justify-space-between mb-1">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@PlanningDisplayNames.ToggleColumns</MudText>
                        <div>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ResetColumnsAsync">Reset</MudButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _columnsPopoverOpen = false" />
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">Drag a row to reorder. Toggle to show or hide.</MudText>
                    <MudDropContainer T="ColumnItem" @ref="_columnDropContainer" Items="_columnItems"
                                      ItemsSelector="@((item, zone) => item.Selector == zone)"
                                      ItemDropped="OnColumnDroppedAsync" Class="d-block">
                        <ChildContent>
                            <MudDropZone T="ColumnItem" Identifier="@ColumnZoneId" AllowReorder="true"
                                         Class="d-flex flex-column gap-1" />
                        </ChildContent>
                        <ItemRenderer>
                            <div class="d-flex align-center gap-2 px-2 py-1 rounded-lg mud-paper-outlined" style="cursor:grab; user-select:none">
                                <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Class="mud-text-secondary" />
                                <MudSwitch T="bool" Value="context.Visible"
                                           ValueChanged="@(v => OnColumnVisibilityChangedAsync(context, v))"
                                           Label="@context.Label" Color="Color.Primary" Dense Class="flex-grow-1 ma-0" />
                            </div>
                        </ItemRenderer>
                    </MudDropContainer>
                </MudPopover>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Disabled="_loading"
                       OnClick="() => _drawerOpen = !_drawerOpen">
                Filter
            </MudButton>

            @if (_canEdit)
            {
                @if (_jiraConnected)
                {
                    @if (_canSyncJira)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   Disabled="_syncing"
                                   OnClick="OpenSyncDialogAsync">
                            Find new Features in Jira
                        </MudButton>
                    }
                    @if (_canSyncFiltered)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.SyncAlt"
                                   Disabled="_syncing"
                                   OnClick="SyncFilteredAsync">
                            Update filtered from Jira
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.AccountTree"
                               Disabled="_syncing"
                               OnClick="OpenHierarchyCheckDialogAsync">
                        Hierarchy check
                    </MudButton>
                }

                @if (_canMapToPi)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Map"
                               Disabled="_loading"
                               OnClick="OpenMapToPiDialogAsync">
                        Map to PI
                    </MudButton>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => Nav.NavigateTo(RoutingPath.FeaturesNew))">
                    New
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           Disabled="_loading || _exporting"
                           OnClick="ExportFilteredAsync">
                    Export to excel
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Description"
                           Disabled="_loading || _exporting"
                           OnClick="ExportEmptyTemplateAsync">
                    Empty template
                </MudButton>

                <MudFileUpload T="IBrowserFile"
                               Accept=".xlsx"
                               MaximumFileCount="1"
                               FilesChanged="OnUploadFileSelected">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.UploadFile"
                                   Disabled="_loading || _exporting">
                            Upload
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
            }
        </div>

        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2"
                    Variant="DrawerVariant.Temporary" Width="400px"
                    Style="background: var(--mud-palette-surface)">
            <MudDrawerHeader>
                <div class="d-flex align-center justify-space-between" style="width:100%">
                    <MudText Typo="Typo.h6">@PlanningDisplayNames.Filters</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _drawerOpen = false" />
                </div>
            </MudDrawerHeader>
            <div class="d-flex flex-column gap-3 pa-4">
                <MudTextField @bind-Value="FilterSearch" Label="@PlanningDisplayNames.Search" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <div class="d-flex align-end gap-2">
                    <MudSelect T="string" Label="@PlanningDisplayNames.PI" MultiSelection
                               @bind-SelectedValues="FilterPiNames"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var pi in _availablePis)
                        {
                            <MudSelectItem T="string" Value="@pi">@pi</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Text="Negate: find features without PI or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterPiNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableBoIds"
                                        Values="FilterBoNames"
                                        ValuesChanged="OnFilterBoNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.BusinessOutcome"
                                        ToStringFunc="@LookupBoText"
                                        ItemTemplate="@BoItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Business Outcome or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterBoNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableEpicIds"
                                        Values="FilterEpicNames"
                                        ValuesChanged="OnFilterEpicNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.PortfolioEpic"
                                        ToStringFunc="@LookupEpicText"
                                        ItemTemplate="@EpicItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Portfolio Epic or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterEpicNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableProgramIds"
                                        Values="FilterProgramNames"
                                        ValuesChanged="OnFilterProgramNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.StrategicObjective"
                                        ToStringFunc="@LookupProgramText"
                                        ItemTemplate="@ProgramItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Strategic Objective or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterProgramNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <MudSelect T="string" Label="@PlanningDisplayNames.Department" MultiSelection
                           @bind-SelectedValues="FilterDepartmentNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var dept in _availableDepartments)
                    {
                        <MudSelectItem T="string" Value="@dept">@dept</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="@PlanningDisplayNames.CapitalProjec" MultiSelection
                           @bind-SelectedValues="FilterCapitalProjectNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cp in _availableCapitalProjects)
                    {
                        <MudSelectItem T="string" Value="@cp">@cp</MudSelectItem>
                    }
                </MudSelect>

                <SearchableDropdown T="string"
                                    Items="_availableTechStacks"
                                    Values="FilterTechStackNames"
                                    ValuesChanged="OnFilterTechStackNamesChanged"
                                    MultiSelect="true"
                                    Label="@PlanningDisplayNames.TechnologyStacks" />

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="_availableTeams"
                                        Values="FilterTeamNames"
                                        ValuesChanged="OnFilterTeamNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.Teams"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Teams or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterTeamNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <MudSelect T="string" Label="@PlanningDisplayNames.Status" MultiSelection
                           @bind-SelectedValues="FilterStatuses"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var s in _availableStatuses)
                    {
                        <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField @bind-Value="FilterLabel" Label="@PlanningDisplayNames.Labels" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Label" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ClearAll"
                           FullWidth OnClick="ClearFilters" Class="mt-2">
                    @PlanningDisplayNames.ClearFilters
                </MudButton>
            </div>
        </MudDrawer>

        @if (_syncing)
        {
            <MudProgressLinear Indeterminate Color="Color.Warning" Class="mb-2" />
            <MudAlert Severity="Severity.Info" Class="mb-2">Synchronizing Features from Jira...</MudAlert>
        }

        <MudDivider />

        <MudDataGrid @ref="_grid" T="FeatureRow" Items="@_filteredRows"
                     Hover="true" Striped="true" Dense="true" Elevation="0"
                     Loading="_loading" LoadingProgressColor="Color.Primary"
                     ColumnResizeMode="ResizeMode.Column"
                     @bind-CurrentPage="CurrentPage"
                     @bind-RowsPerPage="PageSize">
            <Columns>
                <TemplateColumn Sortable="false" CellStyle="width:150px;" Hidden="!_showJiraId">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableJiraId))">
                            <span>@PlanningDisplayNames.JiraId</span>
                            @if (_sortColumn == SortableJiraId)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.JiraId))
                        {
                            <a href="@(Configuration["JiraTaskUrl"] + context.Item.JiraId)" target="_blank" style="text-decoration:none">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                    @context.Item.JiraId
                                </MudChip>
                            </a>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.FeatureName" Title="@PlanningDisplayNames.FeatureName" Sortable="true" Hidden="!_showFeatureName" />

                <TemplateColumn Sortable="false" CellStyle="max-width:320px; white-space:normal; word-break:break-word;" Hidden="!_showName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableSummary))">
                            <span>@PlanningDisplayNames.Summary</span>
                            @if (_sortColumn == SortableSummary)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        <MudText Class="font-weight-bold">@context.Item.Summary</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" CellStyle="width:130px;" Hidden="!_showStatus">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableStatus))">
                            <span>@PlanningDisplayNames.Status</span>
                            @if (_sortColumn == SortableStatus)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.Status))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@context.Item.Status</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.CapitalProjectName" Title="@PlanningDisplayNames.CapitalProjec" Sortable="true" Hidden="!_showCapitalProject" />
                <TemplateColumn Sortable="false" CellStyle="width:150px;" Hidden="!_showBoJiraId">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableBusinessOutcome))">
                            <span>@PlanningDisplayNames.BusinessOutcome</span>
                            @if (_sortColumn == SortableBusinessOutcome)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.BoJiraId))
                        {
                            <MudTooltip Text="@context.Item.BoName">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                         OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.BusinessOutcome, context.Item.BoJiraId, context.Item.BoName, context.Item.BoDescription))">
                                    @context.Item.BoJiraId
                                </MudChip>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" Hidden="!_showBoName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableBusinessOutcomeName))">
                            <span>@PlanningDisplayNames.BusinessOutcomeName</span>
                            @if (_sortColumn == SortableBusinessOutcomeName)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @context.Item.BoName
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" CellStyle="width:150px;" Hidden="!_showEpicJiraId">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortablePortfolioEpic))">
                            <span>@PlanningDisplayNames.PortfolioEpic</span>
                            @if (_sortColumn == SortablePortfolioEpic)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.EpicJiraId))
                        {
                            <MudTooltip Text="@context.Item.EpicName">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                         OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.PortfolioEpic, context.Item.EpicJiraId, context.Item.EpicName, context.Item.EpicDescription))">
                                    @context.Item.EpicJiraId
                                </MudChip>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" Hidden="!_showEpicName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortablePortfolioEpicName))">
                            <span>@PlanningDisplayNames.PortfolioEpicName</span>
                            @if (_sortColumn == SortablePortfolioEpicName)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @context.Item.EpicName
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" CellStyle="width:150px;" Hidden="!_showProgramJiraId">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableStrategicObjective))">
                            <span>@PlanningDisplayNames.StrategicObjective</span>
                            @if (_sortColumn == SortableStrategicObjective)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (context.Item.ProgramJiraIds.Count > 0)
                        {
                            @foreach (var prog in context.Item.ProgramJiraIds)
                            {
                                <MudTooltip Text="@prog.Summary">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                             OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.StrategicObjective, prog.JiraId, prog.Summary, prog.Description))">
                                        @prog.JiraId
                                    </MudChip>
                                </MudTooltip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" Hidden="!_showProgramName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="@(() => ToggleSort(SortableStrategicObjectiveName))">
                            <span>@PlanningDisplayNames.StrategicObjectiveName</span>
                            @if (_sortColumn == SortableStrategicObjectiveName)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        @if (context.Item.ProgramJiraIds.Count > 0)
                        {
                            @string.Join(", ", context.Item.ProgramJiraIds.Select(p => p.Summary).Where(s => !string.IsNullOrEmpty(s)))
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.Labels" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showLabels">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.Labels))
                        {
                            @foreach (var label in context.Item.Labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="mr-1">@label</MudChip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.PiName" Title="@PlanningDisplayNames.FeaturePi" Sortable="true" Groupable="true" CellStyle="width:130px;" Hidden="!_showPi" />
                <PropertyColumn Property="r => r.PiObjective" Title="@PlanningDisplayNames.PiObjective" Sortable="true" Groupable="true" CellStyle="max-width:300px; white-space:normal; word-break:break-word;" Hidden="!_showPiObjective" />
                <TemplateColumn Title="@PlanningDisplayNames.GfedTeams" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showTeams">
                    <CellTemplate>
                        @foreach (var t in context.Item.Teams.Take(3))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.Teams}/{t.Id}"))">@t.Name</MudChip>
                        }
                        @if (context.Item.Teams.Count > 3)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                +@(context.Item.Teams.Count - 3)
                            </MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.TechnologyStacks" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showTechPo">
                    <CellTemplate>
                        @if (context.Item.TechStacks.Count > 0)
                        {
                            @foreach (var ts in context.Item.TechStacks)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="mr-1">@(ts.EstimatedEffort.HasValue ? $"{ts.Name}: {ts.EstimatedEffort}" : ts.Name)</MudChip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.Comments" Title="@PlanningDisplayNames.Comments" Sortable="false" CellStyle="max-width:300px; white-space:normal; word-break:break-word;" Hidden="!_showComments" />
                <PropertyColumn Property="r => r.RagExplain" Title="@PlanningDisplayNames.RagExplain" Sortable="false" CellStyle="max-width:300px; white-space:normal; word-break:break-word;" Hidden="!_showRagExplain" />
                <PropertyColumn Property="r => r.Dependencies" Title="@PlanningDisplayNames.Dependencies" Sortable="false" CellStyle="max-width:300px; white-space:normal; word-break:break-word;" Hidden="!_showDependencies" />
                <PropertyColumn Property="r => r.AcceptanceCriteria" Title="@PlanningDisplayNames.AcceptanceCriteria" Sortable="false" CellStyle="max-width:300px; white-space:normal; word-break:break-word;" Hidden="!_showAcceptanceCriteria" />
                <TemplateColumn Title="@PlanningDisplayNames.TargetStart" Sortable="false" CellStyle="width:130px;" Hidden="!_showTargetStart">
                    <CellTemplate>
                        @if (context.Item.TargetStart.HasValue)
                        {
                            @context.Item.TargetStart.Value.ToString("yyyy-MM-dd")
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.TargetEnd" Sortable="false" CellStyle="width:130px;" Hidden="!_showTargetEnd">
                    <CellTemplate>
                        @if (context.Item.TargetEnd.HasValue)
                        {
                            @context.Item.TargetEnd.Value.ToString("yyyy-MM-dd")
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.StoryPoints" Title="@PlanningDisplayNames.StoryPoints" Sortable="false" CellStyle="width:110px;" Hidden="!_showStoryPoints" />
