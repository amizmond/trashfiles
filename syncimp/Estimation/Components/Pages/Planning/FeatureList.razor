    private async Task ExportFilteredAsync() => await ExportAsync(_filteredRows.Select(r => r.Id).ToList(), "Features.xlsx");

    private async Task ExportEmptyTemplateAsync() => await ExportAsync(new List<int>(), "Features_Template.xlsx");

    private async Task ExportAsync(List<int> featureIds, string fileName)
    {
        // Export: every column is optional and can be unchecked (no locked identity columns).
        var states = PickerColumns.Select(c => new FeatureColumnState
        {
            Column = c.Column,
            Label = c.Label,
            Selected = !DefaultOffColumns.Contains(c.Column),
            Editable = true,
            IsMain = false
        }).ToList();

        var selection = await ShowColumnPickerAsync(
            "Choose columns to export",
            "Exports the features matching the current filters. Select the columns to include.",
            "Export",
            states);
        if (selection is null)
        {
            return;
        }

        try
        {
            _exporting = true;
            StateHasChanged();

            var bytes = await FeatureUploadService.ExportFilteredAsync(
                selection, new FeatureExportFilter { FeatureIds = featureIds });
            await DownloadService.DownloadAsync(bytes, fileName);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to export features");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task OnUploadFileSelected(IBrowserFile file)
    {
        if (file is null)
        {
            return;
        }

        MemoryStream? stream = null;
        try
        {
            stream = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(stream);
            stream.Position = 0;

            var present = await FeatureUploadService.DetectColumnsAsync(stream);
            if (present.Count == 0)
            {
                Snackbar.Add("No recognized feature columns were found in the file.", Severity.Error);
                return;
            }

            // Present columns are on/editable; absent ones are off/disabled. Present main columns lock on.
            var states = PickerColumns.Select(c =>
            {
                var isPresent = present.Contains(c.Column);
                var isMain = MainColumns.Contains(c.Column);
                return new FeatureColumnState
                {
                    Column = c.Column,
                    Label = c.Label,
                    Selected = isPresent && (isMain || !DefaultOffColumns.Contains(c.Column)),
                    Editable = isPresent && !isMain,
                    IsMain = isMain && isPresent
                };
            }).ToList();

            var selection = await ShowColumnPickerAsync(
                "Choose columns to import",
                "Columns not found in the uploaded file are disabled. Unchecked columns keep their existing values.",
                "Continue",
                states);
            if (selection is null)
            {
                return;
            }

            _exporting = true;
            StateHasChanged();

            stream.Position = 0;
            var result = await FeatureUploadService.ParseFileAsync(stream, selection);
            if (result.Rows.Count == 0)
            {
                Snackbar.Add("No data rows found in the uploaded file.", Severity.Warning);
                return;
            }

            FeatureUploadPreviewState.PendingUpload = result.Rows;
            FeatureUploadPreviewState.ImportedColumns = result.AppliedColumns;
            FeatureUploadPreviewState.TechStackNames = result.TechStackNames;
            Nav.NavigateTo(RoutingPath.FeaturesUploadPreview);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to parse uploaded feature file");
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            if (stream is not null)
            {
                await stream.DisposeAsync();
            }
            StateHasChanged();
        }
    }

    private async Task<FeatureUploadColumnSelection?> ShowColumnPickerAsync(
        string title, string description, string confirmLabel, List<FeatureColumnState> states)
    {
        var parameters = new DialogParameters<FeatureColumnPickerDialog>
        {
            { x => x.Columns, states },
            { x => x.Description, description },
            { x => x.ConfirmLabel, confirmLabel },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FeatureColumnPickerDialog>(title, parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled || result.Data is not FeatureUploadColumnSelection selection)
        {
            return null;
        }
        return selection;
    }

    // --- Map to PI ---

    private async Task OpenMapToPiDialogAsync()
    {
        if (!_canMapToPi)
        {
            return;
        }

        try
        {
            var pis = await PiService.GetAllLightAsync();
            if (pis.Count == 0)
            {
                await MessageService.Info(
                    "No Planning Increments have been created yet. Please create a PI first.",
                    "No PIs available");
                return;
            }

            var parameters = new DialogParameters<MapToPiDialog>
            {
                { x => x.Pis, pis },
                { x => x.FeatureCount, _filteredRows.Count }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            var dialog = await DialogService.ShowAsync<MapToPiDialog>("Map to PI", parameters, options);
            var result = await dialog.Result;

            if (result is null || result.Canceled)
            {
                return;
            }

            var mapResult = (MapToPiDialog.MapToPiResult)result.Data!;
            var featureIds = _filteredRows.Select(r => r.Id).ToList();
            var jiraKeysToUpdate = _filteredRows
                .Where(r => !string.IsNullOrWhiteSpace(r.JiraId))
                .Select(r => r.JiraId!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (mapResult.PiId is not null)
            {
                var piName = pis.First(p => p.Id == mapResult.PiId.Value).Name;
                if (!await MessageService.Confirm(
                    $"Map {featureIds.Count} filtered feature(s) to PI \"{piName}\"?"))
                {
                    return;
                }
            }
            else
            {
                if (!await MessageService.Confirm(
                    $"Remove PI mapping from {featureIds.Count} filtered feature(s)?"))
                {
                    return;
                }
            }

            await FeatureService.MapFeaturesToPiAsync(featureIds, mapResult.PiId);

            // Update local rows to reflect the change
            var newPiId = mapResult.PiId;
            var newPiName = newPiId.HasValue ? pis.First(p => p.Id == newPiId.Value).Name : null;
            _rows = _rows.Select(r =>
                featureIds.Contains(r.Id)
                    ? r with { PiId = newPiId, PiName = newPiName }
                    : r).ToList();
            RecomputeFilteredRows();

            Snackbar.Add(
                mapResult.PiId is not null
                    ? $"Mapped {featureIds.Count} feature(s) to PI \"{newPiName}\"."
                    : $"Removed PI mapping from {featureIds.Count} feature(s).",
                Severity.Success);

            if (mapResult.UpdateJira)
            {
                await UpdateJiraPlanningIncrementAsync(jiraKeysToUpdate, newPiName);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Map to PI failed");
            await MessageService.Exception(ex);
        }
    }

    private async Task UpdateJiraPlanningIncrementAsync(List<string> jiraKeys, string? piName)
    {
        if (jiraKeys.Count == 0)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_userName) || !_jiraConnected)
        {
            Snackbar.Add(
                "Features were mapped locally, but Jira was not updated because you are not connected to Jira.",
                Severity.Warning);
            return;
        }

        _syncing = true;
        StateHasChanged();

        var updated = 0;
        var failed = 0;
        try
        {
            foreach (var jiraKey in jiraKeys)
            {
                var request = new JiraUpdateIssueRequest
                {
                    PlanningIncrement = piName,
                    FieldsToUpdate = new HashSet<string> { JiraUpdateFields.PlanningIncrement }
                };

                try
                {
                    await JiraIssueService.UpdateIssueAsync(_userName!, jiraKey, request);
                    updated++;
                }
                catch (Exception ex)
                {
                    failed++;
                    Log.Error(ex, "Failed to update Planning Increment on Jira issue {JiraKey}", jiraKey);
                }
            }
        }
        finally
        {
            _syncing = false;
            StateHasChanged();
        }

        Snackbar.Add(
            $"Jira Planning Increment updated on {updated} issue(s)" +
            (failed > 0 ? $"; {failed} failed." : "."),
            failed > 0 ? Severity.Warning : Severity.Success);
    }

    // --- Jira sync ---

    private async Task OpenSyncDialogAsync()
    {
        if (!_canSyncJira)
        {
            return;
        }

        if (_allCapitalProjectsForSync.Count == 0)
        {
            _allCapitalProjectsForSync = await CapitalProjectService.GetAllAsync();
        }

        var projectsWithKey = _allCapitalProjectsForSync
            .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey)).ToList();

        if (projectsWithKey.Count == 0)
        {
            Snackbar.Add("No ART Level records have a Jira Key configured.", Severity.Warning);
            return;
        }

        var dbPis = await PiService.GetAllLightAsync();
        var dbTeams = await TeamService.GetAllNamesAsync();
        var existingJiraIds = await FeatureService.GetExistingJiraIdsAsync();

        var parameters = new DialogParameters<JiraSyncDialog>
        {
            { x => x.Projects, projectsWithKey.Select(cp => new JiraSyncDialog.ProjectOption(cp.Id, cp.JiraKey!, cp.Name)).ToList() },
            { x => x.IssueType, JiraIssueTypes.Feature },
            { x => x.UserName, _userName! },
            { x => x.AvailablePiNames, dbPis.Select(p => p.Name).OrderBy(n => n).ToList() },
            { x => x.AvailableTeams, dbTeams.OrderBy(t => t.Name).ToList() },
            { x => x.ExistingJiraIds, existingJiraIds }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<JiraSyncDialog>("Find new Features in Jira", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
        {
            return;
        }

        var syncResult = (JiraSyncDialog.JiraSyncDialogResult)result.Data!;
        await RunSyncAsync(syncResult.ProjectKey, syncResult.Issues);
    }

    private async Task RunSyncAsync(string projectKey, List<JiraIssueResponse> jiraIssues, Dictionary<string, HashSet<string>>? propertyMaskByJiraKey = null)
    {
        _syncing = true;
        StateHasChanged();

        try
        {
            if (jiraIssues.Count == 0)
            {
                Snackbar.Add($"No Features found in Jira project {projectKey}.", Severity.Info);
                return;
            }

            var syncItems = jiraIssues
                .Select(ji => ji.ToFeatureSyncItem(propertyMaskByJiraKey?.GetValueOrDefault(ji.Key)))
                .ToList();

            var syncResult = await FeatureService.SyncFromJiraAsync(projectKey, syncItems);

            Snackbar.Add(
                $"Sync complete: {syncResult.Created} created, {syncResult.Updated} updated, {syncResult.Linked} linked.",
                Severity.Success);

            // Reload data
            var items = FilterVisibleFeatures(await FeatureService.GetAllWithHierarchyAsync());
            _rows = items.Select(f =>
            {
                var bo = f.BusinessOutcome;
                var epic = bo?.PortfolioEpic;
                var programs = epic?.StrategicObjectivePortfolioEpics
                    .Select(ppe => ppe.StrategicObjective).ToList() ?? new();

                var resolvedCapitalProjectName = ArtHelper.ResolveArtByJiraId(f.ProjectKey, f.JiraId, _capitalProjectByJiraKey)?.Name;

                return new FeatureRow(
                    Id: f.Id,
                    JiraId: f.JiraId,
                    FeatureName: f.Name,
                    Summary: f.Summary,
                    PiId: f.PiId,
                    PiName: f.Pi?.Name,
                    BoJiraId: bo?.JiraId,
                    BoName: bo?.Summary,
                    BoDescription: bo?.Description,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Summary,
                    EpicDescription: epic?.Description,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Summary, p.Description))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjectName: resolvedCapitalProjectName,
                    Labels: f.Labels,
                    PiObjective: f.PiObjective?.Name,
                    Teams: f.FeatureTeams.Select(ft => new TeamRef(ft.TeamId, ft.Team.Name)).ToList(),
                    TechStacks: f.FeatureTechnologyStacks.Select(fts => new TechStackRef(fts.TechnologyStack.Name, fts.EstimatedEffort)).ToList(),
                    Comments: f.Comments,
                    RagExplain: f.RagExplain,
                    Dependencies: f.Dependencies,
                    AcceptanceCriteria: f.AcceptanceCriteria,
                    TargetStart: f.TargetStart,
                    TargetEnd: f.TargetEnd,
                    StoryPoints: f.StoryPoints,
                    Status: f.Status,
                    Ranking: f.Ranking,
                    RequirementStatus: f.RequirementStatus?.Name
                );
            }).ToList();
            RecomputeFilteredRows();
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Jira Feature sync failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private async Task SyncFilteredAsync()
    {
        if (!_canSyncFiltered)
        {
            return;
        }

        var jiraKeys = _filteredRows
            .Where(r => !string.IsNullOrWhiteSpace(r.JiraId))
            .Select(r => r.JiraId!)
            .Distinct().ToList();

        if (jiraKeys.Count == 0)
        {
            Snackbar.Add("No filtered records have a Jira ID.", Severity.Warning);
            return;
        }

        var confirmed = await MessageService.Confirm(
            $"This will search Jira for the {jiraKeys.Count} filtered Feature(s) that have a Jira ID " +
            "and compare them with the database. You will then see the differences and choose which " +
            "records to update from Jira. No new records are created. Continue?",
            "Update filtered from Jira", "Continue");
        if (!confirmed)
        {
            return;
        }

        _syncing = true;
        StateHasChanged();

        try
        {
            var jiraIssues = await JiraIssueService.GetIssuesByKeysAsync(_userName!, jiraKeys);

            var dbFeatures = (await FeatureService.GetAllAsync())
                .Where(f => jiraKeys.Contains(f.JiraId!))
                .ToDictionary(f => f.JiraId!);

            var dbPis = await PiService.GetAllLightAsync();
            var dbTeams = await TeamService.GetAllNamesAsync();

            var diffResult = JiraDiffService.DiffFeatures(
                jiraIssues,
                dbFeatures,
                dbPis.Select(p => p.Name).ToList(),
                dbTeams);

            var diffs = diffResult.Diffs
                .Select(d => new JiraFilteredSyncDiffDialog.DiffItem(d.JiraKey, d.PropertyName, d.DbValue, d.JiraValue))
                .ToList();

            var parameters = new DialogParameters<JiraFilteredSyncDiffDialog>
            {
                { x => x.Diffs, diffs },
                { x => x.JiraIssues, jiraIssues },
                { x => x.TeamsNotFound, diffResult.TeamsNotFound },
                { x => x.PisToCreate, diffResult.PisToCreate }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
            var dialog = await DialogService.ShowAsync<JiraFilteredSyncDiffDialog>(
                "Jira Differences — Features", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled)
            {
                var selection = (JiraFilteredSyncDiffDialog.SyncSelection)result.Data!;
                await RunSyncAsync(string.Empty, selection.Issues, selection.PropertyMaskByJiraKey);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Sync filtered features failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

