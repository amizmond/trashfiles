    private async Task OpenSyncDialogAsync()
    {
        if (_allCapitalProjects.Count == 0)
        {
            _allCapitalProjects = await CapitalProjectService.GetAllAsync();
        }

        var projectsWithKey = _allCapitalProjects
            .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey))
            .ToList();

        if (projectsWithKey.Count == 0)
        {
            Snackbar.Add("No ART Level records have a Jira Key configured.", Severity.Warning);
            return;
        }

        var existingJiraIds = await ProgramService.GetExistingJiraIdsAsync();

        var parameters = new DialogParameters<JiraSyncDialog>
        {
            { x => x.Projects, projectsWithKey.Select(cp => new JiraSyncDialog.ProjectOption(cp.Id, cp.JiraKey!, cp.Name)).ToList() },
            { x => x.IssueType, JiraIssueTypes.StrategicObjective },
            { x => x.UserName, _userName! },
            { x => x.ExistingJiraIds, existingJiraIds }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<JiraSyncDialog>("Find new Strategic Objectives in Jira", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
        {
            return;
        }

        var syncResult = (JiraSyncDialog.JiraSyncDialogResult)result.Data!;
        await RunSyncAsync(syncResult.ProjectId, syncResult.ProjectKey, syncResult.Issues);
    }

    private async Task RunSyncAsync(int capitalProjectId, string projectKey, List<JiraIssueResponse> jiraIssues, Dictionary<string, HashSet<string>>? propertyMaskByJiraKey = null)
    {
        _syncing = true;
        StateHasChanged();

        try
        {
            if (jiraIssues.Count == 0)
            {
                Snackbar.Add($"No Strategic Objectives found in Jira project {projectKey}.", Severity.Info);
                return;
            }

            var syncItems = jiraIssues
                .Select(ji => ji.ToStrategicObjectiveSyncItem(propertyMaskByJiraKey?.GetValueOrDefault(ji.Key)))
                .ToList();

            var syncResult = await ProgramService.SyncFromJiraAsync(capitalProjectId, projectKey, syncItems);

            Snackbar.Add(
                $"Sync complete: {syncResult.Created} created, {syncResult.Updated} updated, {syncResult.Linked} linked.",
                Severity.Success);

            // Reload data
            var items = FilterVisibleObjectives(await ProgramService.GetAllWithHierarchyAsync());
            _rows = items.Select(pp =>
            {
                var resolvedCp = ArtHelper.ResolveArtByJiraId(pp.ProjectKey, pp.JiraId, _capitalProjectByJiraKey);

                return new ProgramRow(
                    Id: pp.Id,
                    JiraId: pp.JiraId,
                    Summary: pp.Summary,
                    CapitalProjects: resolvedCp is not null
                        ? new List<CapitalProjectRef> { resolvedCp }
                        : new List<CapitalProjectRef>(),
                    Epics: pp.StrategicObjectivePortfolioEpics
                        .Select(ppe => new EpicRef(ppe.PortfolioEpicId, ppe.PortfolioEpic.JiraId, ppe.PortfolioEpic.Summary))
                        .ToList(),
                    FeaturePis: pp.StrategicObjectivePortfolioEpics
                        .SelectMany(ppe => ppe.PortfolioEpic.BusinessOutcomes)
                        .SelectMany(bo => bo.Features)
                        .Where(f => f.Pi is not null)
                        .Select(f => new FeaturePiRef(f.Pi!.Name, f.Pi.StartDate))
                        .DistinctBy(p => p.Name, StringComparer.OrdinalIgnoreCase).ToList(),
                    BoArts: pp.StrategicObjectivePortfolioEpics
                        .SelectMany(ppe => ppe.PortfolioEpic.BusinessOutcomes)
                        .Select(bo => new { Item = bo, ArtName = ArtHelper.ResolveArtByJiraId(bo.ProjectKey, bo.JiraId, _capitalProjectByJiraKey)?.Name })
                        .Where(x => !string.IsNullOrEmpty(x.ArtName))
                        .Select(x => new ArtItemRef(x.Item.Id, x.Item.JiraId, x.Item.Summary, x.ArtName!, x.Item.Labels))
                        .ToList(),
                    Features: pp.StrategicObjectivePortfolioEpics
                        .SelectMany(ppe => ppe.PortfolioEpic.BusinessOutcomes)
                        .SelectMany(bo => bo.Features)
                        .Select(f => new FeatureRef(f.Id, f.JiraId, f.Summary,
                            ArtHelper.ResolveArtByJiraId(f.ProjectKey, f.JiraId, _capitalProjectByJiraKey)?.Name,
                            f.Labels, f.Pi?.Name))
                        .ToList(),
                    Labels: pp.Labels,
                    FeatureLabels: pp.StrategicObjectivePortfolioEpics
                        .SelectMany(ppe => ppe.PortfolioEpic.BusinessOutcomes)
                        .SelectMany(bo => bo.Features)
                        .Where(f => !string.IsNullOrEmpty(f.Labels))
                        .SelectMany(f => f.Labels!.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        .Distinct(StringComparer.OrdinalIgnoreCase).ToList(),
                    Status: pp.Status
                );
            }).ToList();
            PopulateAvailableFilterValues();
            RecomputeFilteredRows();
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Jira sync failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private void ToggleSort(string sortKey)
    {
        if (_sortColumn == sortKey)
        {
            if (_sortDescending)
            {
                _sortColumn = null;
                _sortDescending = false;
            }
            else
            {
                _sortDescending = true;
            }
        }
        else
        {
            _sortColumn = sortKey;
            _sortDescending = false;
        }
        RecomputeFilteredRows();
        UpdateUrl();
    }

    private void ReadUrlParams()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("search", out var search) && !string.IsNullOrWhiteSpace(search))
        {
            _filterSearchBacking = search.ToString();
        }
        if (q.TryGetValue("label", out var label) && !string.IsNullOrWhiteSpace(label))
        {
            _filterLabelBacking = label.ToString();
        }
        if (q.TryGetValue("fLabel", out var fLabel) && !string.IsNullOrWhiteSpace(fLabel))
        {
            _filterFeatureLabelBacking = fLabel.ToString();
        }
        if (q.TryGetValue("dept", out var dept) && !string.IsNullOrWhiteSpace(dept))
        {
            var vals = dept.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterDepartmentNamesBacking = vals;
            _filterDepartmentNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("cp", out var cp) && !string.IsNullOrWhiteSpace(cp))
        {
            var vals = cp.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterCapitalProjectNamesBacking = vals;
            _filterCapitalProjectNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("boArt", out var boArt) && !string.IsNullOrWhiteSpace(boArt))
        {
            var vals = boArt.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterBoArtNamesBacking = vals;
            _filterBoArtNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("artLogic", out var artLogic) && !string.IsNullOrWhiteSpace(artLogic))
        {
            if (string.Equals(artLogic, "and", StringComparison.OrdinalIgnoreCase))
            {
                _filterArtLogicBacking = ArtFilterLogic.And;
            }
            else if (string.Equals(artLogic, "or", StringComparison.OrdinalIgnoreCase))
            {
                _filterArtLogicBacking = ArtFilterLogic.Or;
            }
        }
        if (q.TryGetValue("epic", out var epic) && !string.IsNullOrWhiteSpace(epic))
        {
            var vals = epic.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterEpicNamesBacking = vals;
            _filterEpicNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("piNot", out var piNot)
            && string.Equals(piNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterPiNotBacking = true;
        }
        if (q.TryGetValue("pi", out var pi) && !string.IsNullOrWhiteSpace(pi))
        {
            var vals = pi.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterPiNamesBacking = vals;
            _filterPiNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("status", out var status) && !string.IsNullOrWhiteSpace(status))
        {
            var vals = status.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterStatusesBacking = vals;
            _filterStatusesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }
        if (q.TryGetValue("sortBy", out var sortBy) && !string.IsNullOrWhiteSpace(sortBy))
        {
            _sortColumn = sortBy.ToString();
            _sortDescending = q.TryGetValue("sortDesc", out var sortDesc)
                && string.Equals(sortDesc, "true", StringComparison.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("page", out var pageStr)
            && int.TryParse(pageStr, out var pageVal) && pageVal >= 0)
        {
            _currentPageBacking = pageVal;
        }

        if (q.TryGetValue("pageSize", out var pageSizeStr)
            && int.TryParse(pageSizeStr, out var pageSizeVal) && pageSizeVal > 0)
        {
            _pageSizeBacking = pageSizeVal;
            _initialPageSizeFromUrl = pageSizeVal;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_initialPageSizeFromUrl.HasValue && _grid is not null)
        {
            var size = _initialPageSizeFromUrl.Value;
            _initialPageSizeFromUrl = null;
            await _grid.SetRowsPerPageAsync(size, false);
        }
    }

    private void UpdateUrl()
    {
        if (_suppressUrlUpdate)
        {
            return;
        }
        var query = new Dictionary<string, object?>();
        query["search"] = string.IsNullOrWhiteSpace(_filterSearchBacking) ? null : _filterSearchBacking;
        query["label"] = string.IsNullOrWhiteSpace(_filterLabelBacking) ? null : _filterLabelBacking;
        query["fLabel"] = string.IsNullOrWhiteSpace(_filterFeatureLabelBacking) ? null : _filterFeatureLabelBacking;
        query["dept"] = _filterDepartmentNamesSet.Count > 0 ? string.Join(",", _filterDepartmentNamesBacking) : null;
        query["cp"] = _filterCapitalProjectNamesSet.Count > 0 ? string.Join(",", _filterCapitalProjectNamesBacking) : null;
        query["boArt"] = _filterBoArtNamesSet.Count > 0 ? string.Join(",", _filterBoArtNamesBacking) : null;
        query["artLogic"] = _filterArtLogicBacking switch
        {
            ArtFilterLogic.And => "and",
            ArtFilterLogic.Or => "or",
            _ => null
        };
        query["epic"] = _filterEpicNamesSet.Count > 0 ? string.Join(",", _filterEpicNamesBacking) : null;
        query["piNot"] = _filterPiNotBacking ? (object?)true : null;
        query["pi"] = _filterPiNamesSet.Count > 0 ? string.Join(",", _filterPiNamesBacking) : null;
        query["status"] = _filterStatusesSet.Count > 0 ? string.Join(",", _filterStatusesBacking) : null;
        query["sortBy"] = _sortColumn;
        query["sortDesc"] = _sortDescending && _sortColumn is not null ? (object?)true : null;
        query["page"] = _currentPageBacking > 0 ? (object?)_currentPageBacking : null;
        query["pageSize"] = _pageSizeBacking != 10 ? (object?)_pageSizeBacking : null;
        var uri = Nav.GetUriWithQueryParameters(query);
        Nav.NavigateTo(uri, replace: true);
    }

    private void NavigateToEdit(int id)
    {
        var currentUri = new Uri(Nav.Uri);
        var returnUrl = currentUri.PathAndQuery;
        var editUri = Nav.GetUriWithQueryParameters(
            $"{RoutingPath.StrategicObjectives}/{id}",
            new Dictionary<string, object?> { ["returnUrl"] = returnUrl });
        Nav.NavigateTo(editUri);
    }

    private async Task SyncFilteredAsync()
    {
        var jiraKeys = _filteredRows
            .Where(r => !string.IsNullOrWhiteSpace(r.JiraId))
            .Select(r => r.JiraId!)
            .Distinct().ToList();

        if (jiraKeys.Count == 0)
        {
            Snackbar.Add("No filtered records have a Jira ID.", Severity.Warning);
            return;
        }

        var confirmed = await MessageService.Confirm(
            $"This will search Jira for the {jiraKeys.Count} filtered Strategic Objective(s) that have a Jira ID " +
            "and compare them with the database. You will then see the differences and choose which " +
            "records to update from Jira. No new records are created. Continue?",
            "Update filtered from Jira", "Continue");
        if (!confirmed)
        {
            return;
        }

        _syncing = true;
        StateHasChanged();

        try
        {
            var jiraIssues = await JiraIssueService.GetIssuesByKeysAsync(_userName!, jiraKeys);

            var dbItems = (await ProgramService.GetAllAsync())
                .Where(so => jiraKeys.Contains(so.JiraId!))
                .ToDictionary(so => so.JiraId!);

            var diffs = JiraDiffService.DiffJiraIssues(jiraIssues, dbItems)
                .Select(d => new JiraFilteredSyncDiffDialog.DiffItem(d.JiraKey, d.PropertyName, d.DbValue, d.JiraValue))
                .ToList();

            var parameters = new DialogParameters<JiraFilteredSyncDiffDialog>
            {
                { x => x.Diffs, diffs },
                { x => x.JiraIssues, jiraIssues }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
            var dialog = await DialogService.ShowAsync<JiraFilteredSyncDiffDialog>(
                "Jira Differences — Strategic Objectives", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled)
            {
                var selection = (JiraFilteredSyncDiffDialog.SyncSelection)result.Data!;
                await RunSyncAsync(0, string.Empty, selection.Issues, selection.PropertyMaskByJiraKey);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Sync filtered strategic objectives failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private async Task ExportFilteredAsync()
    {
        try
        {
            _exporting = true;
            StateHasChanged();

            var exportRows = _filteredRows.Select(r => new StrategicObjectiveExportRow
            {
                JiraId = r.JiraId,
                Summary = r.Summary,
                Epics = string.Join(", ", r.Epics.Select(e => e.Summary).Where(s => !string.IsNullOrEmpty(s))),
                Labels = r.Labels
            }).ToList();

            var bytes = StrategicObjectiveExportService.Generate(exportRows);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';a.download='StrategicObjectives.xlsx';document.body.appendChild(a);a.click();a.remove();");
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to export strategic objectives");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private void PopulateAvailableFilterValues()
    {
        _availableDepartments = _rows
            .SelectMany(r => r.CapitalProjects)
            .Where(cp => _cpToDept.ContainsKey(cp.Id))
            .Select(cp => _cpToDept[cp.Id])
            .Distinct().OrderBy(n => n).ToList();
        _availableCapitalProjects = _rows
            .SelectMany(r => r.Features.Select(f => f.ArtName))
            .Where(n => !string.IsNullOrEmpty(n))
            .Select(n => n!)
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(n => n).ToList();
        _availableBoArts = _rows
            .SelectMany(r => r.BoArts.Select(b => b.ArtName))
            .Where(n => !string.IsNullOrEmpty(n))
            .Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(n => n).ToList();
        _availableEpics = _rows
            .SelectMany(r => r.Epics)
            .Where(e => !string.IsNullOrEmpty(e.JiraId))
            .Select(e => (e.JiraId!, e.Summary))
            .DistinctBy(e => e.Item1, StringComparer.OrdinalIgnoreCase)
            .OrderBy(e => e.Item1).ToList();
        _availablePis = _rows
            .SelectMany(r => r.FeaturePis)
            .GroupBy(p => p.Name, StringComparer.OrdinalIgnoreCase)
            .Select(g => new { Name = g.Key, StartDate = g.Max(p => p.StartDate) })
            .OrderByDescending(p => p.StartDate ?? DateTime.MinValue)
            .ThenBy(p => p.Name)
            .Select(p => p.Name).ToList();
        _availableStatuses = _rows
            .Where(r => !string.IsNullOrEmpty(r.Status))
            .Select(r => r.Status!)
            .Distinct().OrderBy(n => n).ToList();
    }

    // --- Matched ART items dialogs ---

    private List<ArtItemRef> GetMatchedBos(ProgramRow r) =>
        r.BoArts
            .Where(b => _filterBoArtNamesSet.Contains(b.ArtName))
            .DistinctBy(b => b.Id)
            .OrderBy(b => b.JiraId, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<FeatureRef> GetMatchedFeatures(ProgramRow r)
    {
        var featureLabelFilter = string.IsNullOrWhiteSpace(_filterFeatureLabelBacking)
            ? null
            : _filterFeatureLabelBacking.Trim();
        var hasFeaturePiFilter = !_filterPiNotBacking && _filterPiNamesSet.Count > 0;
        return r.Features
            .Where(f => f.ArtName is not null && _filterCapitalProjectNamesSet.Contains(f.ArtName)
                && (featureLabelFilter is null || HasLabel(f.Labels, featureLabelFilter))
                && (!hasFeaturePiFilter || (f.PiName is not null && _filterPiNamesSet.Contains(f.PiName))))
            .DistinctBy(f => f.Id)
            .OrderBy(f => f.JiraId, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool HasLabel(string? labels, string labelFilter) =>
        !string.IsNullOrEmpty(labels)
        && labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Any(l => l.Contains(labelFilter, StringComparison.OrdinalIgnoreCase));

    private Task ShowMatchedBosAsync(ProgramRow r) =>
        ShowMatchedItemsAsync(
            GetMatchedBos(r).Select(b => new MatchedItemsDialog.ItemRow(b.Id, b.JiraId, b.Summary)).ToList(),
            RoutingPath.BusinessOutcomes,
            $"Business Outcomes matching selected ARTs — {r.JiraId}");

    private Task ShowMatchedFeaturesAsync(ProgramRow r) =>
        ShowMatchedItemsAsync(
            GetMatchedFeatures(r).Select(f => new MatchedItemsDialog.ItemRow(f.Id, f.JiraId, f.Summary)).ToList(),
            RoutingPath.Features,
            $"Features matching selected ARTs — {r.JiraId}");

    private async Task ShowMatchedItemsAsync(List<MatchedItemsDialog.ItemRow> rows, string itemRoute, string title)
    {
        var parameters = new DialogParameters<MatchedItemsDialog>
        {
            { x => x.Items, rows },
            { x => x.ItemRoute, itemRoute },
            { x => x.JiraTaskUrl, Configuration["JiraTaskUrl"] }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<MatchedItemsDialog>(title, parameters, options);
    }

    public void Dispose()
    {
        _filterDebounceTimer?.Dispose();
    }

    private record EpicRef(int Id, string? JiraId, string? Summary);
    private record FeaturePiRef(string Name, DateTime? StartDate);
    private record ArtItemRef(int Id, string? JiraId, string? Summary, string ArtName, string? Labels);
    private record FeatureRef(int Id, string? JiraId, string? Summary, string? ArtName, string? Labels, string? PiName);

    private record ProgramRow(
        int Id,
        string? JiraId,
        string Summary,
        List<CapitalProjectRef> CapitalProjects,
        List<EpicRef> Epics,
        List<FeaturePiRef> FeaturePis,
        List<ArtItemRef> BoArts,
        List<FeatureRef> Features,
        string? Labels,
        List<string> FeatureLabels,
        string? Status
    );
}
