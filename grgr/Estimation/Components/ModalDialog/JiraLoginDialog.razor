@using Estimation.Core.JiraLogic

@inject IJiraAuthService JiraAuth
@inject IWindowsAuthService WindowsAuth

<MudDialog>
    <DialogContent>
        @if (_checking)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
                      CloseIconClicked="() => _error = null">@_error</MudAlert>
        }

        @if (_isConnected)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Connected to Jira as <strong>@_userName</strong>
            </MudAlert>
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.LinkOff"
                       OnClick="DisconnectAsync" Disabled="_processing">
                Disconnect
            </MudButton>
        }
        else if (_requestToken is null)
        {
            @* ── Step 1: Request authorization ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Step 1:</strong> Request Authorization</MudText>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Click the button below to start the Jira OAuth authorization process.
                This will generate an authorization URL that you need to open in your browser.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Login"
                       OnClick="RequestAuthorizationAsync"
                       Disabled="_processing">
                @(_processing ? "Requesting..." : "Request Authorization")
            </MudButton>
        }
        else
        {
            @* ── Step 2: Open URL ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Step 2:</strong> Authorize in Jira</MudText>
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                Open the URL below in your browser, log in to Jira if needed, and click <strong>Allow</strong> to authorize this application.
            </MudText>
            <MudTextField Value="@_requestToken.AuthorizeUrl"
                          Label="Authorization URL" Variant="Variant.Outlined"
                          ReadOnly Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="CopyUrl" Class="mb-4" />

            @* ── Step 3: Enter verification code ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Step 3:</strong> Enter Verification Code</MudText>
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                After approving access in Jira, you will see a verification code. Paste it below and click <strong>Complete Login</strong>.
            </MudText>
            <MudTextField @bind-Value="_verificationCode" Label="Verification Code"
                          Variant="Variant.Outlined" Class="mb-4"
                          Placeholder="Paste the code from Jira" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="CompleteLoginAsync"
                       Disabled="@(_processing || string.IsNullOrWhiteSpace(_verificationCode))">
                @(_processing ? "Verifying..." : "Complete Login")
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private string? _userName;
    private bool _checking = true;
    private bool _processing;
    private bool _isConnected;
    private string? _error;
    private JiraRequestToken? _requestToken;
    private string? _verificationCode;

    protected override async Task OnInitializedAsync()
    {
        _userName = await WindowsAuth.GetUserName();
        if (_userName is not null)
            _isConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
        _checking = false;
    }

    private async Task RequestAuthorizationAsync()
    {
        _processing = true;
        _error = null;
        try
        {
            _requestToken = await JiraAuth.GetRequestTokenAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to request authorization: {ex.Message}";
        }
        finally { _processing = false; }
    }

    private async Task CompleteLoginAsync()
    {
        if (_requestToken is null || string.IsNullOrWhiteSpace(_verificationCode)) return;

        _processing = true;
        _error = null;
        try
        {
            var (accessToken, accessTokenSecret) = await JiraAuth.ExchangeAccessTokenAsync(
                _requestToken.Token, _requestToken.TokenSecret, _verificationCode.Trim());

            await JiraAuth.SaveTokenAsync(_userName!, accessToken, accessTokenSecret);

            _isConnected = true;
            _requestToken = null;
            _verificationCode = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to complete login: {ex.Message}";
        }
        finally { _processing = false; }
    }

    private async Task DisconnectAsync()
    {
        _processing = true;
        try
        {
            await JiraAuth.LogoutAsync(_userName!);
            _isConnected = false;
        }
        catch (Exception ex)
        {
            _error = $"Failed to disconnect: {ex.Message}";
        }
        finally { _processing = false; }
    }

    private async Task CopyUrl()
    {
        // Clipboard access requires JS interop; the user can select & copy from the text field
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(_isConnected));
}
