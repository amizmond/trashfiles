@attribute [Route(RoutingPath.StaticSettings)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services

@inject IStaticSettingsService SettingsService
@inject IUnfundedOptionService UnfundedOptionService
@inject ITechnologyStackService TechnologyStackService
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService

<PageTitle>Static Settings</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-4">Static Settings</MudText>

        <MudTabs Elevation="0" Rounded ApplyEffectsToContainer ActivePanelIndexChanged="OnActiveTabChanged">
                <MudTabPanel Text="Categories">
                    <MudPaper Class="pa-4" Elevation="0">
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Employee Categories</MudText>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add" OnClick="AddCategory">
                                Add
                            </MudButton>
                        </div>
                        <MudDataGrid T="EmployeeCategory" Items="_employeeCategories" Hover="true" Dense="true" Striped="true" Elevation="0" Loading="@(!_loadedTabs.Contains(0))" LoadingProgressColor="Color.Primary">
                            <Columns>
                                <TemplateColumn Title="Name">
                                    <CellTemplate>
                                        @if (_editingCategoryId == context.Item.Id)
                                        {
                                            <MudTextField @bind-Value="context.Item.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        }
                                        else
                                        {
                                            @context.Item.Name
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Description">
                                    <CellTemplate>
                                        @if (_editingCategoryId == context.Item.Id)
                                        {
                                            <MudTextField @bind-Value="context.Item.Description" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        }
                                        else
                                        {
                                            @context.Item.Description
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" CellStyle="width:120px; text-align:right" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        @if (_editingCategoryId == context.Item.Id)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="() => SaveCategoryAsync(context.Item)" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" OnClick="CancelEdit" />
                                        }
                                        else
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => _editingCategoryId = context.Item.Id" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteCategoryAsync(context.Item)" />
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <NoRecordsContent><MudText Class="pa-4 mud-text-secondary">No categories defined.</MudText></NoRecordsContent>
                            <PagerContent><MudDataGridPager T="EmployeeCategory" PageSizeOptions="new[] { 10, 25, 50 }" /></PagerContent>
                        </MudDataGrid>
                    </MudPaper>
                </MudTabPanel>
