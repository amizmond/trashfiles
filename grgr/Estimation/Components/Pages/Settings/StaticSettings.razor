    private async Task LoadTabAsync(int index)
    {
        try
        {
            switch (index)
            {
                case 0: _employeeCategories = await SettingsService.GetAllEmployeeCategoriesAsync(); break;
                case 1: _employeeTypes = await SettingsService.GetAllEmployeeTypesAsync(); break;
