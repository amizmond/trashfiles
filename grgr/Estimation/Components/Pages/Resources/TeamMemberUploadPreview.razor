@attribute [Route(RoutingPath.TeamsUploadPreview)]
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Estimation.Services
@using Serilog

@inject ITeamMemberUploadService UploadService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Upload Preview - @(TeamMemberUploadPreviewState.TeamName ?? "Team")</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo($"{RoutingPath.Teams}/{Id}"))" />
            <MudText Typo="Typo.h6">Upload Preview - @(TeamMemberUploadPreviewState.TeamName ?? "Team")</MudText>
        </div>

        @if (_saving)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
        }

        @if (_rows is null || !_rows.Any())
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                No data to preview. Please go back and upload a file.
            </MudAlert>
        }
        else
        {
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
                <MudAlert Severity="Severity.Info" Class="mb-3">
                    @_rows.Count row(s) parsed.
                    @_rows.Count(r => r.IsNew) new member(s) will be created.
                    @_rows.Count(r => !r.IsNew) existing member(s) will be updated.
                </MudAlert>

                <div class="mb-3 d-flex flex-wrap gap-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                        New value / Changed
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">
                        Will be removed
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        No change
                    </MudChip>
                </div>

                <MudTable T="TeamMemberUploadRow"
                          Items="_rows"
                          Hover
                          Striped
                          Dense
                          Bordered="true"
                          HorizontalScrollbar
                          Elevation="0">

                    <HeaderContent>
                        <MudTh Style="min-width:60px">#</MudTh>
                        <MudTh Style="min-width:80px">Status</MudTh>
                        <MudTh Style="min-width:250px">Employee Name</MudTh>
                        <MudTh Style="min-width:150px">Employee Number</MudTh>
                        @foreach (var skillName in _allSkillNames)
                        {
                            <MudTh Style="text-align:center; min-width:130px">
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@skillName</MudText>
                            </MudTh>
                        }
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>@(_rows.IndexOf(context) + 1)</MudTd>
                        <MudTd>
                            @if (context.IsNew)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">New</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Update</MudChip>
                            }
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.EmployeeName</MudText>
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2">@context.EmployeeNumber</MudText>
                        </MudTd>
                        @foreach (var skillName in _allSkillNames)
                        {
                            var skill = context.Skills.FirstOrDefault(s => s.SkillName == skillName);
                            <MudTd Style="text-align:center">
                                @if (skill is null)
                                {
                                    @* No data for this skill in the upload *@
                                }
                                else if (skill.IsRemoved)
                                {
                                    <MudTooltip Text="@($"Was: {skill.OldLevelName ?? "Assigned"}")" Placement="Placement.Top">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">
                                            Remove
                                        </MudChip>
                                    </MudTooltip>
                                }
                                else if (skill.IsChanged)
                                {
                                    var tooltip = skill.OldLevelName is not null
                                        ? $"Was: {skill.OldLevelName}"
                                        : "New skill assignment";
                                    <MudTooltip Text="@tooltip" Placement="Placement.Top">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                                            @(skill.NewLevelName ?? "Assigned")
                                        </MudChip>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                        @(skill.NewLevelName ?? "Assigned")
                                    </MudChip>
                                }
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>

                <div class="d-flex gap-2 mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="ConfirmAsync" Disabled="_saving">
                        Confirm & Save
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               OnClick="Cancel" Disabled="_saving">
                        Cancel
                    </MudButton>
                </div>
            </div>
        }
    </MudPaper>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private List<TeamMemberUploadRow>? _rows;
    private List<string> _allSkillNames = new();
    private bool _saving;

    protected override void OnInitialized()
    {
        if (TeamMemberUploadPreviewState.PendingUpload is null || TeamMemberUploadPreviewState.TeamId != Id)
        {
            Navigation.NavigateTo($"{RoutingPath.Teams}/{Id}");
            return;
        }

        _rows = TeamMemberUploadPreviewState.PendingUpload;

        _allSkillNames = _rows
            .SelectMany(r => r.Skills)
            .Select(s => s.SkillName)
            .Distinct()
            .OrderBy(n => n)
            .ToList();
    }

    private async Task ConfirmAsync()
    {
        if (_rows is null) return;

        _saving = true;
        try
        {
            await UploadService.SaveAsync(_rows, Id);
            TeamMemberUploadPreviewState.Clear();
            Snackbar.Add("Team members uploaded successfully.", Severity.Success);
            Navigation.NavigateTo($"{RoutingPath.Teams}/{Id}", true);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to save uploaded team members");
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        TeamMemberUploadPreviewState.Clear();
        Navigation.NavigateTo($"{RoutingPath.Teams}/{Id}");
    }
}
