@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog
@attribute [Route(RoutingPath.Skills)]

@inject ISkillService SkillService
@inject NavigationManager Navigation
@inject IModalDialogService MessageService

<PageTitle>Skills</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6">Skills</MudText>

        <MudToolBar>
            <MudSpacer />

            <MudTextField @bind-Value="_searchTerm"
                          Placeholder="Search by name..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0 mr-4"
                          Style="min-width:260px"
                          Clearable
                          Immediate
                          DebounceInterval="400"
                          OnDebounceIntervalElapsed="OnSearchChanged" />

            <div style="position:relative; margin-right: 10px;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ViewColumn"
                           Disabled="_isLoading"
                           OnClick="() => _columnsPopoverOpen = !_columnsPopoverOpen">
                    Columns
                </MudButton>
                <MudPopover Open="_columnsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:280px">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Toggle Columns</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _columnsPopoverOpen = false" />
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <MudSwitch T="bool" @bind-Value="_showId" Label="Id" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showName" Label="Name" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showDescription" Label="Description" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showLevels" Label="Levels" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showCreated" Label="Created" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showUpdated" Label="Updated" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showActions" Label="Actions" Color="Color.Primary" Dense />
                    </div>
                </MudPopover>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Style="margin-right: 10px"
                       OnClick="@(() => Navigation.NavigateTo(RoutingPath.SkillsNew))">
                New
            </MudButton>
        </MudToolBar>

        <MudDivider />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="my-3" ShowCloseIcon CloseIconClicked="() => _errorMessage = null">@_errorMessage</MudAlert>
        }

        <MudDataGrid T="Skill"
                     Striped
                     Items="@_filteredSkills"
                     ReadOnly="true"
                     Bordered="true"
                     Dense="true"
                     Loading="_isLoading"
                     LoadingProgressColor="Color.Primary"
                     Elevation="0">
            <Columns>
                <PropertyColumn Property="p => p.Id" Sortable="true" Hidden="!_showId" />
                <PropertyColumn Property="p => p.Name" Title="Name" Sortable="true" Hidden="!_showName" />
                <PropertyColumn Property="p => p.Description" Title="Description" Sortable="true" Hidden="!_showDescription" />

                <TemplateColumn Title="Levels" Filterable="false" Hidden="!_showLevels">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Item.Levels.Count</MudChip>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Created" Filterable="false" Hidden="!_showCreated">
                    <CellTemplate>
                        @context.Item.Created?.ToString("yyyy-MM-dd")
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Updated" Filterable="false" Hidden="!_showUpdated">
                    <CellTemplate>
                        @(context.Item.Updated?.ToString("yyyy-MM-dd") ?? "")
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn CellClass="d-flex justify-end" Hidden="!_showActions">
                    <CellTemplate>
                        <MudStack Row>
                            <MudFab Class="m-2" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" Href="@($"{RoutingPath.Skills}/{context.Item.Id}")" Target="_blank" />
                            <MudFab Class="m-2" StartIcon="@Icons.Material.Filled.DeleteForever" IconColor="Color.Secondary" Size="Size.Small" OnClick="@(() => DeleteAsync(context.Item))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent>
                <MudText Class="pa-4 mud-text-secondary">No skills found. Create one to get started.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudDataGridPager T="Skill" PageSizeOptions="new[] { 10, 25, 50 }" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</div>

@code {
    private List<Skill> _skills = new();
    private string? _searchTerm;
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool _columnsPopoverOpen;

    // --- Column visibility ---
    private bool _showId = true;
    private bool _showName = true;
    private bool _showDescription = true;
    private bool _showLevels = true;
    private bool _showCreated = true;
    private bool _showUpdated = true;
    private bool _showActions = true;

    private IEnumerable<Skill> _filteredSkills => string.IsNullOrWhiteSpace(_searchTerm)
        ? _skills
        : _skills.Where(s => s.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true
                          || s.Description?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true);

    protected override async Task OnInitializedAsync() => await LoadSkillsAsync();

    private async Task LoadSkillsAsync()
    {
        _isLoading = true;
        try
        {
            _skills = await SkillService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load skills: {ex.Message}";
            await MessageService.Exception(ex, $"Failed to load skills: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnSearchChanged(string _) => StateHasChanged();

    private async Task DeleteAsync(Skill skill)
    {
        try
        {
            if (await MessageService.Confirm($"Delete {skill.Name} ?"))
            {
                _isLoading = true;
                await SkillService.DeleteAsync(skill.Id);
                _skills.Remove(skill);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex, ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
