@attribute [Route(RoutingPath.TechnologyStacksNew)]
@attribute [Route(RoutingPath.TechnologyStacksEdit)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject ITechnologyStackService TsService
@inject ISkillService SkillService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService

<PageTitle>@(_isNew ? "New Technology Stack" : _model.Name)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo(RoutingPath.TechnologyStacks))" />
            <MudText Typo="Typo.h6">@(_isNew ? "New Technology Stack" : _model.Name)</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_saving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <MudTextField @bind-Value="_model.Name" Label="Name *"
                                          Variant="Variant.Outlined" For="() => _model.Name" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Description" Label="Description"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-4" />
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                            }
                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                           Color="Color.Primary" Disabled="_saving"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save")
                                </MudButton>
                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto"
                                               StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                                }
                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg" Style="height:100%">
                        <MudToolBar Dense Class="gap-2 flex-wrap" Style="min-height:48px; margin-bottom:15px;">
                            <MudText Typo="Typo.h6" Style="white-space:nowrap">Skills</MudText>
                            <MudSpacer />
                            @if (!_isNew)
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedSkillId"
                                           Label="Select skill"
                                           Variant="Variant.Text"
                                           Dense="true"
                                           Style="min-width:130px">
                                    @foreach (var s in _availableSkills)
                                    {
                                        <MudSelectItem T="int?" Value="s.Id">@s.Name</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="AddSkillAsync"
                                           Disabled="_selectedSkillId is null">
                                    Add
                                </MudButton>
                            }
                        </MudToolBar>
                        <MudDivider />
                        @if (_isNew)
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                Save first to assign skills.
                            </MudText>
                        }
                        else if (!_model.TechnologyStackSkills.Any())
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                No skills assigned yet.
                            </MudText>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2 pa-3">
                                @foreach (var tss in _model.TechnologyStackSkills)
                                {
                                    <MudChip T="string" Size="Size.Medium" Color="Color.Primary"
                                             Variant="Variant.Filled"
                                             OnClose="() => RemoveSkillAsync(tss.SkillId)">
                                        @tss.Skill.Name
                                    </MudChip>
                                }
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
    </MudPaper>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private int? _selectedSkillId;
    private TechnologyStack _model = new();
    private List<Skill> _allSkills = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool _isNew => Id is null or 0;
    private IEnumerable<Skill> _availableSkills => _allSkills.Where(s => _model.TechnologyStackSkills.All(tss => tss.SkillId != s.Id));

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        if (!_isNew)
        {
            var skillsTask = SkillService.GetAllAsync();
            var tsTask = TsService.GetByIdAsync(Id!.Value);
            await Task.WhenAll(skillsTask, tsTask);

            var existing = tsTask.Result;
            if (existing is null) { Navigation.NavigateTo(RoutingPath.TechnologyStacks); return; }
            _model = existing;
            _allSkills = skillsTask.Result;
        }
        else
        {
            _model = new TechnologyStack();
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;
        try
        {
            if (_isNew)
            {
                var c = await TsService.CreateAsync(_model);
                Navigation.NavigateTo($"{RoutingPath.TechnologyStacks}/{c.Id}", true);
            }
            else
            {
                await TsService.UpdateAsync(_model);
                Snackbar.Add("Saved.", Severity.Success);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.Name} ?"))
            {
                await TsService.DeleteAsync(_model.Id);
                Navigation.NavigateTo(RoutingPath.TechnologyStacks);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    private async Task AddSkillAsync()
    {
        if (_selectedSkillId is null) return;
        await TsService.AddSkillAsync(_model.Id, _selectedSkillId.Value);
        var skill = _allSkills.FirstOrDefault(s => s.Id == _selectedSkillId);
        if (skill is null) return;
        _model.TechnologyStackSkills.Add(new TechnologyStackSkill
        {
            TechnologyStackId = _model.Id,
            SkillId = _selectedSkillId.Value,
            Skill = skill
        });
        _selectedSkillId = null;
    }

    private async Task RemoveSkillAsync(int skillId)
    {
        await TsService.RemoveSkillAsync(_model.Id, skillId);
        _model.TechnologyStackSkills = _model.TechnologyStackSkills.Where(tss => tss.SkillId != skillId).ToList();
    }
}
