@attribute [Route(RoutingPath.HumanResourcesNew)]
@attribute [Route(RoutingPath.HumanResourcesEdit)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject IHumanResourceService HrService
@inject ISkillService SkillService
@inject IStaticSettingsService StaticSettingsService
@inject NavigationManager Navigation
@inject IModalDialogService MessageService

<PageTitle>@(_isNew ? "New Human Resource" : _model.FullName)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
            <MudText Typo="Typo.h6">@(_isNew ? "New Human Resource" : _model.FullName)</MudText>
        </div>

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_isSaving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_isSaving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Personal Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />

                            <MudCheckBox @bind-Value="_model.IsActive" Label="Active" Class="mb-3" />

                            <MudTextField @bind-Value="_model.EmployeeNumber" Label="BRID"
                                          Variant="Variant.Outlined" For="() => _model.EmployeeNumber"
                                          Placeholder="e.g. G00000001" Class="mb-3" />

                            <MudTextField @bind-Value="_model.EmployeeName" Label="Employee Name *"
                                          Variant="Variant.Outlined" For="() => _model.EmployeeName"
                                          Placeholder="John" Class="mb-3" />

                            <MudTextField @bind-Value="_model.FullName" Label="Full Name *"
                                          Variant="Variant.Outlined" For="() => _model.FullName"
                                          Placeholder="John Doe" Class="mb-3" />

                            <MudTextField @bind-Value="_model.LineManagerName" Label="Line Manager Name"
                                          Variant="Variant.Outlined" Placeholder="Manager name" Class="mb-3" />

                            <MudTextField @bind-Value="_model.Cio" Label="CIO"
                                          Variant="Variant.Outlined" Class="mb-3" />

                            <MudTextField @bind-Value="_model.Cio1" Label="CIO-1"
                                          Variant="Variant.Outlined" Class="mb-3" />

                            <MudTextField @bind-Value="_model.Cio2" Label="CIO-2"
                                          Variant="Variant.Outlined" Class="mb-3" />

                            <MudSelect T="int?" @bind-Value="_model.EmployeeCategoryId" Label="Employee Category"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _employeeCategories)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.EmployeeTypeId" Label="Employee Type"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _employeeTypes)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.EmployeeRoleId" Label="Employee Role"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _employeeRoles)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.EmployeeVendorId" Label="Employee Vendor"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _employeeVendors)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.CorporateGradeId" Label="Corporate Grade"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _corporateGrades)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.CityId" Label="City"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _cities)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.CountryId" Label="Country"
                                       Variant="Variant.Outlined" Clearable Class="mb-3">
                                @foreach (var item in _countries)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_model.TeamRoleId" Label="Role"
                                       Variant="Variant.Outlined" Clearable Class="mb-4">
                                @foreach (var item in _teamRoles)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)item.Id)">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            @if (!string.IsNullOrEmpty(_errorMessage))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_errorMessage</MudAlert>
                            }

                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                           Color="Color.Primary" Disabled="_isSaving"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save Changes")
                                </MudButton>

                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto"
                                               StartIcon="@Icons.Material.Filled.Delete">
                                        Delete
                                    </MudButton>
                                }
                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudPaper Elevation="2" Class="rounded-lg" Style="height:100%">
                        <MudToolBar Dense>
                            <MudText Typo="Typo.h6">Skills</MudText>
                        </MudToolBar>
                        <MudDivider />

                        @if (!_allSkills.Any())
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                No skills available in the system.
                            </MudText>
                        }
                        else
                        {
                            <MudTable 
                                T="Skill"
                                Items="_allSkills"
                                Hover
                                Dense
                                Bordered
                                Striped
                                Elevation="0"
                                Class="rounded-0"
                            >
                                <HeaderContent>
                                    <MudTh>Skill</MudTh>
                                    <MudTh Style="min-width:180px">Level</MudTh>
                                    <MudTh Style="text-align:right">Action</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    @{
                                        var assignment = GetAssignment(context.Id);
                                        var isAssigned = assignment is not null;
                                    }
                                    <MudTd DataLabel="Skill">
                                        <MudText Typo="Typo.body2" Class="@(isAssigned ? "font-weight-bold" : "mud-text-secondary")">
                                            @context.Name
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Level">
                                        @if (isAssigned)
                                        {
                                            <MudSelect T="int?" Value="@assignment!.SkillLevelId"
                                                       ValueChanged="@(val => OnLevelChanged(context.Id, val))"
                                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                                       Placeholder="— No level —">
                                                <MudSelectItem T="int?" Value="@((int?)null)">— No level —</MudSelectItem>
                                                @foreach (var level in context.Levels)
                                                {
                                                    <MudSelectItem T="int?" Value="@((int?)level.Id)">@level.Name</MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Action" Style="text-align:right">
                                        @if (isAssigned)
                                        {
                                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                                       Size="Size.Small" StartIcon="@Icons.Material.Filled.Remove"
                                                       OnClick="() => RemoveSkillAsync(context.Id)"
                                                       Disabled="_isNew">
                                                Remove
                                            </MudButton>
                                        }
                                        else
                                        {
                                            <MudButton Variant="Variant.Outlined" Color="Color.Success"
                                                       Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                                                       OnClick="() => AddSkillAsync(context.Id)"
                                                       Disabled="_isNew">
                                                Add
                                            </MudButton>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>

                            @if (_isNew)
                            {
                                <MudText Class="pa-2 mud-text-secondary" Typo="Typo.caption" Align="Align.Center">
                                    Save the record first to assign skills.
                                </MudText>
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
    </MudPaper>
</div>



@code {
    [Parameter] public int? Id { get; set; }

    private HumanResource _model = new();
    private List<Skill> _allSkills = new();
    private List<HumanResourceSkill> _assignments = new();

    private List<EmployeeCategory> _employeeCategories = new();
    private List<EmployeeType> _employeeTypes = new();
    private List<EmployeeRole> _employeeRoles = new();
    private List<EmployeeVendor> _employeeVendors = new();
    private List<CorporateGrade> _corporateGrades = new();
    private List<City> _cities = new();
    private List<Country> _countries = new();
    private List<TeamRole> _teamRoles = new();

    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;

    private bool _isNew => Id is null or 0;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            await Task.WhenAll(
                LoadSkillsAsync(),
                LoadLookupsAsync()
            );

            if (!_isNew)
            {
                var existing = await HrService.GetByIdAsync(Id!.Value);
                if (existing is null) { Navigation.NavigateTo(RoutingPath.HumanResources); return; }

                _model = existing;
                _assignments = existing.HumanResourceSkills.ToList();
            }
            else
            {
                _model = new HumanResource();
                _assignments = new();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSkillsAsync()
    {
        _allSkills = await SkillService.GetAllAsync();
    }

    private async Task LoadLookupsAsync()
    {
        var tasks = new List<Task>
        {
            Task.Run(async () => _employeeCategories = await StaticSettingsService.GetAllEmployeeCategoriesAsync()),
            Task.Run(async () => _employeeTypes = await StaticSettingsService.GetAllEmployeeTypesAsync()),
            Task.Run(async () => _employeeRoles = await StaticSettingsService.GetAllEmployeeRolesAsync()),
            Task.Run(async () => _employeeVendors = await StaticSettingsService.GetAllEmployeeVendorsAsync()),
            Task.Run(async () => _corporateGrades = await StaticSettingsService.GetAllCorporateGradesAsync()),
            Task.Run(async () => _cities = await StaticSettingsService.GetAllCitiesAsync()),
            Task.Run(async () => _countries = await StaticSettingsService.GetAllCountriesAsync()),
            Task.Run(async () => _teamRoles = await StaticSettingsService.GetAllTeamRolesAsync()),
        };
        await Task.WhenAll(tasks);
    }

    private HumanResourceSkill? GetAssignment(int skillId)
        => _assignments.FirstOrDefault(a => a.SkillId == skillId);

    private async Task SaveAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        try
        {
            if (_isNew)
            {
                var created = await HrService.CreateAsync(_model);
                Navigation.NavigateTo($"{RoutingPath.HumanResources}/{created.Id}", replace: true);
            }
            else
            {
                _model = await HrService.UpdateAsync(_model);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.FullName} ?"))
            {
                await DeleteAsync();
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    private async Task DeleteAsync()
    {
        _isSaving = true;
        try
        {
            await HrService.DeleteAsync(_model.Id);
            Navigation.NavigateTo(RoutingPath.HumanResources);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Delete failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task AddSkillAsync(int skillId)
    {
        try
        {
            await HrService.SetSkillAsync(_model.Id, skillId, null);

            var skill = _allSkills.First(s => s.Id == skillId);
            _assignments.Add(new HumanResourceSkill
            {
                HumanResourceId = _model.Id,
                SkillId = skillId,
                Skill = skill
            });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not add skill: {ex.Message}";
        }
    }

    private async Task RemoveSkillAsync(int skillId)
    {
        try
        {
            await HrService.RemoveSkillAsync(_model.Id, skillId);
            _assignments.RemoveAll(a => a.SkillId == skillId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not remove skill: {ex.Message}";
        }
    }

    private async Task OnLevelChanged(int skillId, int? levelId)
    {
        try
        {
            await HrService.SetSkillAsync(_model.Id, skillId, levelId);

            var assignment = GetAssignment(skillId);
            if (assignment is not null)
            {
                assignment.SkillLevelId = levelId;
                assignment.SkillLevel = levelId.HasValue
                    ? _allSkills.First(s => s.Id == skillId)
                                .Levels.FirstOrDefault(l => l.Id == levelId)
                    : null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not update level: {ex.Message}";
        }
    }

    private void GoBack() => Navigation.NavigateTo(RoutingPath.HumanResources);
}
