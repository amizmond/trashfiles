@using Estimation.Core.Services

<MudPaper Class="pa-4 rounded-lg" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Skill Coverage (Resources per Skill)</MudText>
    @if (Data is { Count: > 0 })
    {
        <div style="max-height: 400px; overflow-y: auto;">
            @foreach (var item in Data)
            {
                <div class="d-flex align-center mb-2">
                    <MudText Typo="Typo.body2" Style="width: 350px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
                             title="@item.Label">
                        @item.Label
                    </MudText>
                    <MudProgressLinear Color="Color.Primary" Value="@GetPercent(item.Value)"
                                       Class="mx-2 flex-grow-1" Style="height: 20px; border-radius: 4px;" />
                    <MudText Typo="Typo.body2" Style="min-width: 30px; text-align: right;">
                        @((int)item.Value)
                    </MudText>
                </div>
            }
        </div>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Default">No data available</MudText>
    }
</MudPaper>

@code {
    [Parameter] public List<ChartItem> Data { get; set; } = new();

    private double _max;

    protected override void OnParametersSet()
    {
        _max = Data is { Count: > 0 } ? Data.Max(d => d.Value) : 1;
    }

    private double GetPercent(double value) => _max > 0 ? value / _max * 100 : 0;
}
