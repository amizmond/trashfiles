@using Estimation.Core.Services

<MudPaper Class="pa-4 rounded-lg" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">PI Timeline</MudText>
    @if (FilteredData is { Count: > 0 })
    {
        <div style="max-height: 400px; overflow-y: auto;">
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var pi in FilteredData)
            {
                <MudTimelineItem Color="@(pi.IsCurrent ? Color.Success : Color.Default)"
                                 Variant="Variant.Filled"
                                 Size="@(pi.IsCurrent ? Size.Medium : Size.Small)">
                    <ItemContent>
                        <MudCard Elevation="@(pi.IsCurrent ? 3 : 1)" Class="@(pi.IsCurrent ? "border-solid border mud-border-success" : "")">
                            <MudCardContent Class="pa-3">
                                <MudText Typo="Typo.subtitle1">
                                    <b>@pi.Name</b>
                                    @if (pi.IsCurrent)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2">Current</MudChip>
                                    }
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Default">
                                    @FormatDate(pi.StartDate) — @FormatDate(pi.EndDate)
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    <b>@pi.FeatureCount</b> features
                                </MudText>
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
        </div>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Default">No PI data available</MudText>
    }
</MudPaper>

@code {
    [Parameter] public List<PiTimelineItem> Data { get; set; } = new();

    private List<PiTimelineItem> FilteredData => Data?.Where(pi => pi.StartDate.HasValue).ToList() ?? new();

    private static string FormatDate(DateTime? date) => date?.ToString("MMM dd, yyyy") ?? "—";
}
