@attribute [Route(RoutingPath.PisNew)]
@attribute [Route(RoutingPath.PisEdit)]

@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject IPiService PiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService

<PageTitle>@(_isNew ? "New PI" : _model.Name)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo(RoutingPath.Pis))" />
            <MudText Typo="Typo.h6">@(_isNew ? "New PI" : _model.Name)</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_saving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                @* ── Details ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <MudTextField @bind-Value="_model.Name" Label="Name *" Variant="Variant.Outlined"
                                          For="() => _model.Name" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Priority" Label="Priority" Variant="Variant.Outlined"
                                          Placeholder="e.g. High" Class="mb-3" />
                            <div class="d-flex gap-3 mb-3">
                                <MudDatePicker @bind-Date="_model.StartDate" Label="Start Date"
                                               Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" Style="flex:1" />
                                <MudDatePicker @bind-Date="_model.EndDate" Label="End Date"
                                               Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" Style="flex:1" />
                            </div>
                            <MudTextField @bind-Value="_model.Description" Label="Description"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Comments" Label="Comments"
                                          Variant="Variant.Outlined" Lines="2" Class="mb-4" />
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                            }
                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                           Color="Color.Primary" Disabled="_saving"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save")
                                </MudButton>
                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto">Delete</MudButton>
                                }
                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>

            </MudGrid>
            </div>
        }
    </MudPaper>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private Pi _model = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool _isNew => Id is null or 0;
    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        if (!_isNew)
        {
            var existing = await PiService.GetByIdAsync(Id!.Value);
            if (existing is null) { Navigation.NavigateTo(RoutingPath.Pis); return; }
            _model = existing;
        }
        else _model = new Pi();
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;
        try
        {
            if (_isNew) { var c = await PiService.CreateAsync(_model); Navigation.NavigateTo($"{RoutingPath.Pis}/{c.Id}", true); }
            else { await PiService.UpdateAsync(_model); _model = (await PiService.GetByIdAsync(_model.Id))!; Snackbar.Add("Saved.", Severity.Success); }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.Name} ?"))
            {
                await PiService.DeleteAsync(_model.Id);
                Navigation.NavigateTo(RoutingPath.Pis);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

}