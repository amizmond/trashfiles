@using Estimation.Core.Models

<div class="pa-4" style="min-width: 700px; max-width: 90vw; max-height: 80vh; overflow-y: auto;">
    <MudText Typo="Typo.h6" Class="mb-3">Team Capacity — @PiName</MudText>

    @if (_teamStats.Count > 0)
    {
        <div style="max-height: 400px; overflow-y: auto;" class="mb-4">
            @foreach (var stat in _teamStats)
            {
                <div class="d-flex align-center mb-2">
                    <a href="@($"{RoutingPath.Teams}/{stat.TeamId}")" target="_blank" style="text-decoration:none; width: 200px; flex-shrink: 0;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Style="cursor:pointer">
                            @stat.TeamName
                        </MudChip>
                    </a>
                    <MudProgressLinear Color="Color.Info" Value="@GetPercent(stat.TotalAllocated)"
                                       Class="mx-2 flex-grow-1" Style="height: 20px; border-radius: 4px;" />
                    <MudText Typo="Typo.body2" Style="min-width: 80px; text-align: right;">
                        @stat.TotalAllocated / @(stat.TotalAllocated + stat.TotalRemaining)
                    </MudText>
                </div>
            }
        </div>

        <MudTable Items="_teamStats" Dense Hover Bordered>
            <HeaderContent>
                <MudTh>Team</MudTh>
                <MudTh>Allocated</MudTh>
                <MudTh>Remaining</MudTh>
                <MudTh>Features</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <a href="@($"{RoutingPath.Teams}/{context.TeamId}")" target="_blank" style="text-decoration:none">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Style="cursor:pointer">
                            @context.TeamName
                        </MudChip>
                    </a>
                </MudTd>
                <MudTd>@context.TotalAllocated</MudTd>
                <MudTd>@context.TotalRemaining</MudTd>
                <MudTd>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var f in context.Features)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                @(!string.IsNullOrEmpty(f.JiraId) ? f.JiraId : f.Name)
                            </MudChip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudText Typo="Typo.body1" Class="mud-text-secondary">No team allocations for this PI.</MudText>
    }

    <div class="d-flex justify-end mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
    </div>
</div>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public PiCapacityResult? CapacityResult { get; set; }
    [Parameter] public string? PiName { get; set; }

    private List<TeamCapacityStat> _teamStats = new();
    private double _max;

    protected override void OnParametersSet()
    {
        if (CapacityResult is null) return;

        // Aggregate team allocations across all features in this PI
        var teamMap = new Dictionary<int, TeamCapacityStat>();

        foreach (var feature in CapacityResult.FeatureResults)
        {
            var featureTeamIds = new HashSet<int>();

            foreach (var skill in feature.TechnologyStackAllocations)
            {
                foreach (var ta in skill.TeamAllocations)
                {
                    if (!teamMap.TryGetValue(ta.TeamId, out var stat))
                    {
                        stat = new TeamCapacityStat
                        {
                            TeamId = ta.TeamId,
                            TeamName = ta.TeamName
                        };
                        teamMap[ta.TeamId] = stat;
                    }

                    stat.TotalAllocated += ta.AllocatedCapacity;
                    stat.TotalRemaining = ta.RemainingCapacity;
                    featureTeamIds.Add(ta.TeamId);
                }
            }

            foreach (var teamId in featureTeamIds)
            {
                teamMap[teamId].FeatureCount++;
                teamMap[teamId].Features.Add(new FeatureRef { JiraId = feature.JiraId, Name = feature.FeatureName });
            }
        }

        _teamStats = teamMap.Values.OrderByDescending(t => t.TotalAllocated).ToList();
        _max = _teamStats.Count > 0 ? _teamStats.Max(t => t.TotalAllocated + t.TotalRemaining) : 1;
    }

    private double GetPercent(int allocated) => _max > 0 ? allocated / _max * 100 : 0;

    private void Close() => MudDialog.Close();

    private class TeamCapacityStat
    {
        public int TeamId { get; set; }
        public string TeamName { get; set; } = null!;
        public int TotalAllocated { get; set; }
        public int TotalRemaining { get; set; }
        public int FeatureCount { get; set; }
        public List<FeatureRef> Features { get; set; } = new();
    }

    private class FeatureRef
    {
        public string? JiraId { get; set; }
        public string? Name { get; set; }
    }
}
