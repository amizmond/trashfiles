@using Estimation.Core.Models

<div class="pa-4" style="min-width: 400px;">
    <MudText Typo="Typo.body1" Class="mb-3">
        Please enter a comment explaining why you are changing the ranking for
        <b>@Feature.JiraId @Feature.Name</b>.
    </MudText>

    <MudTextField @bind-Value="_comment"
                  Label="Comment"
                  Variant="Variant.Outlined"
                  Lines="3"
                  MaxLength="250"
                  Counter="250"
                  Immediate
                  AutoFocus />

    <div class="d-flex justify-end gap-2 mt-4">
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@string.IsNullOrWhiteSpace(_comment)"
                   OnClick="Submit">
            OK
        </MudButton>
    </div>
</div>

@code {
    private string? _comment;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Feature Feature { get; set; } = null!;

    protected override void OnInitialized()
    {
        _comment = Feature.Comments;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(_comment));
}
