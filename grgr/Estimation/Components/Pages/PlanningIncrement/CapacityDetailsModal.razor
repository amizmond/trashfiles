@using Estimation.Core.Models

<div style="min-width: 800px; max-width: 90vw; max-height: 80vh; display: flex; flex-direction: column;">
    @if (CapacityResult is not null)
    {
        <div class="pa-4" style="flex: 1; overflow-y: auto;">
            <MudText Typo="Typo.h6" Class="mb-3">Feature: @CapacityResult.FeatureName</MudText>

            <div class="d-flex gap-4 mb-3">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    Ranking: @CapacityResult.Ranking
                </MudChip>
                <MudChip T="string" Size="Size.Small"
                         Color="@(CapacityResult.IsFullyReserved ? Color.Success : Color.Error)"
                         Variant="Variant.Filled">
                    @(CapacityResult.IsFullyReserved ? "Fully Reserved" : "Capacity Shortage")
                </MudChip>
                <MudText Typo="Typo.body2" Class="mud-text-secondary align-self-center">
                    Reserved: @CapacityResult.TotalReserved / @CapacityResult.TotalRequired
                </MudText>
            </div>

            @if (CapacityResult.TechnologyStackAllocations.Count == 0)
            {
                <MudText Typo="Typo.body1" Class="mud-text-secondary">No technology stack requirements for this feature.</MudText>
            }
            else
            {
                @* --- Technology Stack Capacity Chart --- *@
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Technology Stack Capacity</MudText>
                <MudChart T="double" ChartType="ChartType.Bar"
                          ChartSeries="@_techStackSeries"
                          ChartLabels="@_techStackLabels"
                          Width="100%" Height="250px" />

                @* --- Team Allocation Chart --- *@
                @if (_teamStats.Count > 0)
                {
                    <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Team Allocations</MudText>
                    <div class="mb-4">
                        @foreach (var stat in _teamStats)
                        {
                            <div class="d-flex align-center mb-2">
                                <a href="@($"{RoutingPath.Teams}/{stat.TeamId}")" target="_blank"
                                   style="text-decoration:none; width: 180px; flex-shrink: 0;">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Style="cursor:pointer">
                                        @stat.TeamName
                                    </MudChip>
                                </a>
                                <div class="flex-grow-1 mx-2">
                                    <MudProgressLinear Color="@(stat.RemainingCapacity > 0 ? Color.Info : Color.Warning)"
                                                       Value="@GetTeamPercent(stat)"
                                                       Style="height: 20px; border-radius: 4px;" />
                                </div>
                                <MudText Typo="Typo.body2" Style="min-width: 120px; text-align: right;">
                                    @stat.AllocatedCapacity / @(stat.AllocatedCapacity + stat.RemainingCapacity)
                                </MudText>
                            </div>
                        }
                    </div>
                }

                @* --- Detailed Table --- *@
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Allocation Details</MudText>
                <MudTable Items="CapacityResult.TechnologyStackAllocations" Dense Hover Bordered>
                    <HeaderContent>
                        <MudTh>Technology Stack</MudTh>
                        <MudTh>Required</MudTh>
                        <MudTh>Reserved</MudTh>
                        <MudTh>Shortage</MudTh>
                        <MudTh>Match Method</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Teams</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.TechnologyStackName</MudTd>
                        <MudTd>@context.Required</MudTd>
                        <MudTd>@context.Reserved</MudTd>
                        <MudTd>
                            @{
                                var shortage = context.Required - context.Reserved;
                            }
                            @if (shortage > 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Error">-@shortage</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Success">0</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@GetMethodColor(context.MatchMethod)">
                                @FormatMatchMethod(context.MatchMethod)
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <MudIcon Icon="@(context.IsReserved ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)"
                                     Color="@(context.IsReserved ? Color.Success : Color.Error)"
                                     Size="Size.Small" />
                        </MudTd>
                        <MudTd>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var ta in context.TeamAllocations)
                                {
                                    <a href="@($"{RoutingPath.Teams}/{ta.TeamId}")" target="_blank" style="text-decoration:none">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Style="cursor:pointer">
                                            @ta.TeamName (@ta.AllocatedCapacity)
                                        </MudChip>
                                    </a>
                                }
                                @if (context.TeamAllocations.Count == 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">No team allocated</MudText>
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>

        <div class="pa-4 d-flex justify-end" style="border-top: 1px solid var(--mud-palette-lines-default); flex-shrink: 0;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public FeatureCapacityResult? CapacityResult { get; set; }

    private string[] _techStackLabels = [];
    private List<ChartSeries<double>> _techStackSeries = new();
    private List<TeamStat> _teamStats = new();
    private double _teamMax;

    protected override void OnParametersSet()
    {
        if (CapacityResult is null) return;

        // Technology Stack bar chart data
        var allocations = CapacityResult.TechnologyStackAllocations;
        _techStackLabels = allocations.Select(a => a.TechnologyStackName).ToArray();
        _techStackSeries = new List<ChartSeries<double>>
        {
            new() { Name = "Required", Data = allocations.Select(a => (double)a.Required).ToArray() },
            new() { Name = "Reserved", Data = allocations.Select(a => (double)a.Reserved).ToArray() }
        };

        // Team allocation stats
        var teamMap = new Dictionary<int, TeamStat>();
        foreach (var alloc in allocations)
        {
            foreach (var ta in alloc.TeamAllocations)
            {
                if (!teamMap.TryGetValue(ta.TeamId, out var stat))
                {
                    stat = new TeamStat
                    {
                        TeamId = ta.TeamId,
                        TeamName = ta.TeamName,
                        RemainingCapacity = ta.RemainingCapacity
                    };
                    teamMap[ta.TeamId] = stat;
                }
                stat.AllocatedCapacity += ta.AllocatedCapacity;
                stat.RemainingCapacity = ta.RemainingCapacity;
                stat.TechnologyStacks.Add(alloc.TechnologyStackName);
            }
        }
        _teamStats = teamMap.Values.OrderByDescending(t => t.AllocatedCapacity).ToList();
        _teamMax = _teamStats.Count > 0 ? _teamStats.Max(t => t.AllocatedCapacity + t.RemainingCapacity) : 1;
    }

    private double GetTeamPercent(TeamStat stat)
    {
        var total = stat.AllocatedCapacity + stat.RemainingCapacity;
        return total > 0 ? (double)stat.AllocatedCapacity / total * 100 : 0;
    }

    private void Close() => MudDialog.Close();

    private static Color GetMethodColor(string? method) => method switch
    {
        "AssignedTeam" => Color.Success,
        "MatchingTeam" => Color.Info,
        _ => Color.Default,
    };

    private static string FormatMatchMethod(string? method) => method switch
    {
        "AssignedTeam" => "Assigned Team",
        "MatchingTeam" => "Matching Team",
        _ => "N/A",
    };

    private class TeamStat
    {
        public int TeamId { get; set; }
        public string TeamName { get; set; } = null!;
        public int AllocatedCapacity { get; set; }
        public int RemainingCapacity { get; set; }
        public HashSet<string> TechnologyStacks { get; set; } = new();
    }
}
