@using Estimation.Core.Models
@using Estimation.Core.Services

@inject IFeatureService FeatureService
@inject IConfiguration Configuration

<div class="pa-4" style="min-width: 500px;">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate Color="Color.Primary" />
    }
    else if (_feature is not null)
    {
        <div class="d-flex align-center gap-2 mb-2">
            @if (!string.IsNullOrEmpty(_feature.BusinessOutcome?.JiraId))
            {
                <a href="@(Configuration["JiraTaskUrl"] + _feature.BusinessOutcome.JiraId)" target="_blank" style="text-decoration:none">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Style="cursor:pointer">
                        @_feature.BusinessOutcome.JiraId
                    </MudChip>
                </a>
            }
            @if (!string.IsNullOrEmpty(_feature.BusinessOutcome?.Name))
            {
                <MudText Typo="Typo.body1" Class="fw-bold">@_feature.BusinessOutcome.Name</MudText>
            }
        </div>

        <div class="d-flex align-center gap-2 mb-3">
            @if (!string.IsNullOrEmpty(_feature.JiraId))
            {
                <a href="@(Configuration["JiraTaskUrl"] + _feature.JiraId)" target="_blank" style="text-decoration:none">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined" Style="cursor:pointer">
                        @_feature.JiraId
                    </MudChip>
                </a>
            }
            <MudText Typo="Typo.body1">@_feature.Name</MudText>
        </div>

        @if (!string.IsNullOrWhiteSpace(_feature.Description))
        {
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Description</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">@_feature.Description</MudText>
        }
        else 
        {
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Description</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">Description is not provided</MudText>
        }

        @if (!string.IsNullOrWhiteSpace(_feature.Comments))
        {
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Comments</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">@_feature.Comments</MudText>
        }

        @if (_feature.FeatureTechnologyStacks.Any())
        {
            <MudTable Items="_feature.FeatureTechnologyStacks" Dense Hover Bordered
                      FixedHeader
                      Height="200px">
                <HeaderContent>
                    <MudTh>Technology Stack</MudTh>
                    <MudTh>Estimated Effort</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.TechnologyStack.Name</MudTd>
                    <MudTd>@context.EstimatedEffort</MudTd>
                </RowTemplate>
            </MudTable>
        }

        <div class="d-flex justify-end mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
        </div>
    }
</div>

@code {
    private Feature? _feature;
    private bool _loading = true;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int FeatureId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _feature = await FeatureService.GetByIdAsync(FeatureId);
        _loading = false;
    }

    private void Close() => MudDialog.Close();
}
