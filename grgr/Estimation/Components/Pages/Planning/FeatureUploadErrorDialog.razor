@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Error Details</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Style="white-space: pre-wrap; word-break: break-word;">@ErrorMessage</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string ErrorMessage { get; set; } = "";

    private void Close() => MudDialog.Close();
}
