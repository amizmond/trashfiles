@attribute [Route(RoutingPath.CapitalProjectsNew)]
@attribute [Route(RoutingPath.CapitalProjectsEdit)]

@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject ICapitalProjectService ProjectService
@inject IStrategicObjectiveService ProgramService
@inject ITeamService TeamService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService
@inject IJSRuntime JS
@inject IConfiguration Configuration

<PageTitle>@(_isNew ? "New ART Level" : _model.Name)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo(RoutingPath.CapitalProjects))" />
            <MudText Typo="Typo.h5">@(_isNew ? "New ART Level" : _model.Name)</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_saving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                @* ── Details ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />

                            <MudTextField @bind-Value="_model.JiraKey" Label="Jira Key" Variant="Variant.Outlined" MaxLength="10" Placeholder="e.g. RRWA" Class="mb-3" />

                            <MudTextField @bind-Value="_model.Name" Label="Name *" Variant="Variant.Outlined" For="() => _model.Name" Class="mb-3" />

                            <MudTextField @bind-Value="_model.Description" Label="Description" Variant="Variant.Outlined" Lines="3" Class="mb-4" />

                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                            }
                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving" StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save")
                                </MudButton>

                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto"
                                               StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                                }

                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>

                @* ── Programs ── *@
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="rounded-lg">
                        <MudToolBar Dense Class="gap-2 flex-wrap" Style="min-height:64px">
                            <MudText Typo="Typo.h6" Style="white-space:nowrap">Programs</MudText>
                            <MudSpacer />
                            @if (!_isNew)
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedProgramId"
                                           Label="Select program"
                                           Variant="Variant.Outlined"
                                           Dense
                                           Style="min-width:160px;">
                                    @foreach (var p in _availablePrograms)
                                    {
                                        <MudSelectItem T="int?" Value="p.Id">@p.Name</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="AddProgramAsync"
                                           Disabled="_selectedProgramId is null">
                                    Add
                                </MudButton>
                            }
                        </MudToolBar>
                        @if (_isNew)
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                Save the record first to assign programs.
                            </MudText>
                        }
                        else
                        {
                            <MudDataGrid T="CapitalProjectStrategicObjective" Items="_model.CapitalProjectStrategicObjectives" Hover="true" Dense="true" Striped="true" Bordered="true" Elevation="0">
                                <Columns>
                                    <TemplateColumn Title="Jira ID" Sortable="false" CellStyle="width:130px;">
                                        <CellTemplate>
                                            @if (!string.IsNullOrEmpty(context.Item.StrategicObjective.JiraId))
                                            {
                                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.StrategicObjective.JiraId)" target="_blank" style="text-decoration:none">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                                        @context.Item.StrategicObjective.JiraId
                                                    </MudChip>
                                                </a>
                                            }
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <PropertyColumn Property="x => x.StrategicObjective.Name" Title="Name" Sortable="true" />

                                    <PropertyColumn Property="x => x.StrategicObjective.Description" Title="Description" Sortable="false" />
                                    <PropertyColumn Property="x => x.StrategicObjective.Comments" Title="Comments" Sortable="false" />
                                    <TemplateColumn Title="" CellStyle="width:100px; text-align:right" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => OpenInNewTab($"{RoutingPath.StrategicObjectives}/{context.Item.StrategicObjectiveId}"))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="() => RemoveProgramAsync(context.Item.StrategicObjectiveId)" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No programs assigned yet.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudDataGridPager T="CapitalProjectStrategicObjective" PageSizeOptions="new[] { 5, 10, 25 }" />
                                </PagerContent>
                            </MudDataGrid>
                        }
                    </MudPaper>
                </MudItem>

                @* ── Teams ── *@
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="rounded-lg">
                        <MudToolBar Dense Class="gap-2 flex-wrap" Style="min-height:64px">
                            <MudText Typo="Typo.h6" Style="white-space:nowrap">Teams</MudText>
                            <MudSpacer />
                            @if (!_isNew)
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedTeamId"
                                           Label="Select team"
                                           Variant="Variant.Outlined"
                                           Dense
                                           Style="min-width:140px;">
                                    @foreach (var t in _availableTeams)
                                    {
                                        <MudSelectItem T="int?" Value="t.Id">@t.Name</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="AddTeamAsync"
                                           Disabled="_selectedTeamId is null">
                                    Add
                                </MudButton>
                            }
                        </MudToolBar>
                        @if (_isNew)
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                Save the record first to assign teams.
                            </MudText>
                        }
                        else
                        {
                            <MudDataGrid T="CapitalProjectTeam" Items="_model.CapitalProjectTeams"
                                         Hover="true" Dense="true" Striped="true" Bordered="true" Elevation="0">
                                <Columns>
                                    <PropertyColumn Property="x => x.Team.Name" Title="Name" Sortable="true" />
                                    <PropertyColumn Property="x => x.Team.FullName" Title="Full Name" Sortable="true" />
                                    <PropertyColumn Property="x => x.Team.OptionalTeamTag" Title="Tag" Sortable="true" />
                                    <PropertyColumn Property="x => x.Team.Description" Title="Description" Sortable="false" />
                                    <TemplateColumn Title="" CellStyle="width:100px; text-align:right" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => OpenInNewTab($"{RoutingPath.Teams}/{context.Item.TeamId}"))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="() => RemoveTeamAsync(context.Item.TeamId)" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No teams assigned yet.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudDataGridPager T="CapitalProjectTeam" PageSizeOptions="new[] { 5, 10, 25 }" />
                                </PagerContent>
                            </MudDataGrid>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
    </MudPaper>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private CapitalProject _model = new();
    private List<StrategicObjective> _allPrograms = new();
    private List<Team> _allTeams = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private int? _selectedProgramId;
    private int? _selectedTeamId;
    private bool _isNew => Id is null or 0;

    private IEnumerable<StrategicObjective> _availablePrograms => _allPrograms.Where(p => _model.CapitalProjectStrategicObjectives.All(cpp => cpp.StrategicObjectiveId != p.Id));
    private IEnumerable<Team> _availableTeams => _allTeams.Where(t => _model.CapitalProjectTeams.All(cpt => cpt.TeamId != t.Id));

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var programsTask = ProgramService.GetAllAsync();
        var teamsTask = TeamService.GetAllNamesAsync();
        await Task.WhenAll(programsTask, teamsTask);
        _allPrograms = await programsTask;
        _allTeams = await teamsTask;

        if (!_isNew)
        {
            var existing = await ProjectService.GetByIdAsync(Id!.Value);
            if (existing is null) { Navigation.NavigateTo(RoutingPath.CapitalProjects); return; }
            _model = existing;
        }
        else 
        { 
            _model = new CapitalProject();
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;

        try
        {
            if (_isNew)
            {
                var c = await ProjectService.CreateAsync(_model);
                Navigation.NavigateTo($"{RoutingPath.CapitalProjects}/{c.Id}", true);
            }
            else { _model = await ProjectService.UpdateAsync(_model); Snackbar.Add("Saved.", Severity.Success); }
        }
        catch (Exception ex)
        { 
            _error = ex.Message; 
        }
        finally 
        { 
            _saving = false; 
        }
    }

    private async Task OpenInNewTab(string url)
    {
        await JS.InvokeVoidAsync("open", Navigation.ToAbsoluteUri(url).ToString(), "_blank");
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.Name} ?"))
            {
                await ProjectService.DeleteAsync(_model.Id);
                Navigation.NavigateTo(RoutingPath.CapitalProjects);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    private async Task AddProgramAsync()
    {
        if (_selectedProgramId is null) return;

        await ProjectService.AddProgramAsync(_model.Id, _selectedProgramId.Value);

        var prog = _allPrograms.First(p => p.Id == _selectedProgramId);

        _model.CapitalProjectStrategicObjectives.Add(new CapitalProjectStrategicObjective
        {
            CapitalProjectId = _model.Id,
            StrategicObjectiveId = _selectedProgramId.Value,
            StrategicObjective = prog
        });

        _selectedProgramId = null;
    }


    private async Task RemoveProgramAsync(int programId)
    {
        var name = _model.CapitalProjectStrategicObjectives.FirstOrDefault(cpp => cpp.StrategicObjectiveId == programId)?.StrategicObjective.Name;
        if (!await MessageService.Confirm($"Remove program {name} ?")) return;
        await ProjectService.RemoveProgramAsync(_model.Id, programId);
        _model.CapitalProjectStrategicObjectives = _model.CapitalProjectStrategicObjectives.Where(cpp => cpp.StrategicObjectiveId != programId).ToList();
    }

    private async Task AddTeamAsync()
    {
        if (_selectedTeamId is null) return;

        await ProjectService.AddTeamAsync(_model.Id, _selectedTeamId.Value);
        var team = _allTeams.First(t => t.Id == _selectedTeamId);

        _model.CapitalProjectTeams.Add(new CapitalProjectTeam
        {
            CapitalProjectId = _model.Id,
            TeamId = _selectedTeamId.Value,
            Team = team
        });

        _selectedTeamId = null;
    }

    private async Task RemoveTeamAsync(int teamId)
    {
        var name = _model.CapitalProjectTeams.FirstOrDefault(cpt => cpt.TeamId == teamId)?.Team.Name;
        if (!await MessageService.Confirm($"Remove team {name} ?")) return;
        await ProjectService.RemoveTeamAsync(_model.Id, teamId);
        _model.CapitalProjectTeams = _model.CapitalProjectTeams.Where(cpt => cpt.TeamId != teamId).ToList();
    }
}