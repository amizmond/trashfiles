@attribute [Route(RoutingPath.PortfolioEpicsNew)]
@attribute [Route(RoutingPath.PortfolioEpicsEdit)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject IPortfolioEpicService EpicService
@inject IBusinessOutcomeService OutcomeService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService
@inject IConfiguration Configuration

<PageTitle>@(_isNew ? "New Epic" : _model.Name)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(RoutingPath.PortfolioEpics))" />
            <MudText Typo="Typo.h6">@(_isNew ? "New Portfolio Epic" : _model.Name)</MudText>
        </div>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_saving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                @* ── Details ── *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <div class="d-flex align-center gap-2 mb-3">
                                <MudTextField @bind-Value="_model.JiraId" Label="Jira ID"
                                              Variant="Variant.Outlined" Placeholder="WRBL-622" />
                                @if (!string.IsNullOrWhiteSpace(_model.JiraId))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Primary"
                                                   Href="@(Configuration["JiraTaskUrl"] + _model.JiraId)"
                                                   Target="_blank" />
                                }
                            </div>
                            <MudTextField @bind-Value="_model.Name" Label="Name"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Description" Label="Description"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Comments" Label="Comments"
                                          Variant="Variant.Outlined" Lines="2" Class="mb-4" />
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                            }
                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                           Color="Color.Primary" Disabled="_saving"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save")
                                </MudButton>
                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto"
                                               StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                                }
                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>

                @* ── Business Outcomes ── *@
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="rounded-lg">
                        <MudToolBar Dense Class="gap-2 flex-wrap" Style="min-height:64px">
                            <MudText Typo="Typo.h6" Style="white-space:nowrap">Business Outcomes</MudText>
                            <MudSpacer />
                            @if (!_isNew)
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedOutcomeId"
                                           Label="Select outcome"
                                           Variant="Variant.Outlined"
                                           Dense
                                           Style="min-width:160px;">
                                    @foreach (var o in _availableOutcomes)
                                    {
                                        <MudSelectItem T="int?" Value="o.Id">
                                            @(!string.IsNullOrEmpty(o.JiraId) ? $"[{o.JiraId}] " : "")@o.Name
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="AddOutcomeAsync"
                                           Disabled="_selectedOutcomeId is null">
                                    Add
                                </MudButton>
                            }
                        </MudToolBar>
                        @if (_isNew)
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                Save first to link business outcomes.
                            </MudText>
                        }
                        else
                        {
                            <MudDataGrid T="BusinessOutcome" Items="_model.BusinessOutcomes" Hover="true" Dense="true" Striped="true" Bordered="true" Elevation="0">
                                <Columns>
                                    <TemplateColumn Title="Jira ID" Sortable="true" SortBy="@(x => x.JiraId ?? string.Empty)" CellStyle="width:150px;">
                                        <CellTemplate>
                                            @if (!string.IsNullOrEmpty(context.Item.JiraId))
                                            {
                                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.JiraId)" target="_blank" style="text-decoration:none">
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                                        @context.Item.JiraId
                                                    </MudChip>
                                                </a>
                                            }
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <PropertyColumn Property="x => x.Name" Title="Name" Sortable="true" />

                                    <PropertyColumn Property="x => x.Description" Title="Description" Sortable="false" />
                                    <PropertyColumn Property="x => x.Comments" Title="Comments" Sortable="false" />
                                    <TemplateColumn Title="" CellStyle="width:100px; text-align:right" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small" Color="Color.Primary"
                                                           Href="@($"{RoutingPath.BusinessOutcomes}/{context.Item.Id}")"
                                                           Target="_blank" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="() => RemoveOutcomeAsync(context.Item.Id)" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No business outcomes linked yet.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudDataGridPager T="BusinessOutcome" PageSizeOptions="new[] { 5, 10, 25 }" />
                                </PagerContent>
                            </MudDataGrid>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
    </MudPaper>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private PortfolioEpic _model = new();
    private List<BusinessOutcome> _allOutcomes = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool _isNew => Id is null or 0;
    private int? _selectedOutcomeId;

    private IEnumerable<BusinessOutcome> _availableOutcomes =>
        _allOutcomes.Where(o => o.PortfolioEpicId is null && _model.BusinessOutcomes.All(bo => bo.Id != o.Id));

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _allOutcomes = await OutcomeService.GetAllAsync();
        if (!_isNew)
        {
            var e = await EpicService.GetByIdAsync(Id!.Value);
            if (e is null) { Nav.NavigateTo(RoutingPath.PortfolioEpics); return; }
            _model = e;
        }
        else _model = new PortfolioEpic();
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;
        try
        {
            if (_isNew) { var c = await EpicService.CreateAsync(_model); Nav.NavigateTo($"{RoutingPath.PortfolioEpics}/{c.Id}", true); }
            else { _model = await EpicService.UpdateAsync(_model); Snackbar.Add("Saved.", Severity.Success); }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.Name} ?"))
            {
                await EpicService.DeleteAsync(_model.Id);
                Nav.NavigateTo(RoutingPath.PortfolioEpics);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    private async Task AddOutcomeAsync()
    {
        if (_selectedOutcomeId is null) return;
        var outcome = _allOutcomes.First(o => o.Id == _selectedOutcomeId);
        outcome.PortfolioEpicId = _model.Id;
        await OutcomeService.UpdateAsync(outcome);
        _model.BusinessOutcomes.Add(outcome);
        _selectedOutcomeId = null;
    }

    private async Task RemoveOutcomeAsync(int outcomeId)
    {
        var name = _model.BusinessOutcomes.FirstOrDefault(bo => bo.Id == outcomeId)?.Name;
        if (!await MessageService.Confirm($"Remove outcome {name} ?")) return;
        var outcome = _allOutcomes.First(o => o.Id == outcomeId);
        outcome.PortfolioEpicId = null;
        await OutcomeService.UpdateAsync(outcome);
        _model.BusinessOutcomes = _model.BusinessOutcomes.Where(bo => bo.Id != outcomeId).ToList();
    }
}