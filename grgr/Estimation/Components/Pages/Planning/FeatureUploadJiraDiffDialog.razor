@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Properties that differ between Jira and Excel data are shown below.
        </MudText>

        <MudTable Items="Diffs" Dense="true" Hover="true" Elevation="0" Striped="true">
            <HeaderContent>
                <MudTh>Property</MudTh>
                <MudTh Style="background-color: #E3F2FD;">Jira Value</MudTh>
                <MudTh Style="background-color: #FFF9C4;">@RightColumnTitle</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudText Typo="Typo.body2" Class="font-weight-bold">@context.PropertyName</MudText></MudTd>
                <MudTd Style="background-color: #E3F2FD; max-width:300px; overflow:hidden; text-overflow:ellipsis;">
                    @(context.JiraValue ?? "(empty)")
                </MudTd>
                <MudTd Style="background-color: #FFF9C4; max-width:300px; overflow:hidden; text-overflow:ellipsis;">
                    @(context.ExcelValue ?? "(empty)")
                </MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = "Jira vs Excel Comparison";

    [Parameter]
    public string RightColumnTitle { get; set; } = "Excel Value";

    [Parameter]
    public List<DiffItem> Diffs { get; set; } = new();

    private void Close() => MudDialog.Close();

    public record DiffItem(string PropertyName, string? JiraValue, string? ExcelValue);
}
