@attribute [Route(RoutingPath.StrategicObjectivesNew)]
@attribute [Route(RoutingPath.StrategicObjectivesEdit)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject IStrategicObjectiveService ProgramService
@inject IPortfolioEpicService EpicService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IModalDialogService MessageService
@inject IConfiguration Configuration

<PageTitle>@(_isNew ? "New Strategic Objective" : _model.Name)</PageTitle>

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <div class="d-flex align-center gap-2 mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(RoutingPath.StrategicObjectives))" />
            <MudText Typo="Typo.h6">@(_isNew ? "New Strategic Objective" : _model.Name)</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }
        else
        {
            @if (_saving)
            {
                <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-2" />
            }
            <div style="@(_saving ? "pointer-events:none;opacity:0.6" : "")">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg">
                        <MudText Typo="Typo.h6" Class="mb-4">Details</MudText>
                        <EditForm Model="_model" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <div class="d-flex align-center gap-2 mb-3">
                                <MudTextField @bind-Value="_model.JiraId" Label="Jira ID"
                                              Variant="Variant.Outlined" Placeholder="e.g. WRBL-46" />
                                @if (!string.IsNullOrWhiteSpace(_model.JiraId))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                   Color="Color.Primary"
                                                   Href="@(Configuration["JiraTaskUrl"] + _model.JiraId)"
                                                   Target="_blank" />
                                }
                            </div>
                            <MudTextField @bind-Value="_model.Name" Label="Name *"
                                          Variant="Variant.Outlined" For="() => _model.Name" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Description" Label="Description"
                                          Variant="Variant.Outlined" Lines="3" Class="mb-3" />
                            <MudTextField @bind-Value="_model.Comments" Label="Comments"
                                          Variant="Variant.Outlined" Lines="2" Class="mb-4" />
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                            }
                            <div class="d-flex gap-2">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                           Color="Color.Primary" Disabled="_saving"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    @(_isNew ? "Create" : "Save")
                                </MudButton>
                                @if (!_isNew)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="ConfirmDeleteAsync" Class="ml-auto"
                                               StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
                                }
                            </div>
                        </EditForm>
                    </MudPaper>
                </MudItem>
                @* ── Portfolio Epics ── *@
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="rounded-lg">
                        <MudToolBar Dense Class="gap-2 flex-wrap" Style="min-height:64px">
                            <MudText Typo="Typo.h6" Style="white-space:nowrap">Portfolio Epics</MudText>
                            <MudSpacer />
                            @if (!_isNew)
                            {
                                <MudSelect T="int?"
                                           @bind-Value="_selectedEpicId"
                                           Label="Select epic"
                                           Variant="Variant.Outlined"
                                           Dense
                                           Style="min-width:160px;">
                                    @foreach (var e in _availableEpics)
                                    {
                                        <MudSelectItem T="int?" Value="e.Id">
                                            @(!string.IsNullOrEmpty(e.JiraId) ? $"[{e.JiraId}] " : "")@e.Name
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="AddEpicAsync"
                                           Disabled="_selectedEpicId is null">
                                    Add
                                </MudButton>
                            }
                        </MudToolBar>
                        @if (_isNew)
                        {
                            <MudText Class="pa-4 mud-text-secondary" Typo="Typo.body2">
                                Save first to link epics.
                            </MudText>
                        }
                        else
                        {
                            <MudDataGrid T="StrategicObjectivePortfolioEpic" Items="_model.StrategicObjectivePortfolioEpics"
                                         Hover="true" Dense="true" Striped="true" Bordered="true" Elevation="0">
                                <Columns>
                                    <TemplateColumn Title="Jira ID" Sortable="true" SortBy="x => x.PortfolioEpic.JiraId" CellStyle="width:150px;">
                                        <CellTemplate>
                                            @if (!string.IsNullOrEmpty(context.Item.PortfolioEpic.JiraId))
                                            {
                                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.PortfolioEpic.JiraId)" target="_blank" style="text-decoration:none">
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                                        @context.Item.PortfolioEpic.JiraId
                                                    </MudChip>
                                                </a>
                                            }
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <PropertyColumn Property="x => x.PortfolioEpic.Name" Title="Name" Sortable="true" />

                                    <PropertyColumn Property="x => x.PortfolioEpic.Description" Title="Description" Sortable="false" />
                                    <PropertyColumn Property="x => x.PortfolioEpic.Comments" Title="Comments" Sortable="false" />
                                    <TemplateColumn Title="" CellStyle="width:100px; text-align:right" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small" Color="Color.Primary"
                                                           Href="@($"{RoutingPath.PortfolioEpics}/{context.Item.PortfolioEpicId}")"
                                                           Target="_blank" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small" Color="Color.Error"
                                                           OnClick="() => RemoveEpicAsync(context.Item.PortfolioEpicId)" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No epics linked yet.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudDataGridPager T="StrategicObjectivePortfolioEpic" PageSizeOptions="new[] { 5, 10, 25 }" />
                                </PagerContent>
                            </MudDataGrid>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            </div>
        }
     </MudPaper>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private StrategicObjective _model = new();
    private List<PortfolioEpic> _allEpics = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private bool _isNew => Id is null or 0;
    private int? _selectedEpicId;

    private IEnumerable<PortfolioEpic> _availableEpics =>
        _allEpics.Where(e => _model.StrategicObjectivePortfolioEpics.All(ppe => ppe.PortfolioEpicId != e.Id));

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _allEpics = await EpicService.GetAllAsync();
        if (!_isNew)
        {
            var e = await ProgramService.GetByIdAsync(Id!.Value);
            if (e is null) { Nav.NavigateTo(RoutingPath.StrategicObjectives); return; }
            _model = e;
        }
        else _model = new StrategicObjective();
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;
        try
        {
            if (_isNew) { var c = await ProgramService.CreateAsync(_model); Nav.NavigateTo($"{RoutingPath.StrategicObjectives}/{c.Id}", true); }
            else { _model = await ProgramService.UpdateAsync(_model); Snackbar.Add("Saved.", Severity.Success); }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            if (await MessageService.Confirm($"Delete {_model.Name} ?"))
            {
                await ProgramService.DeleteAsync(_model.Id);
                Nav.NavigateTo(RoutingPath.StrategicObjectives);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    private async Task AddEpicAsync()
    {
        if (_selectedEpicId is null) return;
        await ProgramService.AddEpicAsync(_model.Id, _selectedEpicId.Value);
        var epic = _allEpics.First(e => e.Id == _selectedEpicId);
        _model.StrategicObjectivePortfolioEpics.Add(new StrategicObjectivePortfolioEpic
        {
            StrategicObjectiveId = _model.Id,
            PortfolioEpicId = _selectedEpicId.Value,
            PortfolioEpic = epic
        });
        _selectedEpicId = null;
    }

    private async Task RemoveEpicAsync(int epicId)
    {
        var name = _model.StrategicObjectivePortfolioEpics.FirstOrDefault(ppe => ppe.PortfolioEpicId == epicId)?.PortfolioEpic.Name;
        if (!await MessageService.Confirm($"Remove epic {name} ?")) return;
        await ProgramService.RemoveEpicAsync(_model.Id, epicId);
        _model.StrategicObjectivePortfolioEpics =
            _model.StrategicObjectivePortfolioEpics
                  .Where(ppe => ppe.PortfolioEpicId != epicId).ToList();
    }
}
