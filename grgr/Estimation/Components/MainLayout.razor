@inherits LayoutComponentBase
@using Estimation.Components.ModalDialog
@using Estimation.Core.JiraLogic
@inject IWindowsAuthService WindowsAuthService
@inject IJiraAuthService JiraAuth
@inject IDialogService DialogService

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_authChecked)
{
    <MudLayout>
        <MudMainContent Class="d-flex align-center justify-center" Style="min-height:100vh;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudMainContent>
    </MudLayout>
}
else if (!_isAuthorized)
{
    <MudLayout>
        <MudMainContent Class="d-flex align-center justify-center" Style="min-height:100vh;">
            <MudCard Style="max-width:500px; width:100%;">
                <MudCardHeader>
                    <MudText Typo="Typo.h5" Color="Color.Error">Access Denied</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">
                        You are not authorized to access this application.
                    </MudAlert>
                    <MudText Typo="Typo.body1">
                        User: <strong>@_userName</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
                        Please contact your administrator to request access.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudMainContent>
    </MudLayout>
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
            <MudSpacer />
            @if (JiraAuth.IsConfigured)
            {
                <MudTooltip Text="@(_jiraConnected ? "Jira: Connected" : "Jira: Not connected")">
                    <MudIconButton Icon="@(_jiraConnected ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudOff)"
                                   Color="@(_jiraConnected ? Color.Success : Color.Default)"
                                   OnClick="OpenJiraDialogAsync" />
                </MudTooltip>
            }
            <MudText Typo="Typo.body2" Class="mr-4">@_userName</MudText>
            <div>
                <MudSwitch @bind-value="@_isDarkMode" Color="Color.Primary" Class="ma-4" T="bool" Label="Light/Dark Mode" />
            </div>
        </MudAppBar>
        <MudDrawer @bind-Open="@_open" Elevation="1">
            <MudNavMenu Class="mud-width-full">
                <MudText Typo="Typo.h6" Class="px-4">Estimation</MudText>
                <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">Version: DEV</MudText>
                <MudDivider Class="my-2" />
                <MudNavLink Href="@(RoutingPath.Base)" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                <MudNavGroup Title="Planning Increment" Icon="@Icons.Material.Filled.DataArray" Expanded="true">
                    <MudNavLink Href="@RoutingPath.Pis" Icon="@Icons.Material.Filled.DateRange">PI</MudNavLink>
                    <MudNavLink Href="@RoutingPath.PiPrioritization" Icon="@Icons.Material.Filled.LowPriority">Prioritization</MudNavLink>
                </MudNavGroup>                   
                <MudNavGroup Title="Planning" Icon="@Icons.Material.Filled.AccountTree" Expanded="true">
                    <MudNavLink Href="@RoutingPath.CapitalProjects" Icon="@Icons.Material.Filled.Business">Solution Train Level</MudNavLink>
                    <MudNavLink Href="@RoutingPath.StrategicObjectives" Icon="@Icons.Material.Filled.Schema">Strategic Objectives</MudNavLink>
                    <MudNavLink Href="@RoutingPath.PortfolioEpics" Icon="@Icons.Material.Filled.Layers">Portfolio Epics</MudNavLink>
                    <MudNavLink Href="@RoutingPath.BusinessOutcomes" Icon="@Icons.Material.Filled.TrackChanges">Business Outcomes</MudNavLink>
                    <MudNavLink Href="@RoutingPath.Features" Icon="@Icons.Material.Filled.Extension">Features</MudNavLink>
                    @* <MudNavLink Href="@RoutingPath.CapitalSolutionTrainPriorities" Icon="@Icons.Material.Filled.PriorityHigh">Capital Solution Train Priorities</MudNavLink> *@
                </MudNavGroup>
                <MudNavGroup Title="Resources" Icon="@Icons.Material.Filled.People" Expanded="true">
                    <MudNavLink Href="@RoutingPath.Teams" Icon="@Icons.Material.Filled.Group">Teams</MudNavLink>
                    <MudNavLink Href="@RoutingPath.HumanResources" Icon="@Icons.Material.Filled.Person">Resources</MudNavLink>
                    <MudNavLink Href="@RoutingPath.Skills" Icon="@Icons.Material.Filled.Psychology">Skills</MudNavLink>
                    <MudNavLink Href="@RoutingPath.TechnologyStacks" Icon="@Icons.Material.Filled.Layers">Technology Stacks</MudNavLink>
                </MudNavGroup>
                <MudNavLink Href="@RoutingPath.Upload" Icon="@Icons.Material.Filled.UploadFile">Upload</MudNavLink>
                <MudNavLink Href="@RoutingPath.StaticSettings" Icon="@Icons.Material.Filled.Settings">Static Data</MudNavLink>
            </MudNavMenu>
        </MudDrawer>
        <MudMainContent>
            @Body
        </MudMainContent>
    </MudLayout>
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _isDarkMode;
    bool _open = true;
    private bool _authChecked;
    private bool _isAuthorized;
    private string? _userName;
    private bool _jiraConnected;

    protected override async Task OnInitializedAsync()
    {
        _userName = await WindowsAuthService.GetUserName();
        _isAuthorized = await WindowsAuthService.IsUserAuthorized();
        _authChecked = true;

        if (_isAuthorized && _userName is not null && JiraAuth.IsConfigured)
            _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
    }

    private async Task OpenJiraDialogAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await DialogService.ShowAsync<JiraLoginDialog>("Jira Authentication", options);
        var result = await dialogRef.Result;

        if (result?.Data is bool connected)
            _jiraConnected = connected;
        else if (_userName is not null)
            _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
    }

    void ToggleDrawer()
    {
        _open = !_open;
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Indigo.Lighten1,
            Secondary = Colors.Pink.Accent2,
            AppbarBackground = Colors.Indigo.Lighten5,
            AppbarText = Colors.Shades.Black,
            DrawerBackground = Colors.Indigo.Lighten5,
            Background = Colors.Gray.Lighten4,
        },
    };
}
