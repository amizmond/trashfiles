@attribute [Route(RoutingPath.Features)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Serilog

@inject IFeatureService FeatureService
@inject NavigationManager Nav
@inject IModalDialogService MessageService
@inject ISnackbar Snackbar
@inject IConfiguration Configuration

@implements IDisposable

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6">Features</MudText>

        <MudToolBar>
            <MudSpacer />
            <div style="position:relative; margin-right: 10px;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ViewColumn"
                           Disabled="_loading"
                           OnClick="() => _columnsPopoverOpen = !_columnsPopoverOpen">
                    Columns
                </MudButton>
                <MudPopover Open="_columnsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:280px">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Toggle Columns</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _columnsPopoverOpen = false" />
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <MudSwitch T="bool" @bind-Value="_showJiraId" Label="Jira ID" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showName" Label="Name" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showPi" Label="PI" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showBoJiraId" Label="Business Outcome" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showEpicJiraId" Label="Portfolio Epic" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showProgramJiraId" Label="Project Program" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showCapitalProject" Label="Capital Project" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showTeams" Label="Teams" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showActions" Label="Actions" Color="Color.Primary" Dense />
                    </div>
                </MudPopover>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Disabled="_loading"
                       Style="margin-right: 10px"
                       OnClick="() => _drawerOpen = !_drawerOpen">
                Filter
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Style="margin-right: 10px"
                       OnClick="@(() => Nav.NavigateTo(RoutingPath.FeaturesNew))">
                       New
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.UploadFile"
                       Style="margin-right: 10px"
                       Disabled="_loading"
                       OnClick="@(() => Nav.NavigateTo(RoutingPath.FeaturesUpload))">
                       Upload
            </MudButton>
        </MudToolBar>

        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2"
                    Variant="DrawerVariant.Temporary" Width="400px"
                    Style="background: var(--mud-palette-surface)">
            <MudDrawerHeader>
                <div class="d-flex align-center justify-space-between" style="width:100%">
                    <MudText Typo="Typo.h6">Filters</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _drawerOpen = false" />
                </div>
            </MudDrawerHeader>
            <div class="d-flex flex-column gap-3 pa-4">
                <MudTextField @bind-Value="FilterSearch" Label="Search" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <MudSelect T="string" Label="PI" MultiSelection
                           @bind-SelectedValues="FilterPiNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var pi in _availablePis)
                    {
                        <MudSelectItem T="string" Value="@pi">@pi</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Business Outcome" MultiSelection
                           @bind-SelectedValues="FilterBoNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var bo in _availableBos)
                    {
                        <MudSelectItem T="string" Value="@bo.JiraId">
                            <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                <b>@bo.JiraId</b> — @bo.Name
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Portfolio Epic" MultiSelection
                           @bind-SelectedValues="FilterEpicNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var epic in _availableEpics)
                    {
                        <MudSelectItem T="string" Value="@epic.JiraId">
                            <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                <b>@epic.JiraId</b> — @epic.Name
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Project Program" MultiSelection
                           @bind-SelectedValues="FilterProgramNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var prog in _availablePrograms)
                    {
                        <MudSelectItem T="string" Value="@prog">@prog</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Capital Project" MultiSelection
                           @bind-SelectedValues="FilterCapitalProjectNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cp in _availableCapitalProjects)
                    {
                        <MudSelectItem T="string" Value="@cp">@cp</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ClearAll"
                           FullWidth OnClick="ClearFilters" Class="mt-2">
                    Clear Filters
                </MudButton>
            </div>
        </MudDrawer>

        <MudDivider />

        <MudDataGrid T="FeatureRow" Items="@_filteredRows"
                     Hover="true" Striped="true" Dense="true" Elevation="0"
                     Loading="_loading" LoadingProgressColor="Color.Primary">
            <Columns>
                <TemplateColumn Title="Jira ID" Sortable="false" CellStyle="width:150px;" Hidden="!_showJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.JiraId))
                        {
                            <a href="@(Configuration["JiraTaskUrl"] + context.Item.JiraId)" target="_blank" style="text-decoration:none">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                    @context.Item.JiraId
                                </MudChip>
                            </a>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.Name" Title="Name" Sortable="true" Hidden="!_showName">
                    <CellTemplate>
                        <MudText Class="font-weight-bold">@context.Item.Name</MudText>
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn Title="PI" Sortable="false" Hidden="!_showPi" CellStyle="width:150px;">
                    <CellTemplate>
                        @if (context.Item.PiName is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.Pis}/{context.Item.PiId}"))">@context.Item.PiName</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Business Outcome" Sortable="false" CellStyle="width:150px;" Hidden="!_showBoJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.BoJiraId))
                        {
                            <MudTooltip Text="@context.Item.BoName">
                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.BoJiraId)" target="_blank" style="text-decoration:none">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer">
                                        @context.Item.BoJiraId
                                    </MudChip>
                                </a>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Portfolio Epic" Sortable="false" CellStyle="width:150px;" Hidden="!_showEpicJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.EpicJiraId))
                        {
                            <MudTooltip Text="@context.Item.EpicName">
                                <a href="@(Configuration["JiraTaskUrl"] + context.Item.EpicJiraId)" target="_blank" style="text-decoration:none">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer">
                                        @context.Item.EpicJiraId
                                    </MudChip>
                                </a>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Project Program" Sortable="false" CellStyle="width:150px;" Hidden="!_showProgramJiraId">
                    <CellTemplate>
                        @if (context.Item.ProgramJiraIds.Count > 0)
                        {
                            @foreach (var prog in context.Item.ProgramJiraIds)
                            {
                                <MudTooltip Text="@prog.Name">
                                    <a href="@(Configuration["JiraTaskUrl"] + prog.JiraId)" target="_blank" style="text-decoration:none">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer">
                                            @prog.JiraId
                                        </MudChip>
                                    </a>
                                </MudTooltip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.CapitalProjectName" Title="Capital Project" Sortable="true" Hidden="!_showCapitalProject" />
                <TemplateColumn Title="Teams" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showTeams">
                    <CellTemplate>
                        @foreach (var t in context.Item.Teams.Take(3))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.Teams}/{t.Id}"))">@t.Name</MudChip>
                        }
                        @if (context.Item.Teams.Count > 3)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                +@(context.Item.Teams.Count - 3)
                            </MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="text-align:right; width:150px;" Sortable="false" Filterable="false" Hidden="!_showActions">
                    <CellTemplate>
                        <MudFab Class="m-2" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" Href="@($"{RoutingPath.Features}/{context.Item.Id}")" Target="_blank" />
                        <MudFab Class="m-2" StartIcon="@Icons.Material.Filled.DeleteForever" IconColor="Color.Secondary" Size="Size.Small" OnClick="() => ConfirmDeleteAsync(context.Item)" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent><MudText Class="pa-6 mud-text-secondary">No features found.</MudText></NoRecordsContent>
            <PagerContent><MudDataGridPager T="FeatureRow" PageSizeOptions="new[] { 10, 25, 50, 100 }" /></PagerContent>
        </MudDataGrid>
    </MudPaper>
</div>

@code {
    private List<FeatureRow> _rows = new();
    private List<FeatureRow> _filteredRows = new();
    private bool _loading = true;
    private bool _drawerOpen;
    private bool _columnsPopoverOpen;

    // --- Column visibility (true = visible) ---
    private bool _showJiraId = true;
    private bool _showName = true;
    private bool _showPi = true;
    private bool _showBoJiraId = true;
    private bool _showEpicJiraId = true;
    private bool _showProgramJiraId = true;
    private bool _showCapitalProject;
    private bool _showTeams = true;
    private bool _showActions = true;

    // --- Available filter values ---
    private List<string> _availablePis = new();
    private List<(string JiraId, string? Name)> _availableBos = new();
    private List<(string JiraId, string? Name)> _availableEpics = new();
    private List<string> _availablePrograms = new();
    private List<string> _availableCapitalProjects = new();

    // --- Filter properties with debounced recomputation ---

    private Timer? _filterDebounceTimer;
    private const int FilterDebounceMs = 200;

    private void ScheduleRecompute()
    {
        _filterDebounceTimer?.Dispose();
        _filterDebounceTimer = new Timer(_ =>
            InvokeAsync(() => { RecomputeFilteredRows(); StateHasChanged(); }),
            null, FilterDebounceMs, Timeout.Infinite);
    }

    private string? _filterSearchBacking;
    private string? FilterSearch
    {
        get => _filterSearchBacking;
        set { _filterSearchBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterPiNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterPiNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterPiNames
    {
        get => _filterPiNamesBacking;
        set { _filterPiNamesBacking = value; _filterPiNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterBoNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterBoNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterBoNames
    {
        get => _filterBoNamesBacking;
        set { _filterBoNamesBacking = value; _filterBoNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterEpicNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterEpicNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterEpicNames
    {
        get => _filterEpicNamesBacking;
        set { _filterEpicNamesBacking = value; _filterEpicNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterProgramNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterProgramNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterProgramNames
    {
        get => _filterProgramNamesBacking;
        set { _filterProgramNamesBacking = value; _filterProgramNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterCapitalProjectNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterCapitalProjectNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterCapitalProjectNames
    {
        get => _filterCapitalProjectNamesBacking;
        set { _filterCapitalProjectNamesBacking = value; _filterCapitalProjectNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private void ClearFilters()
    {
        _filterSearchBacking = null;
        _filterPiNamesBacking = Array.Empty<string>();
        _filterPiNamesSet.Clear();
        _filterBoNamesBacking = Array.Empty<string>();
        _filterBoNamesSet.Clear();
        _filterEpicNamesBacking = Array.Empty<string>();
        _filterEpicNamesSet.Clear();
        _filterProgramNamesBacking = Array.Empty<string>();
        _filterProgramNamesSet.Clear();
        _filterCapitalProjectNamesBacking = Array.Empty<string>();
        _filterCapitalProjectNamesSet.Clear();
        RecomputeFilteredRows();
    }

    // --- Filter logic ---

    private void RecomputeFilteredRows()
    {
        _filteredRows = _rows.Where(MatchesFilter).ToList();
    }

    private bool MatchesFilter(FeatureRow r)
    {
        if (!string.IsNullOrWhiteSpace(_filterSearchBacking))
        {
            var s = _filterSearchBacking.Trim();
            if (!((r.Name?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.JiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.PiName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.BoName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.BoJiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.EpicName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)))
                return false;
        }

        if (_filterPiNamesSet.Count > 0
            && (r.PiName is null || !_filterPiNamesSet.Contains(r.PiName)))
            return false;

        if (_filterBoNamesSet.Count > 0
            && (r.BoJiraId is null || !_filterBoNamesSet.Contains(r.BoJiraId)))
            return false;

        if (_filterEpicNamesSet.Count > 0
            && (r.EpicJiraId is null || !_filterEpicNamesSet.Contains(r.EpicJiraId)))
            return false;

        if (_filterProgramNamesSet.Count > 0
            && !r.ProgramJiraIds.Any(p => _filterProgramNamesSet.Contains(p.Name ?? "")))
            return false;

        if (_filterCapitalProjectNamesSet.Count > 0
            && !r.CapitalProjects.Any(cp => _filterCapitalProjectNamesSet.Contains(cp)))
            return false;

        return true;
    }

    // --- Lifecycle ---

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await FeatureService.GetAllWithHierarchyAsync();
            _rows = items.Select(f =>
            {
                var bo = f.BusinessOutcome;
                var epic = bo?.PortfolioEpic;
                var programs = epic?.ProjectProgramPortfolioEpics
                    .Select(ppe => ppe.ProjectProgram).ToList() ?? new();
                var capitalProjects = programs
                    .SelectMany(pp => pp.CapitalProjectPrograms.Select(cpp => cpp.CapitalProject.Name))
                    .Where(n => n is not null).Distinct().ToList();

                return new FeatureRow(
                    Id: f.Id,
                    JiraId: f.JiraId,
                    Name: f.Name,
                    PiId: f.PiId,
                    PiName: f.Pi?.Name,
                    BoJiraId: bo?.JiraId,
                    BoName: bo?.Name,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Name,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Name))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjects: capitalProjects,
                    CapitalProjectName: capitalProjects.Count > 0 ? string.Join(", ", capitalProjects) : null,
                    Teams: f.FeatureTeams.Select(ft => new TeamRef(ft.TeamId, ft.Team.Name)).ToList()
                );
            }).ToList();

            _availablePis = _rows
                .Where(r => r.PiName is not null)
                .Select(r => r.PiName!).Distinct().OrderBy(n => n).ToList();
            _availableBos = _rows
                .Where(r => !string.IsNullOrEmpty(r.BoJiraId))
                .Select(r => (r.BoJiraId!, r.BoName))
                .DistinctBy(b => b.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(b => b.Item1).ToList();
            _availableEpics = _rows
                .Where(r => !string.IsNullOrEmpty(r.EpicJiraId))
                .Select(r => (r.EpicJiraId!, r.EpicName))
                .DistinctBy(e => e.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(e => e.Item1).ToList();
            _availablePrograms = _rows
                .SelectMany(r => r.ProgramJiraIds.Select(p => p.Name ?? ""))
                .Where(n => !string.IsNullOrEmpty(n))
                .Distinct().OrderBy(n => n).ToList();
            _availableCapitalProjects = _rows
                .SelectMany(r => r.CapitalProjects)
                .Distinct().OrderBy(n => n).ToList();

            RecomputeFilteredRows();
        }
        finally { _loading = false; }
    }

    private async Task ConfirmDeleteAsync(FeatureRow row)
    {
        try
        {
            if (await MessageService.Confirm($"Delete {row.Name} ?"))
            {
                await FeatureService.DeleteAsync(row.Id);
                _rows.RemoveAll(r => r.Id == row.Id);
                RecomputeFilteredRows();
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    public void Dispose()
    {
        _filterDebounceTimer?.Dispose();
    }

    private record JiraRef(string JiraId, string? Name);
    private record TeamRef(int Id, string Name);

    private record FeatureRow(
        int Id,
        string? JiraId,
        string? Name,
        int? PiId,
        string? PiName,
        string? BoJiraId,
        string? BoName,
        string? EpicJiraId,
        string? EpicName,
        List<JiraRef> ProgramJiraIds,
        List<string> CapitalProjects,
        string? CapitalProjectName,
        List<TeamRef> Teams
    );
}
