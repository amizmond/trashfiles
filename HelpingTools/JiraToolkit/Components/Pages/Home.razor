@page "/"
@inject JiraSessionService Session
@inject JiraService JiraService
@inject ISnackbar Snackbar
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Issue Explorer</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Issue Explorer</MudText>

@if (!Session.HasCredentials)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Please connect to Jira using the credentials bar above.</MudAlert>
}

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_issueKey" Label="Issue Key" Placeholder="PROJ-123"
                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.ConfirmationNumber" />
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadIssue"
                       Disabled="@(_loading || !Session.HasCredentials)" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Download">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Loading...</span>
                }
                else
                {
                    <span>Get Issue</span>
                }
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="DownloadRawJson"
                       Disabled="@(_downloading || !Session.HasCredentials || string.IsNullOrWhiteSpace(_issueKey))"
                       FullWidth="true" StartIcon="@Icons.Material.Filled.FileDownload">
                @if (_downloading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Downloading...</span>
                }
                else
                {
                    <span>Download JSON</span>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_fields.Count > 0)
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_searchText" Label="Search" Placeholder="Search in fields..."
                              Variant="Variant.Outlined" Immediate="true" DebounceInterval="300"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="8" Class="d-flex align-center gap-4">
                <MudSwitch @bind-Value="_showEmptyFields" Color="Color.Primary" Label="Show Empty Fields" />
                <MudSwitch @bind-Value="_showCustomFields" Color="Color.Secondary" Label="Show Custom Fields" />
                <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="ml-auto">
                    Showing @FilteredFields.Count() of @_fields.Count fields
                </MudText>
            </MudItem>
        </MudGrid>

        <MudDataGrid Items="@FilteredFields" Dense="true" Striped="true" Hover="true" Bordered="true"
                     FixedHeader="true" Height="calc(100vh - 340px)">
            <Columns>
                <PropertyColumn Property="x => x.Field" Title="Field" />
                <PropertyColumn Property="x => x.FieldId" Title="Field Id" />
                <TemplateColumn Title="Value">
                    <CellTemplate>
                        <MudText Style="white-space: pre-wrap; word-break: break-all; max-width: 600px;">
                            @TruncateValue(context.Item.Value)
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private string _issueKey = string.Empty;
    private string _searchText = string.Empty;
    private bool _showEmptyFields = true;
    private bool _showCustomFields = true;
    private bool _loading;
    private bool _downloading;
    private List<JiraFieldRow> _fields = new();

    private IEnumerable<JiraFieldRow> FilteredFields => _fields.Where(f =>
    {
        if (!_showEmptyFields && f.IsEmpty) return false;
        if (!_showCustomFields && f.IsCustomField) return false;
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.Trim();
            return f.Field.Contains(search, StringComparison.OrdinalIgnoreCase)
                || f.FieldId.Contains(search, StringComparison.OrdinalIgnoreCase)
                || f.Value.Contains(search, StringComparison.OrdinalIgnoreCase);
        }
        return true;
    });

    private async Task LoadIssue()
    {
        if (string.IsNullOrWhiteSpace(_issueKey))
        {
            Snackbar.Add("Please enter an issue key", Severity.Warning);
            return;
        }

        _loading = true;
        _fields.Clear();

        try
        {
            _fields = await JiraService.GetIssueFieldsAsync(Session.GetCredentials(), _issueKey.Trim());
            Snackbar.Add($"Loaded {_fields.Count} fields for {_issueKey}", Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "Failed to load issue {IssueKey}", _issueKey);
            Snackbar.Add($"HTTP Error: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load issue {IssueKey}", _issueKey);
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DownloadRawJson()
    {
        if (string.IsNullOrWhiteSpace(_issueKey)) return;

        _downloading = true;
        try
        {
            var json = await JiraService.GetIssueRawJsonAsync(Session.GetCredentials(), _issueKey.Trim());
            var fileName = $"{_issueKey.Trim()}.txt";

            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    var blob = new Blob([{System.Text.Json.JsonSerializer.Serialize(json)}], {{ type: 'text/plain' }});
                    var url = URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = url;
                    a.download = {System.Text.Json.JsonSerializer.Serialize(fileName)};
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                }})();
            ");

            Snackbar.Add($"Downloaded raw JSON for {_issueKey}", Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "Failed to download raw JSON for {IssueKey}", _issueKey);
            Snackbar.Add($"HTTP Error: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download raw JSON for {IssueKey}", _issueKey);
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloading = false;
        }
    }

    private static string TruncateValue(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length > 500 ? value[..500] + "..." : value;
    }
}
