@page "/lookups"
@using JiraToolkit.Models
@using JiraToolkit.Services
@inject JiraService JiraService
@inject LocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject ILogger<Lookups> Logger
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Jira Lookups</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Jira Lookups</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_jiraUrl" Label="Jira URL" Placeholder="https://jira.example.com"
                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Link" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock" />
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAll"
                       Disabled="@_loading" FullWidth="true" StartIcon="@Icons.Material.Filled.Refresh">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Loading...</span>
                }
                else
                {
                    <span>Load All</span>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="pa-4">
    <MudTabPanel Text="Projects" Icon="@Icons.Material.Filled.Folder" BadgeData="@_projects.Count"
                 BadgeColor="Color.Primary">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="LoadProjectsClick" Disabled="@_projectsLoading"
                       StartIcon="@Icons.Material.Filled.Refresh">
                @if (_projectsLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Load Projects
            </MudButton>
        </MudStack>
        @if (_projectsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_projects.Count > 0)
        {
            <MudDataGrid Items="@_projects" Dense="true" Striped="true" Hover="true" Bordered="true"
                         FixedHeader="true" Height="calc(100vh - 420px)" QuickFilter="@ProjectFilter">
                <ToolBarContent>
                    <MudTextField @bind-Value="_projectSearch" Placeholder="Search projects..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="300" Clearable="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Key" Title="Key" />
                    <PropertyColumn Property="x => x.Name" Title="Name" />
                    <PropertyColumn Property="x => x.Id" Title="Id" />
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">No projects loaded. Click "Load Projects" or "Load All" to fetch data.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Issue Types" Icon="@Icons.Material.Filled.Category" BadgeData="@_issueTypes.Count"
                 BadgeColor="Color.Secondary">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                       OnClick="LoadIssueTypesClick" Disabled="@_issueTypesLoading"
                       StartIcon="@Icons.Material.Filled.Refresh">
                @if (_issueTypesLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Load Issue Types
            </MudButton>
        </MudStack>
        @if (_issueTypesLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Secondary" />
        }
        else if (_issueTypes.Count > 0)
        {
            <MudDataGrid Items="@_issueTypes" Dense="true" Striped="true" Hover="true" Bordered="true"
                         FixedHeader="true" Height="calc(100vh - 420px)" QuickFilter="@IssueTypeFilter">
                <ToolBarContent>
                    <MudTextField @bind-Value="_issueTypeSearch" Placeholder="Search issue types..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="300" Clearable="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Id" Title="Id" />
                    <PropertyColumn Property="x => x.Name" Title="Name" />
                    <PropertyColumn Property="x => x.Description" Title="Description" />
                    <TemplateColumn Title="Subtask">
                        <CellTemplate>
                            <MudIcon Icon="@(context.Item.Subtask ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                     Color="@(context.Item.Subtask ? Color.Success : Color.Default)" Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">No issue types loaded. Click "Load Issue Types" or "Load All" to fetch data.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Labels" Icon="@Icons.Material.Filled.Label" BadgeData="@_labels.Count"
                 BadgeColor="Color.Tertiary">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudSelect @bind-Value="_labelsProjectFilter" Label="Filter by Project" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width: 250px;" Clearable="true"
                       Placeholder="All labels" Dense="true">
                @foreach (var p in _projects)
                {
                    <MudSelectItem Value="@p.Key">@p.Key — @p.Name</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" Size="Size.Small"
                       OnClick="LoadLabelsClick" Disabled="@_labelsLoading"
                       StartIcon="@Icons.Material.Filled.Refresh">
                @if (_labelsLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Load Labels
            </MudButton>
        </MudStack>
        @if (_labelsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Tertiary" />
        }
        else if (_labels.Count > 0)
        {
            <MudDataGrid Items="@_labels" Dense="true" Striped="true" Hover="true" Bordered="true"
                         FixedHeader="true" Height="calc(100vh - 420px)" QuickFilter="@LabelFilter">
                <ToolBarContent>
                    <MudTextField @bind-Value="_labelSearch" Placeholder="Search labels..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="300" Clearable="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Name" Title="Label" />
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">No labels loaded. Click "Load Labels" or "Load All" to fetch data.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Parent Link" Icon="@Icons.Material.Filled.AccountTree" BadgeData="@_parentLinks.Count"
                 BadgeColor="Color.Info">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudTextField @bind-Value="_parentLinkFieldId" Label="Custom Field ID" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="max-width: 250px;" />
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                       OnClick="LoadParentLinksClick" Disabled="@_parentLinksLoading"
                       StartIcon="@Icons.Material.Filled.Refresh">
                @if (_parentLinksLoading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Load Parent Links
            </MudButton>
        </MudStack>
        @if (_parentLinksLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Info" />
        }
        else if (_parentLinks.Count > 0)
        {
            <MudDataGrid Items="@_parentLinks" Dense="true" Striped="true" Hover="true" Bordered="true"
                         FixedHeader="true" Height="calc(100vh - 420px)">
                <Columns>
                    <PropertyColumn Property="x => x.FieldId" Title="Field Id" />
                    <PropertyColumn Property="x => x.Value" Title="Value" />
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">
                No Parent Link data loaded. Click "Load Parent Links" or "Load All" to fetch data.
            </MudAlert>
        }
    </MudTabPanel>
</MudTabs>

@code {
    private string _jiraUrl = string.Empty;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _parentLinkFieldId = "customfield_19001";
    private bool _loading;

    private bool _projectsLoading;
    private bool _issueTypesLoading;
    private bool _labelsLoading;
    private bool _parentLinksLoading;

    private string _projectSearch = string.Empty;
    private string _issueTypeSearch = string.Empty;
    private string _labelSearch = string.Empty;
    private string? _labelsProjectFilter;

    private List<JiraProject> _projects = new();
    private List<JiraIssueType> _issueTypes = new();
    private List<JiraLabel> _labels = new();
    private List<JiraFieldRow> _parentLinks = new();

    private CancellationTokenSource _projectsCts = new();
    private CancellationTokenSource _issueTypesCts = new();
    private CancellationTokenSource _labelsCts = new();
    private CancellationTokenSource _parentLinksCts = new();

    private string _lastSavedUrl = string.Empty;
    private string _lastSavedUsername = string.Empty;

    private Func<JiraProject, bool> ProjectFilter => p =>
    {
        if (string.IsNullOrWhiteSpace(_projectSearch)) return true;
        var s = _projectSearch.Trim();
        return p.Key.Contains(s, StringComparison.OrdinalIgnoreCase)
            || p.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || p.Id.Contains(s, StringComparison.OrdinalIgnoreCase);
    };

    private Func<JiraIssueType, bool> IssueTypeFilter => t =>
    {
        if (string.IsNullOrWhiteSpace(_issueTypeSearch)) return true;
        var s = _issueTypeSearch.Trim();
        return t.Id.Contains(s, StringComparison.OrdinalIgnoreCase)
            || t.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
            || t.Description.Contains(s, StringComparison.OrdinalIgnoreCase);
    };

    private Func<JiraLabel, bool> LabelFilter => l =>
    {
        if (string.IsNullOrWhiteSpace(_labelSearch)) return true;
        return l.Name.Contains(_labelSearch.Trim(), StringComparison.OrdinalIgnoreCase);
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedUrl = await LocalStorage.GetItemAsync("jiraUrl");
            var savedUsername = await LocalStorage.GetItemAsync("jiraUsername");
            var savedFieldId = await LocalStorage.GetItemAsync("parentLinkFieldId");

            if (!string.IsNullOrEmpty(savedUrl))
            {
                _jiraUrl = savedUrl;
                _lastSavedUrl = savedUrl;
            }
            if (!string.IsNullOrEmpty(savedUsername))
            {
                _username = savedUsername;
                _lastSavedUsername = savedUsername;
            }
            if (!string.IsNullOrEmpty(savedFieldId))
                _parentLinkFieldId = savedFieldId;

            StateHasChanged();
        }
    }

    private JiraCredentials GetCredentials() => new()
    {
        BaseUrl = _jiraUrl,
        Username = _username,
        Password = _password
    };

    private bool ValidateCredentials()
    {
        if (string.IsNullOrWhiteSpace(_jiraUrl) || string.IsNullOrWhiteSpace(_username)
            || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Please fill in Jira URL, Username and Password", Severity.Warning);
            return false;
        }
        return true;
    }

    private async Task SaveCredentialsIfChanged()
    {
        if (_jiraUrl != _lastSavedUrl)
        {
            await LocalStorage.SetItemAsync("jiraUrl", _jiraUrl);
            _lastSavedUrl = _jiraUrl;
        }
        if (_username != _lastSavedUsername)
        {
            await LocalStorage.SetItemAsync("jiraUsername", _username);
            _lastSavedUsername = _username;
        }
        await LocalStorage.SetItemAsync("parentLinkFieldId", _parentLinkFieldId);
    }

    private CancellationToken ResetCts(ref CancellationTokenSource cts)
    {
        cts.Cancel();
        cts.Dispose();
        cts = new CancellationTokenSource();
        return cts.Token;
    }

    private async Task LoadProjectsClick()
    {
        if (!ValidateCredentials()) return;
        await SaveCredentialsIfChanged();
        _projectsLoading = true;
        var ct = ResetCts(ref _projectsCts);
        await LoadProjects(GetCredentials(), ct);
    }

    private async Task LoadIssueTypesClick()
    {
        if (!ValidateCredentials()) return;
        await SaveCredentialsIfChanged();
        _issueTypesLoading = true;
        var ct = ResetCts(ref _issueTypesCts);
        await LoadIssueTypes(GetCredentials(), ct);
    }

    private async Task LoadLabelsClick()
    {
        if (!ValidateCredentials()) return;
        await SaveCredentialsIfChanged();
        _labelsLoading = true;
        var ct = ResetCts(ref _labelsCts);
        await LoadLabels(GetCredentials(), ct);
    }

    private async Task LoadParentLinksClick()
    {
        if (!ValidateCredentials()) return;
        await SaveCredentialsIfChanged();
        _parentLinksLoading = true;
        var ct = ResetCts(ref _parentLinksCts);
        await LoadParentLinks(GetCredentials(), ct);
    }

    private async Task LoadAll()
    {
        if (!ValidateCredentials()) return;

        _loading = true;
        await SaveCredentialsIfChanged();

        var credentials = GetCredentials();
        _projectsLoading = _issueTypesLoading = _labelsLoading = _parentLinksLoading = true;

        var ctProjects = ResetCts(ref _projectsCts);
        var ctIssueTypes = ResetCts(ref _issueTypesCts);
        var ctLabels = ResetCts(ref _labelsCts);
        var ctParentLinks = ResetCts(ref _parentLinksCts);

        StateHasChanged();

        await Task.WhenAll(
            LoadProjects(credentials, ctProjects),
            LoadIssueTypes(credentials, ctIssueTypes),
            LoadLabels(credentials, ctLabels),
            LoadParentLinks(credentials, ctParentLinks));

        _loading = false;
    }

    private async Task LoadProjects(JiraCredentials credentials, CancellationToken ct)
    {
        try
        {
            _projects = await JiraService.GetProjectsAsync(credentials, ct);
            Snackbar.Add($"Loaded {_projects.Count} projects", Severity.Success);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load projects from Jira");
            Snackbar.Add($"Projects error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _projectsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadIssueTypes(JiraCredentials credentials, CancellationToken ct)
    {
        try
        {
            _issueTypes = await JiraService.GetIssueTypesAsync(credentials, ct);
            Snackbar.Add($"Loaded {_issueTypes.Count} issue types", Severity.Success);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load issue types from Jira");
            Snackbar.Add($"Issue types error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _issueTypesLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadLabels(JiraCredentials credentials, CancellationToken ct)
    {
        try
        {
            _labels = await JiraService.GetLabelsAsync(credentials, _labelsProjectFilter, ct);
            var scope = string.IsNullOrWhiteSpace(_labelsProjectFilter) ? "all" : _labelsProjectFilter;
            Snackbar.Add($"Loaded {_labels.Count} labels ({scope})", Severity.Success);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load labels from Jira");
            Snackbar.Add($"Labels error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _labelsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadParentLinks(JiraCredentials credentials, CancellationToken ct)
    {
        try
        {
            _parentLinks = await JiraService.GetCustomFieldOptionsAsync(credentials, _parentLinkFieldId, ct);
            if (_parentLinks.Count > 0)
                Snackbar.Add($"Loaded {_parentLinks.Count} parent link values", Severity.Success);
            else
                Snackbar.Add($"No data found for {_parentLinkFieldId}", Severity.Info);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load parent links from Jira");
            Snackbar.Add($"Parent Link error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _parentLinksLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _projectsCts.Cancel(); _projectsCts.Dispose();
        _issueTypesCts.Cancel(); _issueTypesCts.Dispose();
        _labelsCts.Cancel(); _labelsCts.Dispose();
        _parentLinksCts.Cancel(); _parentLinksCts.Dispose();
    }
}
