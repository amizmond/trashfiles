@inherits LayoutComponentBase
@using Estimation.Components.ModalDialog
@using Estimation.Core.JiraLogic
@using Estimation.Core.Models
@using Estimation.Core.Services
@inject IWindowsAuthService WindowsAuthService
@inject IAppAuthorizationService AppAuthService
@inject IJiraAuthService JiraAuth
@inject IDialogService DialogService

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_authChecked)
{
    <MudLayout>
        <MudMainContent Class="d-flex align-center justify-center" Style="min-height:100vh;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudMainContent>
    </MudLayout>
}
else if (!_isAuthorized)
{
    <MudLayout>
        <MudMainContent Class="d-flex align-center justify-center" Style="min-height:100vh;">
            <MudCard Style="max-width:500px; width:100%;">
                <MudCardHeader>
                    <MudText Typo="Typo.h5" Color="Color.Error">Access Denied</MudText>
                </MudCardHeader>
                <MudCardContent>
                    @if (_accessRequested)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                            Your access request has been submitted. Please wait for administrator approval.
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">
                            You are not authorized to access this application.
                        </MudAlert>
                    }
                    <MudText Typo="Typo.body1">
                        User: <strong>@_userName</strong>
                    </MudText>
                    @if (!_accessRequested)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="mt-4"
                                   FullWidth="true"
                                   OnClick="RequestAccessAsync"
                                   Disabled="_requestingAccess">
                            @if (_requestingAccess)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Request Access
                        </MudButton>
                    }
                </MudCardContent>
            </MudCard>
        </MudMainContent>
    </MudLayout>
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
            <MudSpacer />
            @if (JiraAuth.IsConfigured)
            {
                <MudTooltip Text="@(_jiraConnected ? "Jira: Connected" : "Jira: Not connected")">
                    <MudIconButton Icon="@(_jiraConnected ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudOff)"
                                   Color="@(_jiraConnected ? Color.Success : Color.Default)"
                                   OnClick="OpenJiraDialogAsync" />
                </MudTooltip>
            }
            <MudText Typo="Typo.body2" Class="mr-4">@_userName</MudText>
            <div>
                <MudSwitch @bind-value="@_isDarkMode" Color="Color.Primary" Class="ma-4" T="bool" Label="Light/Dark Mode" />
            </div>
        </MudAppBar>
        <MudDrawer @bind-Open="@_open" Elevation="1">
            <MudNavMenu Class="mud-width-full">
                <MudText Typo="Typo.h6" Class="px-4">Estimation</MudText>
                <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">Version: DEV</MudText>
                <MudDivider Class="my-2" />

                @foreach (var navItem in _navPages.Where(p => p.Group is null))
                {
                    <MudNavLink Href="@GetPageHref(navItem.Key)" Match="@(navItem.Key == "Dashboard" ? NavLinkMatch.All : NavLinkMatch.Prefix)" Icon="@GetPageIcon(navItem.Key)">@navItem.DisplayName</MudNavLink>
                }

                @foreach (var group in _navPages.Where(p => p.Group is not null).GroupBy(p => p.Group!).OrderBy(g => g.Min(p => p.SortOrder)))
                {
                    <MudNavGroup Title="@group.Key" Icon="@GetGroupIcon(group.Key)" Expanded="true">
                        @foreach (var navItem in group.OrderBy(p => p.SortOrder))
                        {
                            @if (navItem.Key == "Authorization" && _hasPendingRequests)
                            {
                                <MudNavLink Href="@GetPageHref(navItem.Key)" Icon="@GetPageIcon(navItem.Key)">
                                    @navItem.DisplayName
                                    <MudBadge Color="Color.Error" Dot="true" Overlap="true" Class="ml-2" />
                                </MudNavLink>
                            }
                            else
                            {
                                <MudNavLink Href="@GetPageHref(navItem.Key)" Icon="@GetPageIcon(navItem.Key)">@navItem.DisplayName</MudNavLink>
                            }
                        }
                    </MudNavGroup>
                }

            </MudNavMenu>
        </MudDrawer>
        <MudMainContent>
            <CascadingValue Value="_isAdmin" Name="IsAdmin">
                <CascadingValue Value="_userPageAccess" Name="UserPageAccess">
                    @Body
                </CascadingValue>
            </CascadingValue>
        </MudMainContent>
    </MudLayout>
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _isDarkMode;
    bool _open = true;
    private bool _authChecked;
    private bool _isAuthorized;
    private bool _isAdmin;
    private string? _userName;
    private bool _jiraConnected;
    private bool _accessRequested;
    private bool _requestingAccess;
    private bool _hasPendingRequests;
    private List<NavPageInfo> _navPages = [];
    private Dictionary<string, AccessLevel> _userPageAccess = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _userName = await WindowsAuthService.GetUserName();

        if (_userName is null)
        {
            _authChecked = true;
            return;
        }

        var currentUser = await AppAuthService.GetCurrentUserAsync(_userName);
        _isAuthorized = currentUser is not null && currentUser.IsApproved;
        _accessRequested = currentUser is not null && currentUser.IsAccessRequested && !currentUser.IsApproved;

        if (_isAuthorized)
        {
            _isAdmin = currentUser!.IsAdmin;
            _navPages = await AppAuthService.GetNavigationPagesAsync(_userName);
            _userPageAccess = _navPages.ToDictionary(p => p.Key, p => p.AccessLevel, StringComparer.OrdinalIgnoreCase);

            if (_isAdmin)
            {
                _hasPendingRequests = await AppAuthService.HasPendingRequestsAsync();
            }

            if (JiraAuth.IsConfigured)
            {
                _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
            }
        }

        _authChecked = true;
    }

    private async Task RequestAccessAsync()
    {
        if (_userName is null)
        {
            return;
        }

        _requestingAccess = true;
        await AppAuthService.RequestAccessAsync(_userName);
        _accessRequested = true;
        _requestingAccess = false;
    }

    private string GetPageHref(string key) => key switch
    {
        "Dashboard" => RoutingPath.Base,
        "Pis" => RoutingPath.Pis,
        "PiPrioritization" => RoutingPath.PiPrioritization,
        "Departments" => RoutingPath.Departments,
        "CapitalProjects" => RoutingPath.CapitalProjects,
        "StrategicObjectives" => RoutingPath.StrategicObjectives,
        "PortfolioEpics" => RoutingPath.PortfolioEpics,
        "BusinessOutcomes" => RoutingPath.BusinessOutcomes,
        "Features" => RoutingPath.Features,
        "Teams" => RoutingPath.Teams,
        "HumanResources" => RoutingPath.HumanResources,
        "Skills" => RoutingPath.Skills,
        "TechnologyStacks" => RoutingPath.TechnologyStacks,
        "AuditLog" => RoutingPath.AuditLog,
        "StaticSettings" => RoutingPath.StaticSettings,
        "Authorization" => RoutingPath.Authorization,
        "DatabaseBackup" => RoutingPath.DatabaseBackup,
        _ => RoutingPath.Base
    };

    private string GetPageIcon(string key) => key switch
    {
        "Dashboard" => Icons.Material.Filled.Dashboard,
        "Pis" => Icons.Material.Filled.DateRange,
        "PiPrioritization" => Icons.Material.Filled.LowPriority,
        "Departments" => Icons.Material.Filled.CorporateFare,
        "CapitalProjects" => Icons.Material.Filled.Business,
        "StrategicObjectives" => Icons.Material.Filled.Schema,
        "PortfolioEpics" => Icons.Material.Filled.Layers,
        "BusinessOutcomes" => Icons.Material.Filled.TrackChanges,
        "Features" => Icons.Material.Filled.Extension,
        "Teams" => Icons.Material.Filled.Group,
        "HumanResources" => Icons.Material.Filled.Person,
        "Skills" => Icons.Material.Filled.Psychology,
        "TechnologyStacks" => Icons.Material.Filled.Layers,
        "AuditLog" => Icons.Material.Filled.History,
        "StaticSettings" => Icons.Material.Filled.Settings,
        "Authorization" => Icons.Material.Filled.AdminPanelSettings,
        "DatabaseBackup" => Icons.Material.Filled.Backup,
        _ => Icons.Material.Filled.Circle
    };

    private string GetGroupIcon(string group) => group switch
    {
        "Planning Increment" => Icons.Material.Filled.DataArray,
        "Planning" => Icons.Material.Filled.AccountTree,
        "Resources" => Icons.Material.Filled.People,
        "Admin" => Icons.Material.Filled.AdminPanelSettings,
        _ => Icons.Material.Filled.Folder
    };

    private async Task OpenJiraDialogAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await DialogService.ShowAsync<JiraLoginDialog>("Jira Authentication", options);
        var result = await dialogRef.Result;

        if (result?.Data is bool connected)
        {
            _jiraConnected = connected;
        }
        else if (_userName is not null)
        {
            _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
        }
    }

    void ToggleDrawer()
    {
        _open = !_open;
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Indigo.Lighten1,
            Secondary = Colors.Pink.Accent2,
            AppbarBackground = Colors.Indigo.Lighten5,
            AppbarText = Colors.Shades.Black,
            DrawerBackground = Colors.Indigo.Lighten5,
            Background = Colors.Gray.Lighten4,
        },
    };
}
