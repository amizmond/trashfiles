    // --- Sort logic ---

    private void ToggleSummarySort()
    {
        if (_sortColumn == SortableSummary)
        {
            if (_sortDescending)
            {
                _sortColumn = null;
                _sortDescending = false;
            }
            else
            {
                _sortDescending = true;
            }
        }
        else
        {
            _sortColumn = SortableSummary;
            _sortDescending = false;
        }
        RecomputeFilteredRows();
        UpdateUrl();
    }

    // --- Filter logic ---

    private void RecomputeFilteredRows()
    {
        IEnumerable<FeatureRow> filtered = _rows.Where(MatchesFilter);

        if (_sortColumn == SortableSummary)
        {
            filtered = _sortDescending
                ? filtered.OrderByDescending(r => r.Summary)
                : filtered.OrderBy(r => r.Summary);
        }

        _filteredRows = filtered.ToList();
    }

    private bool MatchesFilter(FeatureRow r)
    {
        if (!string.IsNullOrWhiteSpace(_filterSearchBacking))
        {
            var s = _filterSearchBacking.Trim();
            if (!((r.Summary?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.JiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.PiName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.BoName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.BoJiraId?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.FeatureName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (r.EpicName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)))
            {
                return false;
            }
        }

        if (!string.IsNullOrWhiteSpace(_filterLabelBacking))
        {
            var labelFilter = _filterLabelBacking.Trim();
            if (string.IsNullOrEmpty(r.Labels)
                || !r.Labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Any(l => l.Contains(labelFilter, StringComparison.OrdinalIgnoreCase)))
            {
                return false;
            }
        }

        if (_filterPiNotBacking)
        {
            if (_filterPiNamesSet.Count > 0)
            {
                // Exclude features that match any of the selected PIs
                if (r.PiName is not null && _filterPiNamesSet.Contains(r.PiName))
                {
                    return false;
                }
            }
            else
            {
                // No PIs selected + Not checked => show only features without a PI
                if (r.PiName is not null)
                {
                    return false;
                }
            }
        }
        else if (_filterPiNamesSet.Count > 0
            && (r.PiName is null || !_filterPiNamesSet.Contains(r.PiName)))
        {
            return false;
        }

        if (_filterBoNotBacking)
        {
            if (_filterBoNamesSet.Count > 0)
            {
                if (r.BoJiraId is not null && _filterBoNamesSet.Contains(r.BoJiraId))
                {
                    return false;
                }
            }
            else
            {
                if (r.BoJiraId is not null)
                {
                    return false;
                }
            }
        }
        else if (_filterBoNamesSet.Count > 0
            && (r.BoJiraId is null || !_filterBoNamesSet.Contains(r.BoJiraId)))
        {
            return false;
        }

        if (_filterEpicNotBacking)
        {
            if (_filterEpicNamesSet.Count > 0)
            {
                if (r.EpicJiraId is not null && _filterEpicNamesSet.Contains(r.EpicJiraId))
                {
                    return false;
                }
            }
            else
            {
                if (r.EpicJiraId is not null)
                {
                    return false;
                }
            }
        }
        else if (_filterEpicNamesSet.Count > 0
            && (r.EpicJiraId is null || !_filterEpicNamesSet.Contains(r.EpicJiraId)))
        {
            return false;
        }

        if (_filterProgramNotBacking)
        {
            if (_filterProgramNamesSet.Count > 0)
            {
                if (r.ProgramJiraIds.Any(p => _filterProgramNamesSet.Contains(p.Summary ?? "")))
                {
                    return false;
                }
            }
            else
            {
                if (r.ProgramJiraIds.Count > 0)
                {
                    return false;
                }
            }
        }
        else if (_filterProgramNamesSet.Count > 0
            && !r.ProgramJiraIds.Any(p => _filterProgramNamesSet.Contains(p.Summary ?? "")))
        {
            return false;
        }

        if (_filterDepartmentNamesSet.Count > 0
            && !(r.CapitalProjectName is not null
                && _cpNameToDept.TryGetValue(r.CapitalProjectName, out var dn)
                && _filterDepartmentNamesSet.Contains(dn)))
        {
            return false;
        }

        if (_filterCapitalProjectNamesSet.Count > 0
            && (r.CapitalProjectName is null || !_filterCapitalProjectNamesSet.Contains(r.CapitalProjectName)))
        {
            return false;
        }

        if (_filterTechStackNamesSet.Count > 0
            && !r.TechStacks.Any(ts => _filterTechStackNamesSet.Contains(ts.Name)))
        {
            return false;
        }

        return true;
    }

    // --- Lifecycle ---

    protected override async Task OnInitializedAsync()
    {
        _canEdit = UserPageAccess.TryGetValue("Features", out var access) && access == AccessLevel.Edit;

        try
        {
            _userName = await WindowsAuth.GetUserName();
            if (_userName is not null && JiraAuth.IsConfigured)
            {
                _jiraConnected = await JiraAuth.IsAuthenticatedAsync(_userName);
            }

            var departments = await DepartmentService.GetAllAsync();
            _cpNameToDept = departments
                .SelectMany(d => d.CapitalProjects.Select(cp => (cp.Name, d.Name)))
                .GroupBy(x => x.Item1, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First().Item2, StringComparer.OrdinalIgnoreCase);

            _allCapitalProjectsForSync = await CapitalProjectService.GetAllAsync();
            _capitalProjectNameByJiraKey = _allCapitalProjectsForSync
                .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey))
                .GroupBy(cp => cp.JiraKey!, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First().Name, StringComparer.OrdinalIgnoreCase);

            var items = await FeatureService.GetAllWithHierarchyAsync();
            _rows = items.Select(f =>
            {
                var bo = f.BusinessOutcome;
                var epic = bo?.PortfolioEpic;
                var programs = epic?.StrategicObjectivePortfolioEpics
                    .Select(ppe => ppe.StrategicObjective).ToList() ?? new();

                var resolvedCapitalProjectName = ResolveCapitalProjectName(f.ProjectKey, f.JiraId);

                return new FeatureRow(
                    Id: f.Id,
                    JiraId: f.JiraId,
                    FeatureName: f.Name,
                    Summary: f.Summary,
                    PiId: f.PiId,
                    PiName: f.Pi?.Name,
                    BoJiraId: bo?.JiraId,
                    BoName: bo?.Summary,
                    BoDescription: bo?.Description,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Summary,
                    EpicDescription: epic?.Description,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Summary, p.Description))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjectName: resolvedCapitalProjectName,
                    Labels: f.Labels,
                    Teams: f.FeatureTeams.Select(ft => new TeamRef(ft.TeamId, ft.Team.Name)).ToList(),
                    TechStacks: f.FeatureTechnologyStacks.Select(fts => new TechStackRef(fts.TechnologyStack.Name, fts.EstimatedEffort)).ToList(),
                    Comments: f.Comments,
                    TargetStart: f.TargetStart,
                    TargetEnd: f.TargetEnd,
                    StoryPoints: f.StoryPoints
                );
            }).ToList();

            _availablePis = _rows
                .Where(r => r.PiName is not null)
                .Select(r => r.PiName!).Distinct().OrderBy(n => n).ToList();
            _availableBos = _rows
                .Where(r => !string.IsNullOrEmpty(r.BoJiraId))
                .Select(r => (r.BoJiraId!, r.BoName))
                .DistinctBy(b => b.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(b => b.Item1).ToList();
            _availableEpics = _rows
                .Where(r => !string.IsNullOrEmpty(r.EpicJiraId))
                .Select(r => (r.EpicJiraId!, r.EpicName))
                .DistinctBy(e => e.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(e => e.Item1).ToList();
            _availablePrograms = _rows
                .SelectMany(r => r.ProgramJiraIds.Select(p => p.Summary ?? ""))
                .Where(n => !string.IsNullOrEmpty(n))
                .Distinct().OrderBy(n => n).ToList();
            _availableDepartments = _rows
                .Where(r => r.CapitalProjectName is not null && _cpNameToDept.ContainsKey(r.CapitalProjectName))
                .Select(r => _cpNameToDept[r.CapitalProjectName!])
                .Distinct().OrderBy(n => n).ToList();
            _availableCapitalProjects = _rows
                .Where(r => !string.IsNullOrEmpty(r.CapitalProjectName))
                .Select(r => r.CapitalProjectName!)
                .Distinct().OrderBy(n => n).ToList();
            _availableTechStacks = _rows
                .SelectMany(r => r.TechStacks.Select(ts => ts.Name))
                .Where(n => !string.IsNullOrEmpty(n))
                .Distinct().OrderBy(n => n).ToList();

            ReadUrlParams();
            RecomputeFilteredRows();
        }
        finally
        {
            _loading = false;
            _suppressUrlUpdate = false;
        }
    }

    private async Task ConfirmDeleteAsync(FeatureRow row)
    {
        try
        {
            if (await MessageService.Confirm($"Delete {row.Summary} ?"))
            {
                await FeatureService.DeleteAsync(row.Id);
                _rows.RemoveAll(r => r.Id == row.Id);
                RecomputeFilteredRows();
                UpdateUrl();
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, ex.Message);
            await MessageService.Exception(ex);
        }
    }

    // --- URL state management ---

    private void ReadUrlParams()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);

        if (q.TryGetValue("search", out var search) && !string.IsNullOrWhiteSpace(search))
        {
            _filterSearchBacking = search.ToString();
        }

        if (q.TryGetValue("label", out var label) && !string.IsNullOrWhiteSpace(label))
        {
            _filterLabelBacking = label.ToString();
        }

        if (q.TryGetValue("piNot", out var piNot)
            && string.Equals(piNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterPiNotBacking = true;
        }

        if (q.TryGetValue("pi", out var pi) && !string.IsNullOrWhiteSpace(pi))
        {
            var vals = pi.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterPiNamesBacking = vals;
            _filterPiNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("boNot", out var boNot)
            && string.Equals(boNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterBoNotBacking = true;
        }

        if (q.TryGetValue("bo", out var bo) && !string.IsNullOrWhiteSpace(bo))
        {
            var vals = bo.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterBoNamesBacking = vals;
            _filterBoNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("epicNot", out var epicNot)
            && string.Equals(epicNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterEpicNotBacking = true;
        }

        if (q.TryGetValue("epic", out var epic) && !string.IsNullOrWhiteSpace(epic))
        {
            var vals = epic.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterEpicNamesBacking = vals;
            _filterEpicNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("programNot", out var programNot)
            && string.Equals(programNot, "true", StringComparison.OrdinalIgnoreCase))
        {
            _filterProgramNotBacking = true;
        }

        if (q.TryGetValue("program", out var program) && !string.IsNullOrWhiteSpace(program))
        {
            var vals = program.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterProgramNamesBacking = vals;
            _filterProgramNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("dept", out var dept) && !string.IsNullOrWhiteSpace(dept))
        {
            var vals = dept.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterDepartmentNamesBacking = vals;
            _filterDepartmentNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("cp", out var cp) && !string.IsNullOrWhiteSpace(cp))
        {
            var vals = cp.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterCapitalProjectNamesBacking = vals;
            _filterCapitalProjectNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("ts", out var ts) && !string.IsNullOrWhiteSpace(ts))
        {
            var vals = ts.ToString().Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _filterTechStackNamesBacking = vals;
            _filterTechStackNamesSet = new HashSet<string>(vals, StringComparer.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("sortBy", out var sortBy) && !string.IsNullOrWhiteSpace(sortBy))
        {
            _sortColumn = sortBy.ToString();
            _sortDescending = q.TryGetValue("sortDesc", out var sortDesc)
                && string.Equals(sortDesc, "true", StringComparison.OrdinalIgnoreCase);
        }
    }

    private void UpdateUrl()
    {
        if (_suppressUrlUpdate)
        {
            return;
        }

        var query = new Dictionary<string, object?>();
        query["search"] = string.IsNullOrWhiteSpace(_filterSearchBacking) ? null : _filterSearchBacking;
        query["label"] = string.IsNullOrWhiteSpace(_filterLabelBacking) ? null : _filterLabelBacking;
        query["piNot"] = _filterPiNotBacking ? (object?)true : null;
        query["pi"] = _filterPiNamesSet.Count > 0 ? string.Join(",", _filterPiNamesBacking) : null;
        query["boNot"] = _filterBoNotBacking ? (object?)true : null;
        query["bo"] = _filterBoNamesSet.Count > 0 ? string.Join(",", _filterBoNamesBacking) : null;
        query["epicNot"] = _filterEpicNotBacking ? (object?)true : null;
        query["epic"] = _filterEpicNamesSet.Count > 0 ? string.Join(",", _filterEpicNamesBacking) : null;
        query["programNot"] = _filterProgramNotBacking ? (object?)true : null;
        query["program"] = _filterProgramNamesSet.Count > 0 ? string.Join(",", _filterProgramNamesBacking) : null;
        query["dept"] = _filterDepartmentNamesSet.Count > 0 ? string.Join(",", _filterDepartmentNamesBacking) : null;
        query["cp"] = _filterCapitalProjectNamesSet.Count > 0 ? string.Join(",", _filterCapitalProjectNamesBacking) : null;
        query["ts"] = _filterTechStackNamesSet.Count > 0 ? string.Join(",", _filterTechStackNamesBacking) : null;
        query["sortBy"] = _sortColumn;
        query["sortDesc"] = _sortDescending && _sortColumn is not null ? (object?)true : null;

        var uri = Nav.GetUriWithQueryParameters(query);
        Nav.NavigateTo(uri, replace: true);
    }

    private void NavigateToEdit(int id)
    {
        var currentUri = new Uri(Nav.Uri);
        var returnUrl = currentUri.PathAndQuery;
        var editUri = Nav.GetUriWithQueryParameters(
            $"{RoutingPath.Features}/{id}",
            new Dictionary<string, object?> { ["returnUrl"] = returnUrl });
        Nav.NavigateTo(editUri);
    }

    // --- Excel export ---

    private async Task<(List<string> ProjectKeys, List<string> PiNames, List<string> TeamNames, List<string> TechStackNames)> LoadExportLookupsAsync()
    {
        var capitalProjects = await CapitalProjectService.GetAllAsync();
        var projectKeys = capitalProjects
            .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey))
            .Select(cp => cp.JiraKey!).Distinct().OrderBy(k => k).ToList();

        var pis = await PiService.GetAllLightAsync();
        var piNames = pis.Select(p => p.Name).OrderBy(n => n).ToList();

        var teams = await TeamService.GetAllNamesAsync();
        var teamNames = teams.Select(t => t.Name).OrderBy(n => n).ToList();

        var techStacks = await TechnologyStackService.GetAllAsync();
        var techStackNames = techStacks.Select(ts => ts.Name).OrderBy(n => n).ToList();

        return (projectKeys, piNames, teamNames, techStackNames);
    }

    private async Task ExportFilteredAsync()
    {
        try
        {
            _exporting = true;
            StateHasChanged();

            var (projectKeys, piNames, teamNames, techStackNames) = await LoadExportLookupsAsync();

            // Build lookup: feature ID -> full feature with tech stacks and teams
            var allFeatures = await FeatureService.GetAllAsync();
            var featureById = allFeatures.ToDictionary(f => f.Id);

            var exportRows = _filteredRows.Select(r =>
            {
                featureById.TryGetValue(r.Id, out var dbFeature);

                // Determine project key from hierarchy
                string? pk = dbFeature?.ProjectKey;

                // Team: take first team name
                var teamName = dbFeature?.FeatureTeams.FirstOrDefault()?.Team?.Name;

                // Tech stack efforts
                var tsDict = dbFeature?.FeatureTechnologyStacks
                    .Where(fts => fts.TechnologyStack != null)
                    .ToDictionary(fts => fts.TechnologyStack.Name, fts => fts.EstimatedEffort, StringComparer.OrdinalIgnoreCase)
                    ?? new Dictionary<string, int?>(StringComparer.OrdinalIgnoreCase);

                var efforts = techStackNames.Select(tsName =>
                    tsDict.TryGetValue(tsName, out var effort) ? effort : null).ToList();

                return new FeatureExportRow
                {
                    ProjectKey = pk,
                    JiraId = r.JiraId,
                    FeatureName = r.FeatureName,
                    Summary = r.Summary,
                    Ranking = dbFeature?.Ranking,
                    Description = dbFeature?.Description,
                    Pi = r.PiName,
                    Team = teamName,
                    Comments = r.Comments,
                    TechStackEfforts = efforts
                };
            }).ToList();

            var bytes = ExcelTemplateService.GenerateFeatureExport(exportRows, projectKeys, piNames, teamNames, techStackNames);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';a.download='Features.xlsx';document.body.appendChild(a);a.click();a.remove();");
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to export features");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportEmptyTemplateAsync()
    {
        try
        {
            _exporting = true;
            StateHasChanged();

            var (projectKeys, piNames, teamNames, techStackNames) = await LoadExportLookupsAsync();

            var bytes = ExcelTemplateService.GenerateFeatureExport(new List<FeatureExportRow>(), projectKeys, piNames, teamNames, techStackNames);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';a.download='Features_Template.xlsx';document.body.appendChild(a);a.click();a.remove();");
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to export template");
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    // --- Map to PI ---

    private async Task OpenMapToPiDialogAsync()
    {
        try
        {
            var pis = await PiService.GetAllLightAsync();
            if (pis.Count == 0)
            {
                await MessageService.Info(
                    "No Planning Increments have been created yet. Please create a PI first.",
                    "No PIs available");
                return;
            }

            var parameters = new DialogParameters<MapToPiDialog>
            {
                { x => x.Pis, pis },
                { x => x.FeatureCount, _filteredRows.Count }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            var dialog = await DialogService.ShowAsync<MapToPiDialog>("Map to PI", parameters, options);
            var result = await dialog.Result;

            if (result is null || result.Canceled)
            {
                return;
            }

            var mapResult = (MapToPiDialog.MapToPiResult)result.Data!;
            var featureIds = _filteredRows.Select(r => r.Id).ToList();

            if (mapResult.PiId is not null)
            {
                var piName = pis.First(p => p.Id == mapResult.PiId.Value).Name;
                if (!await MessageService.Confirm(
                    $"Map {featureIds.Count} filtered feature(s) to PI \"{piName}\"?"))
                {
                    return;
                }
            }
            else
            {
                if (!await MessageService.Confirm(
                    $"Remove PI mapping from {featureIds.Count} filtered feature(s)?"))
                {
                    return;
                }
            }

            await FeatureService.MapFeaturesToPiAsync(featureIds, mapResult.PiId);

            // Update local rows to reflect the change
            var newPiId = mapResult.PiId;
            var newPiName = newPiId.HasValue ? pis.First(p => p.Id == newPiId.Value).Name : null;
            _rows = _rows.Select(r =>
                featureIds.Contains(r.Id)
                    ? r with { PiId = newPiId, PiName = newPiName }
                    : r).ToList();
            RecomputeFilteredRows();

            Snackbar.Add(
                mapResult.PiId is not null
                    ? $"Mapped {featureIds.Count} feature(s) to PI \"{newPiName}\"."
                    : $"Removed PI mapping from {featureIds.Count} feature(s).",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Map to PI failed");
            await MessageService.Exception(ex);
        }
    }

    // --- Jira sync ---

    private async Task OpenSyncDialogAsync()
    {
        if (_allCapitalProjectsForSync.Count == 0)
        {
            _allCapitalProjectsForSync = await CapitalProjectService.GetAllAsync();
        }

        var projectsWithKey = _allCapitalProjectsForSync
            .Where(cp => !string.IsNullOrWhiteSpace(cp.JiraKey)).ToList();

        if (projectsWithKey.Count == 0)
        {
            Snackbar.Add("No ART Level records have a Jira Key configured.", Severity.Warning);
            return;
        }

        var dbPis = await PiService.GetAllLightAsync();
        var dbTeams = await TeamService.GetAllNamesAsync();

        var parameters = new DialogParameters<JiraSyncDialog>
        {
            { x => x.Projects, projectsWithKey.Select(cp => new JiraSyncDialog.ProjectOption(cp.Id, cp.JiraKey!, cp.Name)).ToList() },
            { x => x.IssueType, JiraIssueTypes.Feature },
            { x => x.UserName, _userName! },
            { x => x.AvailablePiNames, dbPis.Select(p => p.Name).OrderBy(n => n).ToList() },
            { x => x.AvailableTeamNames, dbTeams.Select(t => t.Name).OrderBy(n => n).ToList() }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<JiraSyncDialog>("Synchronize with Jira", parameters, options);
        var result = await dialog.Result;

        if (result is null || result.Canceled)
        {
            return;
        }

        var syncResult = (JiraSyncDialog.JiraSyncDialogResult)result.Data!;
        await RunSyncAsync(syncResult.ProjectKey, syncResult.Issues);
    }

    private async Task RunSyncAsync(string projectKey, List<JiraIssueResponse> jiraIssues)
    {
        _syncing = true;
        StateHasChanged();

        try
        {
            if (jiraIssues.Count == 0)
            {
                Snackbar.Add($"No Features found in Jira project {projectKey}.", Severity.Info);
                return;
            }

            var syncItems = jiraIssues.Select(ji => new JiraFeatureSyncItem(
                JiraKey: ji.Key,
                Summary: ji.Summary,
                Description: ji.Description,
                IssueType: ji.IssueType,
                Labels: ji.Labels is { Count: > 0 } ? string.Join(",", ji.Labels) : null,
                FeatureName: ji.FeatureName,
                ParentLink: ji.ParentLink,
                Status: ji.Status,
                JiraUpdated: ji.Updated,
                TargetStart: ji.TargetStart,
                TargetEnd: ji.TargetEnd,
                StoryPoints: ji.StoryPoints,
                GfedTeam: ji.GfedTeam,
                PlanningIncrement: ji.PlanningIncrement
            )).ToList();

            var syncResult = await FeatureService.SyncFromJiraAsync(projectKey, syncItems);

            Snackbar.Add(
                $"Sync complete: {syncResult.Created} created, {syncResult.Updated} updated, {syncResult.Linked} linked.",
                Severity.Success);

            // Reload data
            var items = await FeatureService.GetAllWithHierarchyAsync();
            _rows = items.Select(f =>
            {
                var bo = f.BusinessOutcome;
                var epic = bo?.PortfolioEpic;
                var programs = epic?.StrategicObjectivePortfolioEpics
                    .Select(ppe => ppe.StrategicObjective).ToList() ?? new();

                var resolvedCapitalProjectName = ResolveCapitalProjectName(f.ProjectKey, f.JiraId);

                return new FeatureRow(
                    Id: f.Id,
                    JiraId: f.JiraId,
                    FeatureName: f.Name,
                    Summary: f.Summary,
                    PiId: f.PiId,
                    PiName: f.Pi?.Name,
                    BoJiraId: bo?.JiraId,
                    BoName: bo?.Summary,
                    BoDescription: bo?.Description,
                    EpicJiraId: epic?.JiraId,
                    EpicName: epic?.Summary,
                    EpicDescription: epic?.Description,
                    ProgramJiraIds: programs
                        .Where(p => !string.IsNullOrEmpty(p.JiraId))
                        .Select(p => new JiraRef(p.JiraId!, p.Summary, p.Description))
                        .DistinctBy(p => p.JiraId).ToList(),
                    CapitalProjectName: resolvedCapitalProjectName,
                    Labels: f.Labels,
                    Teams: f.FeatureTeams.Select(ft => new TeamRef(ft.TeamId, ft.Team.Name)).ToList(),
                    TechStacks: f.FeatureTechnologyStacks.Select(fts => new TechStackRef(fts.TechnologyStack.Name, fts.EstimatedEffort)).ToList(),
                    Comments: f.Comments,
                    TargetStart: f.TargetStart,
                    TargetEnd: f.TargetEnd,
                    StoryPoints: f.StoryPoints
                );
            }).ToList();
            RecomputeFilteredRows();
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Jira Feature sync failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private async Task SyncFilteredAsync()
    {
        var jiraKeys = _filteredRows
            .Where(r => !string.IsNullOrWhiteSpace(r.JiraId))
            .Select(r => r.JiraId!)
            .Distinct().ToList();

        if (jiraKeys.Count == 0)
        {
            Snackbar.Add("No filtered records have a Jira ID.", Severity.Warning);
            return;
        }

        _syncing = true;
        StateHasChanged();

        try
        {
            var jiraIssues = await JiraIssueService.GetIssuesByKeysAsync(_userName!, jiraKeys);

            // Load current DB state for comparison
            var dbFeatures = (await FeatureService.GetAllAsync())
                .Where(f => jiraKeys.Contains(f.JiraId!))
                .ToDictionary(f => f.JiraId!);

            var dbPis = await PiService.GetAllLightAsync();
            var dbTeams = await TeamService.GetAllNamesAsync();
            var dbPiNames = new HashSet<string>(dbPis.Select(p => p.Name), StringComparer.OrdinalIgnoreCase);
            var teamsNotFound = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var pisToCreate = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            var diffs = new List<JiraFilteredSyncDiffDialog.DiffItem>();
            foreach (var ji in jiraIssues)
            {
                if (!dbFeatures.TryGetValue(ji.Key, out var db))
                {
                    continue;
                }

                if (!string.Equals(db.Summary, ji.Summary, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Summary", db.Summary, ji.Summary));
                }
                if (!string.Equals(db.Description, ji.Description, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Description", db.Description, ji.Description));
                }
                var jiraLabels = ji.Labels is { Count: > 0 } ? string.Join(",", ji.Labels) : null;
                if (!string.Equals(db.Labels, jiraLabels, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Labels", db.Labels, jiraLabels));
                }
                if (!string.Equals(db.Status, ji.Status, StringComparison.Ordinal))
                {
                    diffs.Add(new(ji.Key, "Status", db.Status, ji.Status));
                }
                if (db.TargetStart != ji.TargetStart)
                {
                    diffs.Add(new(ji.Key, PlanningDisplayNames.TargetStart, db.TargetStart?.ToString("yyyy-MM-dd"), ji.TargetStart?.ToString("yyyy-MM-dd")));
                }
                if (db.TargetEnd != ji.TargetEnd)
                {
                    diffs.Add(new(ji.Key, PlanningDisplayNames.TargetEnd, db.TargetEnd?.ToString("yyyy-MM-dd"), ji.TargetEnd?.ToString("yyyy-MM-dd")));
                }
                if (db.StoryPoints != ji.StoryPoints)
                {
                    diffs.Add(new(ji.Key, PlanningDisplayNames.StoryPoints, db.StoryPoints?.ToString(), ji.StoryPoints?.ToString()));
                }

                // PI diff
                var dbPiName = db.Pi?.Name;
                var jiraPiName = string.IsNullOrWhiteSpace(ji.PlanningIncrement) ? null : ji.PlanningIncrement.Trim();
                if (!string.Equals(dbPiName, jiraPiName, StringComparison.OrdinalIgnoreCase))
                {
                    diffs.Add(new(ji.Key, PlanningDisplayNames.PI, dbPiName, jiraPiName));
                }
                if (jiraPiName is not null && !dbPiNames.Contains(jiraPiName))
                {
                    pisToCreate.Add(jiraPiName);
                }

                // Teams diff (resolve Jira values to matched DB teams; ignore unmatched)
                var dbTeamNames = db.FeatureTeams
                    .Where(ft => ft.Team is not null)
                    .Select(ft => ft.Team.Name)
                    .OrderBy(n => n, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                var resolvedJiraTeamNames = new List<string>();
                if (!string.IsNullOrWhiteSpace(ji.GfedTeam))
                {
                    var jiraTeamValues = ji.GfedTeam.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    foreach (var jt in jiraTeamValues)
                    {
                        var match = dbTeams
                            .Where(t => !string.IsNullOrEmpty(t.Name) && jt.Contains(t.Name, StringComparison.OrdinalIgnoreCase))
                            .OrderByDescending(t => t.Name.Length)
                            .FirstOrDefault();
                        if (match is null)
                        {
                            teamsNotFound.Add(jt);
                        }
                        else if (!resolvedJiraTeamNames.Contains(match.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            resolvedJiraTeamNames.Add(match.Name);
                        }
                    }
                }
                var resolvedSorted = resolvedJiraTeamNames.OrderBy(n => n, StringComparer.OrdinalIgnoreCase).ToList();
                if (!dbTeamNames.SequenceEqual(resolvedSorted, StringComparer.OrdinalIgnoreCase))
                {
                    diffs.Add(new(
                        ji.Key,
                        PlanningDisplayNames.Teams,
                        dbTeamNames.Count > 0 ? string.Join(", ", dbTeamNames) : null,
                        resolvedSorted.Count > 0 ? string.Join(", ", resolvedSorted) : null));
                }
            }

            var parameters = new DialogParameters<JiraFilteredSyncDiffDialog>
            {
                { x => x.Diffs, diffs },
                { x => x.JiraIssues, jiraIssues },
                { x => x.TeamsNotFound, teamsNotFound.OrderBy(s => s).ToList() },
                { x => x.PisToCreate, pisToCreate.OrderBy(s => s).ToList() }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
            var dialog = await DialogService.ShowAsync<JiraFilteredSyncDiffDialog>(
                "Jira Differences — Features", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled)
            {
                var issuesToApply = (List<JiraIssueResponse>)result.Data!;
                await RunSyncAsync(string.Empty, issuesToApply);
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Sync filtered features failed");
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

