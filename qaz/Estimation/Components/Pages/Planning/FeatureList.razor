    private record JiraRef(string JiraId, string? Summary, string? Description);
    private record TeamRef(int Id, string Name);
    private record TechStackRef(string Name, int? EstimatedEffort);

    private record FeatureRow(
        int Id,
        string? JiraId,
        string? FeatureName,
        string? Summary,
        int? PiId,
        string? PiName,
        string? BoJiraId,
        string? BoName,
        string? BoDescription,
        string? EpicJiraId,
        string? EpicName,
        string? EpicDescription,
        List<JiraRef> ProgramJiraIds,
        string? CapitalProjectName,
        string? Labels,
        List<TeamRef> Teams,
        List<TechStackRef> TechStacks,
        string? Comments,
        DateTime? TargetStart,
        DateTime? TargetEnd,
        int? StoryPoints
    );

    private string? ResolveCapitalProjectName(string? projectKey, string? jiraId)
    {
        var key = projectKey;
        if (string.IsNullOrWhiteSpace(key) && !string.IsNullOrWhiteSpace(jiraId))
        {
            var dash = jiraId.IndexOf('-');
            key = dash > 0 ? jiraId.Substring(0, dash) : jiraId;
        }

        if (string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        return _capitalProjectNameByJiraKey.TryGetValue(key, out var name) ? name : null;
    }
