@attribute [Route(RoutingPath.Features)]
@using Estimation.Components.ModalDialog
@using Estimation.Core.JiraLogic
@using Estimation.Core.Models
@using Estimation.Core.Services
@using Estimation.Excel
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@using Serilog

@inject IFeatureService FeatureService
@inject IPiService PiService
@inject ICapitalProjectService CapitalProjectService
@inject IDepartmentService DepartmentService
@inject ITeamService TeamService
@inject ITechnologyStackService TechnologyStackService
@inject IJiraAuthService JiraAuth
@inject IWindowsAuthService WindowsAuth
@inject NavigationManager Nav
@inject IModalDialogService MessageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJiraIssueService JiraIssueService
@inject IConfiguration Configuration
@inject IJSRuntime JS

@implements IDisposable

<div class="container-fluid mt-3 mb-5">
    <MudPaper Class="p-3 rounded-lg" Elevation="2">
        <MudText Typo="Typo.h6">@PlanningDisplayNames.Features</MudText>

        <div class="d-flex flex-wrap align-center justify-end gap-2 pa-2">
            <div style="position:relative;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ViewColumn"
                           Disabled="_loading"
                           OnClick="() => _columnsPopoverOpen = !_columnsPopoverOpen">
                    Columns
                </MudButton>
                <MudPopover Open="_columnsPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4" Style="min-width:280px">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@PlanningDisplayNames.ToggleColumns</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _columnsPopoverOpen = false" />
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <MudSwitch T="bool" @bind-Value="_showJiraId" Label="@PlanningDisplayNames.JiraId" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showFeatureName" Label="@PlanningDisplayNames.FeatureName" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showName" Label="@PlanningDisplayNames.Summary" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showPi" Label="@PlanningDisplayNames.PI" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showBoJiraId" Label="@PlanningDisplayNames.BusinessOutcome" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showEpicJiraId" Label="@PlanningDisplayNames.PortfolioEpic" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showProgramJiraId" Label="@PlanningDisplayNames.StrategicObjective" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showCapitalProject" Label="@PlanningDisplayNames.CapitalProjec" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showLabels" Label="@PlanningDisplayNames.Labels" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showTeams" Label="@PlanningDisplayNames.Teams" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showTechPo" Label="@PlanningDisplayNames.TechnologyStacks" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showComments" Label="@PlanningDisplayNames.Comments" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showTargetStart" Label="@PlanningDisplayNames.TargetStart" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showTargetEnd" Label="@PlanningDisplayNames.TargetEnd" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showStoryPoints" Label="@PlanningDisplayNames.StoryPoints" Color="Color.Primary" Dense />
                        <MudSwitch T="bool" @bind-Value="_showActions" Label="@PlanningDisplayNames.Actions" Color="Color.Primary" Dense />
                    </div>
                </MudPopover>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Disabled="_loading"
                       OnClick="() => _drawerOpen = !_drawerOpen">
                Filter
            </MudButton>

            @if (_canEdit)
            {
                @if (_jiraConnected)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Sync"
                               Disabled="_syncing"
                               OnClick="OpenSyncDialogAsync">
                        Synchronize with Jira
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.SyncAlt"
                               Disabled="_syncing"
                               OnClick="SyncFilteredAsync">
                        Synchronize only filtered
                    </MudButton>
                }

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Map"
                           Disabled="_loading"
                           OnClick="OpenMapToPiDialogAsync">
                    Map to PI
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => Nav.NavigateTo(RoutingPath.FeaturesNew))">
                    New
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           Disabled="_loading || _exporting"
                           OnClick="ExportFilteredAsync">
                    Export to excel
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Description"
                           Disabled="_loading || _exporting"
                           OnClick="ExportEmptyTemplateAsync">
                    Empty template
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.UploadFile"
                           Disabled="_loading"
                           OnClick="@(() => Nav.NavigateTo(RoutingPath.FeaturesUpload))">
                    Upload
                </MudButton>
            }
        </div>

        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2"
                    Variant="DrawerVariant.Temporary" Width="400px"
                    Style="background: var(--mud-palette-surface)">
            <MudDrawerHeader>
                <div class="d-flex align-center justify-space-between" style="width:100%">
                    <MudText Typo="Typo.h6">@PlanningDisplayNames.Filters</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _drawerOpen = false" />
                </div>
            </MudDrawerHeader>
            <div class="d-flex flex-column gap-3 pa-4">
                <MudTextField @bind-Value="FilterSearch" Label="@PlanningDisplayNames.Search" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <div class="d-flex align-end gap-2">
                    <MudSelect T="string" Label="@PlanningDisplayNames.PI" MultiSelection
                               @bind-SelectedValues="FilterPiNames"
                               Dense Variant="Variant.Outlined" Clearable
                               AnchorOrigin="Origin.BottomCenter" Style="flex:1">
                        @foreach (var pi in _availablePis)
                        {
                            <MudSelectItem T="string" Value="@pi">@pi</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Text="Negate: find features without PI or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterPiNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableBoIds"
                                        Values="FilterBoNames"
                                        ValuesChanged="OnFilterBoNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.BusinessOutcome"
                                        ToStringFunc="@LookupBoText"
                                        ItemTemplate="@BoItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Business Outcome or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterBoNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="@_availableEpicIds"
                                        Values="FilterEpicNames"
                                        ValuesChanged="OnFilterEpicNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.PortfolioEpic"
                                        ToStringFunc="@LookupEpicText"
                                        ItemTemplate="@EpicItemTemplate"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Portfolio Epic or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterEpicNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <div class="d-flex align-end gap-2">
                    <SearchableDropdown T="string"
                                        Items="_availablePrograms"
                                        Values="FilterProgramNames"
                                        ValuesChanged="OnFilterProgramNamesChanged"
                                        MultiSelect="true"
                                        Label="@PlanningDisplayNames.StrategicObjective"
                                        Style="flex:1" />
                    <MudTooltip Text="Negate: find features without Strategic Objective or exclude selected">
                        <MudCheckBox T="bool" @bind-Value="FilterProgramNot" Label="Not" Dense Color="Color.Secondary" />
                    </MudTooltip>
                </div>

                <MudSelect T="string" Label="@PlanningDisplayNames.Department" MultiSelection
                           @bind-SelectedValues="FilterDepartmentNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var dept in _availableDepartments)
                    {
                        <MudSelectItem T="string" Value="@dept">@dept</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="@PlanningDisplayNames.CapitalProjec" MultiSelection
                           @bind-SelectedValues="FilterCapitalProjectNames"
                           Dense Variant="Variant.Outlined" Clearable
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var cp in _availableCapitalProjects)
                    {
                        <MudSelectItem T="string" Value="@cp">@cp</MudSelectItem>
                    }
                </MudSelect>

                <SearchableDropdown T="string"
                                    Items="_availableTechStacks"
                                    Values="FilterTechStackNames"
                                    ValuesChanged="OnFilterTechStackNamesChanged"
                                    MultiSelect="true"
                                    Label="@PlanningDisplayNames.TechnologyStacks" />

                <MudTextField @bind-Value="FilterLabel" Label="@PlanningDisplayNames.Labels" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Label" Clearable Immediate
                              DebounceInterval="300" Dense Variant="Variant.Outlined" />

                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ClearAll"
                           FullWidth OnClick="ClearFilters" Class="mt-2">
                    @PlanningDisplayNames.ClearFilters
                </MudButton>
            </div>
        </MudDrawer>

        @if (_syncing)
        {
            <MudProgressLinear Indeterminate Color="Color.Warning" Class="mb-2" />
            <MudAlert Severity="Severity.Info" Class="mb-2">Synchronizing Features from Jira...</MudAlert>
        }

        <MudDivider />

        <MudDataGrid T="FeatureRow" Items="@_filteredRows"
                     Hover="true" Striped="true" Dense="true" Elevation="0"
                     Loading="_loading" LoadingProgressColor="Color.Primary">
            <Columns>
                <TemplateColumn Title="@PlanningDisplayNames.JiraId" Sortable="false" CellStyle="width:150px;" Hidden="!_showJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.JiraId))
                        {
                            <a href="@(Configuration["JiraTaskUrl"] + context.Item.JiraId)" target="_blank" style="text-decoration:none">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Style="cursor:pointer">
                                    @context.Item.JiraId
                                </MudChip>
                            </a>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.FeatureName" Title="@PlanningDisplayNames.FeatureName" Sortable="true" Hidden="!_showFeatureName" />

                <TemplateColumn Sortable="false" Hidden="!_showName">
                    <HeaderTemplate>
                        <div style="cursor:pointer; display:flex; align-items:center; user-select:none" @onclick="ToggleSummarySort">
                            <span>@PlanningDisplayNames.Summary</span>
                            @if (_sortColumn == SortableSummary)
                            {
                                <MudIcon Icon="@(_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)"
                                         Size="Size.Small" Class="ml-1" />
                            }
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        <MudText Class="font-weight-bold">@context.Item.Summary</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.PI" Sortable="false" Hidden="!_showPi" CellStyle="width:150px;">
                    <CellTemplate>
                        @if (context.Item.PiName is not null)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.Pis}/{context.Item.PiId}"))">@context.Item.PiName</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.CapitalProjectName" Title="@PlanningDisplayNames.CapitalProjec" Sortable="true" Hidden="!_showCapitalProject" />
                <TemplateColumn Title="@PlanningDisplayNames.BusinessOutcome" Sortable="false" CellStyle="width:150px;" Hidden="!_showBoJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.BoJiraId))
                        {
                            <MudTooltip Text="@context.Item.BoName">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                         OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.BusinessOutcome, context.Item.BoJiraId, context.Item.BoName, context.Item.BoDescription))">
                                    @context.Item.BoJiraId
                                </MudChip>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.PortfolioEpic" Sortable="false" CellStyle="width:150px;" Hidden="!_showEpicJiraId">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.EpicJiraId))
                        {
                            <MudTooltip Text="@context.Item.EpicName">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                         OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.PortfolioEpic, context.Item.EpicJiraId, context.Item.EpicName, context.Item.EpicDescription))">
                                    @context.Item.EpicJiraId
                                </MudChip>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.StrategicObjective" Sortable="false" CellStyle="width:150px;" Hidden="!_showProgramJiraId">
                    <CellTemplate>
                        @if (context.Item.ProgramJiraIds.Count > 0)
                        {
                            @foreach (var prog in context.Item.ProgramJiraIds)
                            {
                                <MudTooltip Text="@prog.Summary">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="cursor:pointer"
                                             OnClick="@(() => OpenJiraDetailsDialogAsync(PlanningDisplayNames.StrategicObjective, prog.JiraId, prog.Summary, prog.Description))">
                                        @prog.JiraId
                                    </MudChip>
                                </MudTooltip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.Labels" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showLabels">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.Labels))
                        {
                            @foreach (var label in context.Item.Labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="mr-1">@label</MudChip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.Teams" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showTeams">
                    <CellTemplate>
                        @foreach (var t in context.Item.Teams.Take(3))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                     Class="mr-1" OnClick="@(() => Nav.NavigateTo($"{RoutingPath.Teams}/{t.Id}"))">@t.Name</MudChip>
                        }
                        @if (context.Item.Teams.Count > 3)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                +@(context.Item.Teams.Count - 3)
                            </MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.TechnologyStacks" Sortable="false" CellStyle="max-width:250px;" Hidden="!_showTechPo">
                    <CellTemplate>
                        @if (context.Item.TechStacks.Count > 0)
                        {
                            @foreach (var ts in context.Item.TechStacks)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="mr-1">@(ts.EstimatedEffort.HasValue ? $"{ts.Name}: {ts.EstimatedEffort}" : ts.Name)</MudChip>
                            }
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.Comments" Title="@PlanningDisplayNames.Comments" Sortable="false" Hidden="!_showComments" />
                <TemplateColumn Title="@PlanningDisplayNames.TargetStart" Sortable="false" CellStyle="width:130px;" Hidden="!_showTargetStart">
                    <CellTemplate>
                        @if (context.Item.TargetStart.HasValue)
                        {
                            @context.Item.TargetStart.Value.ToString("yyyy-MM-dd")
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="@PlanningDisplayNames.TargetEnd" Sortable="false" CellStyle="width:130px;" Hidden="!_showTargetEnd">
                    <CellTemplate>
                        @if (context.Item.TargetEnd.HasValue)
                        {
                            @context.Item.TargetEnd.Value.ToString("yyyy-MM-dd")
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="r => r.StoryPoints" Title="@PlanningDisplayNames.StoryPoints" Sortable="false" CellStyle="width:110px;" Hidden="!_showStoryPoints" />
                @if (_canEdit)
                {
                    <TemplateColumn Title="@PlanningDisplayNames.Actions" CellStyle="text-align:right; width:150px;" Sortable="false" Filterable="false" Hidden="!_showActions">
                        <CellTemplate>
                            <MudFab Class="m-2" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => NavigateToEdit(context.Item.Id))" />
                            <MudFab Class="m-2" StartIcon="@Icons.Material.Filled.DeleteForever" IconColor="Color.Secondary" Size="Size.Small" OnClick="() => ConfirmDeleteAsync(context.Item)" />
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
            <NoRecordsContent><MudText Class="pa-6 mud-text-secondary">No features found.</MudText></NoRecordsContent>
            <PagerContent><MudDataGridPager T="FeatureRow" PageSizeOptions="new[] { 10, 25, 50, 100 }" /></PagerContent>
        </MudDataGrid>
    </MudPaper>
</div>

@code {
    [CascadingParameter(Name = "UserPageAccess")]
    private Dictionary<string, AccessLevel> UserPageAccess { get; set; } = new();

    private List<FeatureRow> _rows = new();
    private List<FeatureRow> _filteredRows = new();
    private bool _loading = true;
    private bool _canEdit;
    private bool _exporting;
    private bool _drawerOpen;
    private bool _columnsPopoverOpen;

    // --- Capital project lookup: JiraKey -> Name ---
    private Dictionary<string, string> _capitalProjectNameByJiraKey = new(StringComparer.OrdinalIgnoreCase);

    // --- Jira state ---
    private string? _userName;
    private bool _jiraConnected;
    private bool _syncing;
    private List<CapitalProject> _allCapitalProjectsForSync = new();

    // --- Sort state ---
    private const string SortableSummary = "Summary";
    private string? _sortColumn;
    private bool _sortDescending;

    // --- URL state ---
    private bool _suppressUrlUpdate = true;

    // --- Column visibility (true = visible) ---
    private bool _showJiraId = true;
    private bool _showFeatureName = true;
    private bool _showName = true;
    private bool _showPi = true;
    private bool _showBoJiraId = true;
    private bool _showEpicJiraId = true;
    private bool _showProgramJiraId = true;
    private bool _showCapitalProject = true;
    private bool _showLabels = true;
    private bool _showTeams = true;
    private bool _showTechPo;
    private bool _showComments;
    private bool _showTargetStart;
    private bool _showTargetEnd;
    private bool _showStoryPoints;
    private bool _showActions = true;

    // --- Available filter values ---
    private List<string> _availableDepartments = new();
    private List<string> _availablePis = new();
    private List<(string JiraId, string? Summary)> _availableBos = new();
    private List<(string JiraId, string? Summary)> _availableEpics = new();
    private List<string> _availablePrograms = new();
    private List<string> _availableCapitalProjects = new();
    private List<string> _availableTechStacks = new();
    private Dictionary<string, string> _cpNameToDept = new();

    private List<string> _availableBoIds => _availableBos.Select(b => b.JiraId).ToList();
    private List<string> _availableEpicIds => _availableEpics.Select(e => e.JiraId).ToList();

    private string LookupBoText(string? jiraId)
    {
        if (string.IsNullOrEmpty(jiraId))
        {
            return string.Empty;
        }

        var bo = _availableBos.FirstOrDefault(b => b.JiraId == jiraId);

        if (bo.JiraId is null)
        {
            return jiraId;
        }

        return string.IsNullOrEmpty(bo.Summary) ? bo.JiraId : $"{bo.JiraId} — {bo.Summary}";
    }

    private string LookupEpicText(string? jiraId)
    {
        if (string.IsNullOrEmpty(jiraId))
        {
            return string.Empty;
        }

        var epic = _availableEpics.FirstOrDefault(e => e.JiraId == jiraId);

        if (epic.JiraId is null)
        {
            return jiraId;
        }

        return string.IsNullOrEmpty(epic.Summary) ? epic.JiraId : $"{epic.JiraId} — {epic.Summary}";
    }

    private RenderFragment<string> BoItemTemplate => jiraId => @<text>
        @{
            var bo = _availableBos.FirstOrDefault(b => b.JiraId == jiraId);
        }
        <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
            <b>@jiraId</b>@(string.IsNullOrEmpty(bo.Summary) ? "" : $" — {bo.Summary}")
        </div>
    </text>;

    private RenderFragment<string> EpicItemTemplate => jiraId => @<text>
        @{
            var epic = _availableEpics.FirstOrDefault(e => e.JiraId == jiraId);
        }
        <div style="font-size:0.8rem; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
            <b>@jiraId</b>@(string.IsNullOrEmpty(epic.Summary) ? "" : $" — {epic.Summary}")
        </div>
    </text>;

    private void OnFilterBoNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterBoNames = values;
    }

    private void OnFilterEpicNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterEpicNames = values;
    }

    private void OnFilterProgramNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterProgramNames = values;
    }

    private void OnFilterTechStackNamesChanged(IReadOnlyCollection<string> values)
    {
        FilterTechStackNames = values;
    }

    // --- Filter properties with debounced recomputation ---

    private Timer? _filterDebounceTimer;
    private const int FilterDebounceMs = 200;

    private void ScheduleRecompute()
    {
        _filterDebounceTimer?.Dispose();
        _filterDebounceTimer = new Timer(_ =>
            InvokeAsync(() => { RecomputeFilteredRows(); UpdateUrl(); StateHasChanged(); }),
            null, FilterDebounceMs, Timeout.Infinite);
    }

    private string? _filterSearchBacking;
    private string? FilterSearch
    {
        get => _filterSearchBacking;
        set { _filterSearchBacking = value; ScheduleRecompute(); }
    }

    private string? _filterLabelBacking;
    private string? FilterLabel
    {
        get => _filterLabelBacking;
        set { _filterLabelBacking = value; ScheduleRecompute(); }
    }

    private bool _filterPiNotBacking;
    private bool FilterPiNot
    {
        get => _filterPiNotBacking;
        set { _filterPiNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterPiNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterPiNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterPiNames
    {
        get => _filterPiNamesBacking;
        set { _filterPiNamesBacking = value; _filterPiNamesSet = new HashSet<string>(value, StringComparer.OrdinalIgnoreCase); ScheduleRecompute(); }
    }

    private bool _filterBoNotBacking;
    private bool FilterBoNot
    {
        get => _filterBoNotBacking;
        set { _filterBoNotBacking = value; ScheduleRecompute(); }
    }

    private IReadOnlyCollection<string> _filterBoNamesBacking = Array.Empty<string>();
    private HashSet<string> _filterBoNamesSet = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyCollection<string> FilterBoNames
