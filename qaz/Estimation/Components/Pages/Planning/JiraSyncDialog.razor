@using Estimation.Core.JiraLogic
@using Estimation.Core.Models
@inject IJiraMetadataService JiraMetadata
@inject IJiraIssueService JiraIssueService
@inject Microsoft.Extensions.Options.IOptions<JiraSettings> JiraConfig

<MudDialog Style="@_dialogStyle" Class="@_dialogClass">
    <TitleContent>
        <div class="d-flex align-center" style="width:100%; gap:8px;">
            <MudIcon Icon="@Icons.Material.Filled.Sync" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Sync from Jira</MudText>
            <MudSpacer />
            <MudTooltip Text="@(_fullscreen ? "Exit fullscreen" : "Fullscreen")">
                <MudIconButton
                    Icon="@(_fullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)"
                    Size="Size.Small"
                    OnClick="ToggleFullscreen" />
            </MudTooltip>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudSelect T="ProjectOption" Value="_selectedProject" ValueChanged="OnProjectChanged"
                           Label="Jira Project"
                           Variant="Variant.Outlined" Required Dense
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in Projects)
                    {
                        <MudSelectItem T="ProjectOption" Value="p">@p.JiraKey — @p.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="6">
                <MudTextField T="string" Value="@IssueType" Label="Issue Type"
                              Variant="Variant.Outlined" ReadOnly Dense />
            </MudItem>

            <MudItem xs="9">
                @if (_labelsLoading)
                {
                    <MudField Label="Labels" Variant="Variant.Outlined">
                        <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Primary" Class="mr-2" />
                        Loading labels...
                    </MudField>
                }
                else
                {
                    <MudSelect T="string" Label="Labels" MultiSelection @bind-SelectedValues="_selectedLabels"
                               Variant="Variant.Outlined" Dense Clearable Disabled="_selectedProject is null"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var label in _availableLabels)
                        {
                            <MudSelectItem T="string" Value="@label.Name">@label.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudItem>
            <MudItem xs="3">
                <MudSelect T="LabelMatchMode" @bind-Value="_labelMatchMode" Label="Match"
                           Variant="Variant.Outlined" Dense>
                    <MudSelectItem T="LabelMatchMode" Value="LabelMatchMode.Any">Any</MudSelectItem>
                    <MudSelectItem T="LabelMatchMode" Value="LabelMatchMode.All">All</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="9">
                @if (_statusesLoading)
                {
                    <MudField Label="Status" Variant="Variant.Outlined">
                        <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Primary" Class="mr-2" />
                        Loading statuses...
                    </MudField>
                }
                else
                {
                    <MudSelect T="string" Label="Status" MultiSelection @bind-SelectedValues="_selectedStatuses"
                               Variant="Variant.Outlined" Dense Clearable Disabled="_selectedProject is null"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var status in _availableStatuses)
                        {
                            <MudSelectItem T="string" Value="@status.Name">@status.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudItem>
            <MudItem xs="3" Class="d-flex align-end">
                <MudCheckBox T="bool" @bind-Value="_excludeStatuses" Label="NOT"
                             Dense Color="Color.Warning" />
            </MudItem>

            <MudItem xs="6">
                <MudSelect T="string" @bind-Value="_selectedPi" Label="Planning Increment"
                           Variant="Variant.Outlined" Dense Clearable
                           Disabled="_selectedProject is null"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var pi in AvailablePiNames)
                    {
                        <MudSelectItem T="string" Value="@pi">@pi</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="6">
                <MudDatePicker @bind-Date="_updatedFrom" Label="Updated From"
                               Variant="Variant.Outlined" Dense Clearable
                               Disabled="_selectedProject is null"
                               DateFormat="yyyy-MM-dd" />
            </MudItem>

            <MudItem xs="12" Class="d-flex justify-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           Disabled="_selectedProject is null || _searching"
                           OnClick="SearchAsync">
                    @if (_searching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Default" Class="mr-2" />
                        @:Searching...
                    }
                    else
                    {
                        @:Search
                    }
                </MudButton>
            </MudItem>

            @if (_searchExecuted)
            {
                <MudItem xs="12">
                    <div class="d-flex align-center mb-2" style="gap:12px; flex-wrap:wrap;">
                        <MudText Typo="Typo.subtitle2">
                            Found @_searchResults.Count issue(s)
                        </MudText>
                        @if (_selectedIssues.Count > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                @_selectedIssues.Count selected
                            </MudChip>
                        }
                    </div>

                    @if (_teamsNotFound.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-2" Dense>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                Teams from Jira with no match in DB (will be ignored):
                            </MudText>
                            <MudText Typo="Typo.body2">@string.Join(", ", _teamsNotFound)</MudText>
                        </MudAlert>
                    }

                    @if (_pisToCreate.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-2" Dense>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                PIs that don't exist in DB and will be created:
                            </MudText>
                            <MudText Typo="Typo.body2">@string.Join(", ", _pisToCreate)</MudText>
                        </MudAlert>
                    }

                    @if (_showPreview && _searchResults.Count > 0)
                    {
                        <MudDataGrid T="JiraIssueResponse" Items="_searchResults"
                                     MultiSelection="true"
                                     SelectOnRowClick="false"
                                     @bind-SelectedItems="_selectedIssues"
                                     Dense Hover Striped
                                     Filterable="true" FilterMode="DataGridFilterMode.ColumnFilterRow"
                                     Style="@_gridStyle"
                                     Class="jira-sync-grid"
                                     Bordered="true">
                            <Columns>
                                <SelectColumn T="JiraIssueResponse" />
                                <PropertyColumn Property="x => x.Key" Title="Key" />
                                <PropertyColumn Property="x => x.Summary" Title="Summary" />
                                <PropertyColumn Property="x => x.Status" Title="Status" />
                                <TemplateColumn Title="Labels">
                                    <CellTemplate>
                                        @if (context.Item.Labels is { Count: > 0 })
                                        {
                                            @string.Join(", ", context.Item.Labels)
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.PlanningIncrement" Title="PI" />
                                <PropertyColumn Property="x => x.GfedTeam" Title="Teams" />
                                <TemplateColumn Title="Updated">
                                    <CellTemplate>
                                        @(context.Item.Updated?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Target Start">
                                    <CellTemplate>
                                        @(context.Item.TargetStart?.ToString("yyyy-MM-dd") ?? "—")
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Target End">
                                    <CellTemplate>
                                        @(context.Item.TargetEnd?.ToString("yyyy-MM-dd") ?? "—")
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.StoryPoints" Title="Story Points" />
                            </Columns>
                        </MudDataGrid>
                    }
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.PlaylistAddCheck"
                   Disabled="@(_selectedIssues.Count == 0)"
                   OnClick="SynchronizeSelected">
            Synchronize selected@(_selectedIssues.Count > 0 ? $" ({_selectedIssues.Count})" : "")
        </MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Sync"
                   Disabled="!_searchExecuted || _searchResults.Count == 0"
                   OnClick="SynchronizeAll">
            Synchronize all
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* Default mode: dialog stretches to viewport-width minus a small margin. */
    .mud-dialog-container:has(.jira-sync-dialog) {
        max-width: calc(100vw - 25px) !important;
        width: calc(100vw - 25px) !important;
    }
    .jira-sync-dialog {
        margin: 15px;
        max-width: calc(100vw - 25px) !important;
        width: calc(100vw - 25px) !important;
    }

    /* Fullscreen mode: container fills the viewport. */
    .mud-dialog-container:has(.jira-sync-dialog-fullscreen) {
        max-width: 100vw !important;
        width: 100vw !important;
        max-height: 100vh !important;
        height: 100vh !important;
        margin: 0 !important;
    }
    .jira-sync-dialog-fullscreen {
        max-width: 100vw !important;
        width: 100vw !important;
        max-height: 100vh !important;
        height: 100vh !important;
        margin: 0 !important;
        border-radius: 0 !important;
    }

    /* Compact column filter row */
    .jira-sync-grid .mud-table-cell.filter-header-cell {
        padding: 2px 6px !important;
    }
    .jira-sync-grid .mud-table-cell.filter-header-cell .mud-input-control {
        margin-top: 0 !important;
    }
    .jira-sync-grid .mud-table-cell.filter-header-cell .mud-input-control .mud-input-slot {
        padding-top: 2px !important;
        padding-bottom: 2px !important;
        font-size: 0.8rem !important;
    }
    .jira-sync-grid .mud-table-cell.filter-header-cell .mud-input-control .mud-input-label {
        font-size: 0.8rem !important;
    }
    .jira-sync-grid .mud-table-head .mud-table-cell {
        padding: 6px 10px !important;
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<ProjectOption> Projects { get; set; } = new();
    [Parameter] public string IssueType { get; set; } = string.Empty;
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public List<string> AvailablePiNames { get; set; } = new();
    [Parameter] public List<string> AvailableTeamNames { get; set; } = new();

    private ProjectOption? _selectedProject;
    private IReadOnlyCollection<string> _selectedLabels = Array.Empty<string>();
    private LabelMatchMode _labelMatchMode = LabelMatchMode.Any;
    private IReadOnlyCollection<string> _selectedStatuses = Array.Empty<string>();
    private bool _excludeStatuses;
    private string? _selectedPi;
    private DateTime? _updatedFrom;

    private List<JiraLabel> _availableLabels = [];
    private List<JiraStatus> _availableStatuses = [];
    private bool _labelsLoading;
    private bool _statusesLoading;

    private List<JiraIssueResponse> _searchResults = [];
    private HashSet<JiraIssueResponse> _selectedIssues = new();
    private List<string> _teamsNotFound = new();
    private List<string> _pisToCreate = new();
    private bool _searching;
    private bool _searchExecuted;
    private bool _showPreview;
    private bool _fullscreen;

    private string _dialogClass => _fullscreen ? "jira-sync-dialog jira-sync-dialog-fullscreen" : "jira-sync-dialog";

    private string _dialogStyle => _fullscreen ? "" : "max-width: calc(100vw - 25px); width: calc(100vw - 25px);";

    private string _gridStyle => _fullscreen
        ? "height: calc(100vh - 420px); overflow-y:auto;"
        : "max-height: 60vh; min-height: 360px; overflow-y:auto;";

    private void ToggleFullscreen()
    {
        _fullscreen = !_fullscreen;
    }

    protected override void OnInitialized()
    {
        _showPreview = !JiraConfig.Value.SkipSyncPreview;
    }

    private void OnProjectChanged(ProjectOption? value)
    {
        if (_selectedProject == value)
        {
            return;
        }
        _selectedProject = value;
        _searchExecuted = false;
        _searchResults.Clear();
        _selectedIssues.Clear();
        _teamsNotFound.Clear();
        _pisToCreate.Clear();
        _selectedLabels = Array.Empty<string>();
        _selectedStatuses = Array.Empty<string>();
        _selectedPi = null;
        if (value is not null)
        {
            _ = LoadMetadataAsync(value.JiraKey);
        }
    }

    private async Task LoadMetadataAsync(string projectKey)
    {
        _labelsLoading = true;
        _statusesLoading = true;
        StateHasChanged();

        var labelsTask = JiraMetadata.GetLabelsAsync(UserName, projectKey);
        var statusesTask = JiraMetadata.GetStatusesAsync(UserName, projectKey);

        try
        {
            _availableLabels = await labelsTask;
        }
        catch
        {
            _availableLabels = [];
        }
        finally
        {
            _labelsLoading = false;
            StateHasChanged();
        }

        try
        {
            _availableStatuses = await statusesTask;
        }
        catch
        {
            _availableStatuses = [];
        }
        finally
        {
            _statusesLoading = false;
            StateHasChanged();
        }
    }

    private string BuildJql()
    {
        var jql = $"project = \"{_selectedProject!.JiraKey}\" AND issuetype = \"{IssueType}\"";

        var labels = _selectedLabels.ToList();
        if (labels.Count > 0)
        {
            if (_labelMatchMode == LabelMatchMode.All)
            {
                foreach (var label in labels)
                {
                    jql += $" AND labels = \"{label}\"";
                }
            }
            else
            {
                var labelList = string.Join(", ", labels.Select(l => $"\"{l}\""));
                jql += $" AND labels in ({labelList})";
            }
        }

        var statuses = _selectedStatuses.ToList();
        if (statuses.Count > 0)
        {
            var statusList = string.Join(", ", statuses.Select(s => $"\"{s}\""));
            var op = _excludeStatuses ? "not in" : "in";
            jql += $" AND status {op} ({statusList})";
        }

        if (!string.IsNullOrWhiteSpace(_selectedPi))
        {
            var piFieldId = JiraConfig.Value.PlanningIncrementCustomFieldId;
            if (!string.IsNullOrWhiteSpace(piFieldId))
            {
                var fieldRef = piFieldId.StartsWith("customfield_", StringComparison.OrdinalIgnoreCase)
                    ? $"cf[{piFieldId.Substring("customfield_".Length)}]"
                    : piFieldId;
                jql += $" AND {fieldRef} = \"{_selectedPi}\"";
            }
        }

        if (_updatedFrom.HasValue)
        {
            jql += $" AND updated >= \"{_updatedFrom.Value:yyyy-MM-dd}\"";
        }

        return jql;
    }

    private async Task SearchAsync()
    {
        if (_selectedProject is null)
        {
            return;
        }

        _searching = true;
        _searchExecuted = false;
        StateHasChanged();

        try
        {
            var jql = BuildJql();
            _searchResults = await JiraIssueService.SearchIssuesAsync(UserName, jql);
            _selectedIssues.Clear();
            ComputeWarnings();
            _searchExecuted = true;
        }
        catch (Exception ex)
        {
            _searchResults = [];
            _selectedIssues.Clear();
            _teamsNotFound.Clear();
            _pisToCreate.Clear();
            _searchExecuted = true;
            Serilog.Log.Error(ex, "Jira search failed");
        }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private void ComputeWarnings()
    {
        var piSet = new HashSet<string>(AvailablePiNames, StringComparer.OrdinalIgnoreCase);
        var teamNames = AvailableTeamNames.Where(n => !string.IsNullOrEmpty(n)).ToList();

        var unmatchedTeams = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var missingPis = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var issue in _searchResults)
        {
            if (!string.IsNullOrWhiteSpace(issue.GfedTeam))
            {
                var jiraTeams = issue.GfedTeam.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                foreach (var jt in jiraTeams)
                {
                    var matched = teamNames.Any(tn => jt.Contains(tn, StringComparison.OrdinalIgnoreCase));
                    if (!matched)
                    {
                        unmatchedTeams.Add(jt);
                    }
                }
            }

            if (!string.IsNullOrWhiteSpace(issue.PlanningIncrement)
                && !piSet.Contains(issue.PlanningIncrement.Trim()))
            {
                missingPis.Add(issue.PlanningIncrement.Trim());
            }
        }

        _teamsNotFound = unmatchedTeams.OrderBy(s => s).ToList();
        _pisToCreate = missingPis.OrderBy(s => s).ToList();
    }

    private void Cancel() => MudDialog.Cancel();

    private void SynchronizeAll()
    {
        var result = new JiraSyncDialogResult(_selectedProject!.Id, _selectedProject.JiraKey, _searchResults);
        MudDialog.Close(DialogResult.Ok(result));
    }

    private void SynchronizeSelected()
    {
        if (_selectedIssues.Count == 0)
        {
            return;
        }
        var issues = _searchResults.Where(_selectedIssues.Contains).ToList();
        var result = new JiraSyncDialogResult(_selectedProject!.Id, _selectedProject.JiraKey, issues);
        MudDialog.Close(DialogResult.Ok(result));
    }

    public enum LabelMatchMode { Any, All }

    public record ProjectOption(int Id, string JiraKey, string Name);
    public record JiraSyncDialogResult(int ProjectId, string ProjectKey, List<JiraIssueResponse> Issues);
}
